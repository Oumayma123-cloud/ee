/* ========== Container ========== */
page {
  background: #FFFFFF;
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
}

.scroll-content {
  flex: 1;
  overflow: hidden;
}

.scroll-inner {
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
}

/* ========== Header ========== */
.header-section {
  background: #FFFFFF;
  padding-bottom: 0;
  position: relative;
  z-index: 10;
}

.header-content {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 80rpx 14rpx 28rpx;
  height: 110rpx;
  box-sizing: border-box;
}

.back-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  z-index: 10;
}

.back-circle {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: #F0F0F0;
  display: flex;
  justify-content: center;
  align-items: center;
}

.back-arrow-txt {
  font-size: 26rpx;
  color: #333;
  font-weight: normal;
  line-height: 1;
}

.back-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}

.logo {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 140rpx;
  height: 56rpx;
  z-index: 5;
}

/* Bubble avatar */
.avatar-container {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
}

.avatar-bubble {
  position: relative;
  width: 100rpx;
  height: 110rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-img {
  width: 100rpx;
  height: 110rpx;
  display: block;
}

/* ========== Hero Section ========== */
.hero-section {
  background: #A9D3EC;
  height: 300rpx;
  display: flex;
  flex-direction: row;
  align-items: stretch;
  padding-left: 28rpx;
  padding-right: 0;
  position: relative;
  overflow: visible;
  z-index: 2;
}

.hero-left {
  flex: 1;
  display: flex;
  align-items: center;
  padding-right: 12rpx;
}

.hero-bubble {
  background: #FAF0ED;
  border-radius: 20rpx;
  padding: 16rpx 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
  width: 320rpx;
}

.hero-bubble-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #1A1A1A;
  line-height: 1.3;
}

.hero-right {
  width: 330rpx;
  height: 300rpx;
  flex-shrink: 0;
  align-self: flex-end;
  margin-top: 0;
  z-index: 5;
  overflow: visible;
}

.hero-woman {
  width: 330rpx;
  height: 300rpx;
  display: block;
}

/* ========== Location/Map Section ========== */
.location-section {
  background: #5391C0;
  padding: 24rpx 40rpx 24rpx;
  position: relative;
  z-index: 3;
}

.location-content {
  display: flex;
  flex-direction: column;
}

/* Address Card */
.address-card {
  background: #6099C2; /* Semi-desaturated blue-grey as mockup */
  border-radius: 20rpx;
  height: 96rpx;
  padding: 0 32rpx;
  margin-bottom: 16rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.address-details {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.address-title {
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: bold;
  margin-bottom: 2rpx;
}

.address-text {
  color: #FFFFFF;
  font-size: 20rpx;
  opacity: 0.95;
  white-space: nowrap;
  text-overflow: ellipsis;
  overflow: hidden;
  max-width: 480rpx;
}

.edit-icon {
  color: #FFFFFF;
  font-size: 32rpx;
}

/* Map Container */
.map-container {
  width: 100%;
  height: 420rpx;
  margin: 0 auto; /* Center the square map */
  border: 4rpx solid #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  display: block;
  box-sizing: border-box;
}

.map-image {
  width: 100%;
  height: 100%;
  display: block;
}

/* ========== Action Buttons ========== */
.btn-wrap {
  background: #FFFFFF;
  padding: 24rpx 40rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  align-items: center;
}

.btn {
  border-radius: 60rpx;
  height: 90rpx;
  width: 500rpx; /* Reduced width to match Image 2 exactly */
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  box-sizing: border-box;
}

.btn:active {
  opacity: 0.85;
}

.btn-confirm {
  background: #5FA1CD;
  box-shadow: 0 4rpx 12rpx rgba(95, 161, 205, 0.25);
}

.btn-locate {
  background: #234D6F; /* Deep steel blue as mockup */
  box-shadow: 0 4rpx 12rpx rgba(35, 77, 111, 0.25);
}

.btn-txt {
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

/* ========== Bottom Spacer ========== */
.bottom-spacer {
  height: 160rpx;
  background: #FFFFFF;
}
