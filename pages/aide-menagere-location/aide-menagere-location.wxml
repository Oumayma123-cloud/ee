<!-- ========== Page Confirmation Lieu Aide Ménagère ========== -->
<view class="container">
  <scroll-view class="scroll-content" scroll-y="true" show-scrollbar="false">
    <view class="scroll-inner">

      <!-- 1. Header -->
      <view class="header-section" style="padding-top: {{statusBarHeight + 10}}px;">
        <view class="header-content">
          <view class="back-btn" bindtap="onBack">
            <view class="back-circle">
              <text class="back-arrow-txt">←</text>
            </view>
            <text class="back-label">Retour</text>
          </view>
          <image src="/assets/logtiqqa.png" class="logo" mode="aspectFit"></image>
          <view class="avatar-container">
            <view class="avatar-bubble">
              <image src="/assets/avatar/avatar-user.png" class="avatar-img" mode="aspectFit"></image>
            </view>
          </view>
        </view>
      </view>

      <!-- 2. Hero Section -->
      <view class="hero-section">
        <view class="hero-left">
          <view class="hero-bubble">
            <text class="hero-bubble-text">{{bubbleText}}</text>
          </view>
        </view>
        <view class="hero-right">
          <image class="hero-woman" src="/assets/aide-menagere-woman-transparent-v2.png" mode="aspectFit"></image>
        </view>
      </view>

      <!-- 3. Location/Map Section -->
      <view class="location-section">
        <view class="location-content">
          <!-- Address Card -->
          <view class="address-card" bindtap="onEditAddress">
            <view class="address-details">
              <text class="address-title">Lieu</text>
              <text class="address-text">{{address}}</text>
            </view>
            <text class="edit-icon">✎</text>
          </view>

          <!-- Map Container -->
          <view class="map-container">
            <image src="/assets/map-tracking.png" style="width: 100%; height: 100%; display: block;" mode="aspectFill"></image>
          </view>
        </view>
      </view>

      <!-- 4. Action Buttons -->
      <view class="btn-wrap">
        <view class="btn btn-confirm" bindtap="onConfirm">
          <text class="btn-txt">CONFIRMER</text>
        </view>
        <view class="btn btn-locate" bindtap="onLocate">
          <text class="btn-txt">ACTIVEZ LA LOCALISATION</text>
        </view>
      </view>

      <view class="bottom-spacer"></view>
    </view>
  </scroll-view>

  <bottom-nav-bar variant="fixed" message-count="6" bind:navtap="onNavTap" />
</view>
