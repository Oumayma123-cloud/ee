.urgence-container {
  height: 100vh;
  background-color: #ffffff;
  color: #333333;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
}

.body-scroll {
  flex: 1;
  width: 100%;
  height: 0;
}

/* Header Styles */
.header {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  background: white;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.back-circle {
  width: 50rpx;
  height: 50rpx;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  font-size: 24rpx;
  color: #666;
}

.back-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.logo {
  width: 180rpx;
  height: 60rpx;
  display: block;
  flex-shrink: 0;
  margin: 0 auto;
}

.avatar-bubble {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  position: relative;
  z-index: 10;
}

.avatar-wrap {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: transparent;
}

.avatar-wrap--bubble {
  border: none;
  box-shadow: none;
  overflow: hidden;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

/* Hero Section */
.hero-section {
  background-color: #D6998A;
  height: 420rpx;
  position: relative;
  display: flex;
  align-items: flex-end;
  padding: 0;
  margin-top: 0;
  overflow: visible;
}

.operator-container {
  width: 300rpx;
  height: 350rpx;
  position: absolute;
  left: 40rpx;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  z-index: 2;
}

.operator-img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.question-bubble {
  position: absolute;
  right: 40rpx;
  top: 80rpx;
  background: white;
  padding: 30rpx 40rpx;
  border-radius: 40rpx;
  width: 45%;
  box-shadow: 0 10rpx 20rpx rgba(0,0,0,0.1);
}

.bubble-text {
  font-size: 32rpx;
  color: #333;
  line-height: 1.4;
  font-weight: 500;
}

.text-red {
  color: #E63946;
  font-weight: 600;
}

/* Separator Bar */
.separator-bar {
  height: 60rpx;
  background-color: #F8DCD9;
  width: 100%;
}

/* Card Section */
.cards-section {
  display: flex;
  justify-content: center;
  padding: 60rpx 40rpx;
}

.confirm-card-single {
  width: 350rpx;
  background: white;
  border-radius: 30rpx;
  overflow: hidden;
  box-shadow: 0 15rpx 40rpx rgba(0,0,0,0.1);
  display: flex;
  flex-direction: column;
}

.image-area {
  height: 280rpx;
  background: #FCE6E1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.card-urg-img {
  width: 80%;
  height: 80%;
}

.cancel-x {
  position: absolute;
  font-size: 200rpx;
  color: rgba(100, 100, 100, 0.5);
  font-weight: 300;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.card-footer {
  background: #D6998A;
  padding: 30rpx 20rpx;
  display: flex;
  justify-content: center;
}

.btn-confirm-final {
  width: 90%;
  background: #FF0000;
  color: white;
  padding: 20rpx 0;
  border-radius: 40rpx;
  text-align: center;
  font-weight: 800;
  font-size: 28rpx;
  box-shadow: 0 6rpx 12rpx rgba(255,0,0,0.3);
}

.bottom-spacer {
  height: 180rpx;
}
