/* ============================================================
   Video Detail Page – video_detail.wxss
   ============================================================ */

.video-detail-container {
  height: 100vh;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: hidden;
}

.mobile-card {
  width: 750rpx;
  height: 100%;
  margin: 0 auto;
  border-radius: 57.69rpx;
  overflow: hidden;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  position: relative;
  box-sizing: border-box;
}

/* ── Header ─────────────────────────────────────────────── */
.horaire-header-wrap {
  flex-shrink: 0;
  background: #ffffff;
  padding-top: 10rpx;
  padding-bottom: 8rpx;
  box-sizing: border-box;
}

.status-row {
  display: flex;
  align-items: center;
  padding: 0 34rpx 0rpx;
  box-sizing: border-box;
}

.top-bar--horaire {
  position: relative;
  width: 100%;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx 0 20rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.back-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  z-index: 15;
}

.back-circle {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #f2f2f2;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #333;
  font-size: 24rpx;
  font-weight: bold;
}

.back-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #000000;
}

.logo {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 60rpx;
  z-index: 10;
}

.avatar-bubble {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  position: relative;
  z-index: 15;
}

.avatar-wrap {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: transparent;
  overflow: hidden;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-bubble-tail {
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-top: 8rpx solid #c19a89;
  margin-top: -2rpx;
}

/* ── Hero Section ────────────────────────────────────────── */
.video-hero-area {
  width: 100%;
  flex-shrink: 0;
}

.video-hero-main {
  position: relative;
  width: 100%;
  height: 400rpx;
}

.video-hero-img {
  width: 100%;
  height: 100%;
}

.video-hero-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 90rpx;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  padding: 0 40rpx;
}

.hero-overlay-content {
  width: 100%;
  height: 60rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.hero-overlay-logo {
  width: 70rpx;
  height: 30rpx;
  filter: brightness(0) invert(1);
}

.hero-overlay-divider {
  width: 2rpx;
  height: 30rpx;
  background: rgba(255, 255, 255, 0.8);
  margin: 0 16rpx;
}

.hero-overlay-text-wrap {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.hero-overlay-name {
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  line-height: 1.1;
  text-transform: uppercase;
}

.hero-overlay-role {
  color: #dddddd;
  font-size: 14rpx;
  font-weight: 500;
  text-transform: uppercase;
  line-height: 1.1;
}

/* ── Content Container & Title ───────────────────────────── */
.video-content-container {
  display: flex;
  flex: 1;
  min-height: 0;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 110rpx; /* Space for bottom nav */
}

.content-scroll {
  flex: 1;
  height: 100%;
}

.aide-header {
  display: flex;
  justify-content: center;
  align-items: baseline;
  padding: 40rpx 0 30rpx;
  gap: 12rpx;
}

.aide-title-script {
  font-family: 'Brush Script MT', 'Comic Sans MS', cursive;
  font-size: 46rpx;
  color: #444444;
}

.aide-title-bold {
  font-size: 32rpx;
  font-weight: 800;
  color: #727272;
  letter-spacing: 2rpx;
}

/* ── Cards Grid ────────────────────────────────────────── */
.aide-grid {
  display: grid;
  grid-template-columns: repeat(2, 250rpx);
  gap: 24rpx;
  justify-content: center;
  padding: 0 40rpx 60rpx;
}

.aide-card {
  width: 250rpx;
  height: 300rpx;
  background: #EAF0E8; /* Light mint green */
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.05);
}

.aide-card-img {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: auto;
}

.aide-card-label {
  font-size: 20rpx;
  font-weight: 800;
  color: #6A6258; /* Brownish grey */
  text-align: center;
  line-height: 1.3;
  margin-top: 16rpx;
}

.bottom-spacer {
  height: 60rpx;
}
