.container {
  min-height: 100vh;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.mobile-card {
  width: 750rpx;
  margin: 0 auto;
  border-radius: 57.69rpx;
  overflow: hidden;
  background: #ffffff;
  flex: 1;
  display: flex;
  flex-direction: column;
  position: relative;
  padding-top: 8rpx;
}

.content-scroll {
  flex: 1;
  overflow-y: auto;
  background: #ffffff;
}

/* Header Styles */
.horaire-header-wrap {
  flex-shrink: 0;
  background: #ffffff;
  min-height: 120rpx;
  height: auto;
  padding-top: 10rpx;
  padding-bottom: 8rpx;
  box-sizing: border-box;
}

.status-row {
  display: flex;
  align-items: center;
  padding: 0 34rpx 0rpx;
  box-sizing: border-box;
  min-height: 0;
  height: auto;
}

.top-bar--horaire {
  position: relative;
  width: 100%;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx 0 20rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.back-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.back-circle {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #f2f2f2;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #333;
  font-size: 24rpx;
  font-weight: bold;
}

.back-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #000000;
}

.logo {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 60rpx;
}

.avatar-bubble {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  position: relative;
  z-index: 10;
  margin-right: 20rpx;
}

.avatar-wrap {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: transparent;
  overflow: hidden;
}

.avatar-wrap--bubble {
  border: none;
  box-shadow: none;
  overflow: hidden;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-bubble-tail {
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-top: 8rpx solid #c19a89;
  margin-top: -2rpx;
}

/* Hero Section */
.ess-hero-area {
  width: 100%;
  flex-shrink: 0;
}

.ess-hero-strip {
  height: 50rpx;
  background: #e8d0c1; /* Light brown/tan strip */
}

.ess-hero-main {
  position: relative;
  width: 100%;
  height: 460rpx;
}

.ess-hero-img {
  width: 100%;
  height: 100%;
}

.ess-hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding-left: 40rpx;
  padding-bottom: 75rpx;
  box-sizing: border-box;
}

.ess-hero-title {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  max-width: 350rpx;
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.ess-hero-btn {
  width: 180rpx;
  height: 54rpx;
  background: #ffffff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.1);
}

.ess-hero-btn-txt {
  color: #333333;
  font-size: 24rpx;
  font-weight: 700;
}

/* Main Content */
.ess-main {
  padding: 40rpx 70rpx 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ess-title-row {
  display: flex;
  align-items: baseline;
  gap: 15rpx;
  margin-bottom: 40rpx;
}

.ess-title-script {
  font-family: cursive, serif;
  font-size: 54rpx;
  color: #333333;
}

.ess-title-bold {
  font-size: 44rpx;
  font-weight: 800;
  color: #9c7661; /* Brownish color from screenshot */
  letter-spacing: 2rpx;
}

/* Grid Layout */
.ess-grid-container {
  display: flex;
  width: 100%;
}

.ess-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30rpx;
  flex: 1;
}

.ess-card {
  height: 280rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 10rpx 20rpx;
  box-sizing: border-box;
}

.ess-card-img {
  width: 100%;
  height: 180rpx;
}

.ess-card-label {
  font-size: 24rpx;
  font-weight: 800;
  color: #ffffff;
  text-align: center;
  letter-spacing: 1rpx;
}

.ess-card--sante { background: #b2d699; }
.ess-card--clubs { background: #A76A65; }
.ess-card--services { background: #a8c8e1; }
.ess-card--plans { background: #f6d674; }

/* Hero Navigation Strip */
.ess-hero-nav {
  height: 60rpx;
  background: #c28b70;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.ess-hero-nav-arrow {
  width: 44rpx;
  height: 44rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #c28b70;
  font-size: 24rpx;
  font-weight: bold;
}

/* Scrollbar Decorative */
.ess-scrollbar {
  width: 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  height: 440rpx; /* Shorter scrollbar */
  align-self: center; /* Center vertically */
}

.ess-scroll-arrow {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(180deg, #ffffff 0%, #ededed 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #7f8c8d;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.12);
  border: 1rpx solid #e0e0e0;
}

.ess-scroll-track {
  width: 24rpx;
  flex: 1;
  background: #ffffff;
  border-radius: 12rpx;
  position: relative;
  box-shadow: inset 0 2rpx 6rpx rgba(0, 0, 0, 0.06), 0 2rpx 4rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #e2e2e2;
}

.ess-scroll-thumb {
  position: absolute;
  top: 40rpx;
  left: 0;
  width: 100%;
  height: 120rpx;
  background: #6b4c3e; /* Brown thumb */
  border-radius: 12rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.ess-bottom-spacer {
  height: 100rpx;
}
