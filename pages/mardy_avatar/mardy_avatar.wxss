.container {
  min-height: 100vh;
  background-color: #ffffff;
  display: flex;
  flex-direction: column;
  color: #333333;
}

.header {
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  padding-top: 20rpx;
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.back-circle {
  width: 50rpx;
  height: 50rpx;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  font-size: 24rpx;
  color: #666;
}

.back-text {
  font-size: 26rpx;
  color: #000;
  font-weight: 600;
}

.logo {
  width: 150rpx;
  height: 60rpx;
}

.content {
  flex: 1;
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.title {
  font-size: 42rpx;
  font-weight: 800;
  text-align: left;
  color: #000000;
  margin-bottom: 80rpx;
  line-height: 1.4;
  width: 100%;
}

.avatars-row {
  display: flex;
  justify-content: center;
  gap: 60rpx;
  width: 100%;
}

.avatar-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 220rpx;
}

.avatar-name {
  font-size: 40rpx;
  color: #000000;
  margin-bottom: 20rpx;
  font-family: 'Times New Roman', serif;
  font-style: italic;
}

.avatar-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 20rpx;
  object-fit: cover;
  margin-bottom: 30rpx;
}

.checkbox-wrapper {
  width: 100%;
  display: flex;
  justify-content: center;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid #cccccc;
  border-radius: 8rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.checkbox.checked {
  background: #8F6E61;
  border-color: #8F6E61;
}

.checkbox.checked::after {
  content: '';
  width: 12rpx;
  height: 20rpx;
  border: solid white;
  border-width: 0 4rpx 4rpx 0;
  transform: rotate(45deg);
  margin-bottom: 6rpx;
}
