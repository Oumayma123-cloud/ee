.container {
  min-height: 100vh;
  background-color: #B88E7E;
  display: flex;
  flex-direction: column;
}

.header-bg {
  width: 100%;
  padding-bottom: 60rpx;
}

.header-content {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  padding: 0 40rpx;
  height: 100rpx;
}

.back-btn {
  position: absolute;
  left: 40rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  padding: 20rpx;
}

.back-arrow {
  color: #fff;
  font-size: 40rpx;
  font-weight: 300;
}

.logo-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
}

.logo {
  width: 200rpx;
}

.content-card {
  flex: 1;
  background-color: #ffffff;
  border-radius: 60rpx 60rpx 0 0;
  padding: 80rpx 50rpx;
  display: flex;
  flex-direction: column;
  color: #333333;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #000000;
  text-align: center;
  margin-bottom: 60rpx;
}

.form-container {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.input-group {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 600;
  color: #000000;
}

.input {
  height: 90rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  color: #333333;
  background: #ffffff;
}

.btn-ajouter {
  margin-top: 40rpx;
  height: 100rpx;
  background-color: #B88E7E;
  color: #ffffff;
  border-radius: 50rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

/* Modal Overlay */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(5px);
}

.modal-box {
  background: #504D4A;
  width: 80%;
  border-radius: 30rpx;
  padding: 80rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-text {
  color: #ffffff;
  font-size: 28rpx;
  text-align: center;
  line-height: 1.5;
  margin-bottom: 60rpx;
}

.modal-close-btn {
  width: 80rpx;
  height: 80rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-close-text {
  color: #333333;
  font-size: 32rpx;
  font-weight: 600;
}
