/* Styles for Abonnement page */
.container {
  height: 100vh;
  width: 100%;
  background: #1a1a1a;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.mobile-card {
  width: 750rpx;
  margin: 0 auto;
  border-radius: 57.69rpx;
  overflow: hidden;
  background: #ffffff;
  flex: 1;
  display: flex;
  flex-direction: column;
  position: relative;
  padding-top: 8rpx;
}

.content-scroll {
  flex: 1;
  overflow-y: auto;
  background: #ffffff;
}

/* Header Styles */
.horaire-header-wrap {
  flex-shrink: 0;
  background: #ffffff;
  min-height: 120rpx;
  height: auto;
  padding-top: 10rpx;
  padding-bottom: 8rpx;
  box-sizing: border-box;
}

.status-row {
  display: flex;
  align-items: center;
  padding: 0 34rpx 0rpx;
  box-sizing: border-box;
  min-height: 0;
  height: auto;
}

.top-bar--horaire {
  position: relative;
  width: 100%;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx 0 20rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.back-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.back-circle {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #fcfcfc;
  border: 1px solid #eeeeee;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #333;
  font-size: 24rpx;
}

.back-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #000000;
}

.logo {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 60rpx;
}

.avatar-bubble {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  position: relative;
  z-index: 10;
}

.avatar-wrap {
  width: 150rpx;
  height: 150rpx;
  background: transparent;
}

.avatar {
  width: 100%;
  height: 100%;
}

/* Page Content */
.page-content {
  padding: 0 40rpx;
  display: flex;
  flex-direction: column;
}

.page-header {
  margin-top: 20rpx;
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #1a1a1a;
}

.subtitle-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
  text-align: center;
}

.subtitle-bold {
  font-size: 38rpx;
  font-weight: 700;
  color: #2c3e50;
  margin-bottom: 15rpx;
}

.subtitle-text {
  font-size: 24rpx;
  color: #777777;
  line-height: 1.4;
  padding: 0 10rpx;
}

/* Blue Info Box */
.info-box-blue {
  background: #f0f6ff;
  border: 2rpx solid #d4e3f5;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: flex-start;
  margin-bottom: 40rpx;
}

.info-icon-blue {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid #233a76;
  color: #233a76;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: bold;
  font-family: serif;
  margin-right: 16rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
}

.info-text-blue {
  font-size: 24rpx;
  color: #233a76;
  line-height: 1.5;
  flex: 1;
}

.text-bold {
  font-weight: 700;
}

/* Plans */
.plans-container {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.plan-card {
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 30rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
  transition: all 0.3s;
}

.plan-card--selected {
  border-color: #9d7c6b;
  background: #fbf7f4;
}

.plan-info {
  display: flex;
  flex-direction: column;
}

.plan-duration {
  font-size: 28rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 10rpx;
}

.plan-price-wrap {
  display: flex;
  align-items: baseline;
}

.plan-price-bold {
  font-size: 34rpx;
  font-weight: 800;
  color: #1a1a1a;
}

.plan-price-small {
  font-size: 24rpx;
  color: #888888;
  margin-left: 6rpx;
}

.plan-radio {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 4rpx solid #dddddd;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.plan-radio--selected {
  border: none;
  background: #9d7c6b;
}

.radio-check {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: bold;
}

/* Brown Info Box */
.info-box-brown {
  background: #ffffff;
  border: 2rpx solid #9d7c6b;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: flex-start;
  margin-bottom: 50rpx;
}

.info-icon-brown {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid #9d7c6b;
  color: #9d7c6b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: bold;
  font-family: serif;
  margin-right: 16rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
}

.info-text-brown {
  font-size: 24rpx;
  color: #9d7c6b;
  line-height: 1.5;
  flex: 1;
}

/* Action Section */
.action-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn-continue {
  width: 100%;
  height: 90rpx;
  background: #9d7c6b;
  border-radius: 45rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.footer-links {
  font-size: 22rpx;
  text-align: center;
  margin-top: 10rpx;
}

.footer-text {
  color: #888888;
}

.footer-link {
  color: #333333;
  font-weight: 700;
  text-decoration: underline;
}

.bottom-spacer {
  height: 120rpx;
}
