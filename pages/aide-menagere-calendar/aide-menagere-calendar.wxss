/* ========== Container ========== */
page {
  background: #CEE8F8;
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #CEE8F8;
}

.scroll-content {
  flex: 1;
  overflow: hidden;
}

.scroll-inner {
  display: flex;
  flex-direction: column;
}

/* ========== Header ========== */
.header-section {
  background: #CEE8F8;
  padding-bottom: 0;
  position: relative;
  z-index: 10;
}

.header-content {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 28rpx 14rpx;
}

.back-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
}

.back-circle {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: #F0F0F0;
  display: flex;
  justify-content: center;
  align-items: center;
}

.back-arrow-txt {
  font-size: 22rpx;
  color: #333;
  font-weight: 900;
  line-height: 1;
}

.back-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}

.logo {
  width: 140rpx;
  height: 56rpx;
}

/* Circular avatar */
.avatar-container {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  overflow: hidden;
  border: 3rpx solid #CEE8F8;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.15);
}

.avatar-img {
  width: 80rpx;
  height: 80rpx;
  display: block;
}

/* ========== Hero Section ========== */
/*
 * Woman (hero-right) is a normal flex child with negative margin-top
 * so her head pokes UP into the header area.
 * align-self: flex-end anchors her to the BOTTOM of the hero.
 * overflow: visible lets her head render above the hero boundary.
 */
.hero-section {
  background: #CEE8F8;
  height: 260rpx;
  display: flex;
  flex-direction: row;
  align-items: stretch;
  padding-left: 28rpx;
  padding-right: 0;
  position: relative;
  overflow: visible;
  z-index: 2;
}

.hero-left {
  flex: 1;
  display: flex;
  align-items: center;
  padding-right: 12rpx;
}

.hero-bubble {
  background: #FFFFFF;
  border-radius: 18rpx;
  padding: 22rpx 26rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.hero-bubble-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #1A3D5C;
  line-height: 1.5;
}

/* Woman: in-flow, anchored to bottom, overflows upward with negative margin */
.hero-right {
  width: 240rpx;
  height: 350rpx;
  flex-shrink: 0;
  align-self: flex-end;
  margin-top: -90rpx;
  z-index: 5;
  overflow: visible;
}

.hero-woman {
  width: 240rpx;
  height: 314rpx;
  display: block;
}

/* ========== Calendar Section ========== */
/*
 * z-index: 3 clips woman's downward overflow.
 * BLUE background like the design — dark navy text on blue.
 */
.calendar-section {
  background: #CEE8F8;
  padding: 24rpx 32rpx 28rpx;
  position: relative;
  z-index: 3;
  margin-top: 0;
}

/* Month Navigation */
.month-nav {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.month-arrow {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.12);
}

.month-arrow-txt {
  font-size: 20rpx;
  color: #1A3D5C;
  font-weight: 900;
}

.month-title-wrap {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 18rpx;
}

/* JUILLET: large bold dark navy on blue bg */
.month-name-txt {
  font-size: 44rpx;
  font-weight: 900;
  color: #1A3D5C;
  letter-spacing: 1rpx;
}

/* 2025: smaller dark */
.year-txt {
  font-size: 30rpx;
  font-weight: 400;
  color: #1A3D5C;
}

/* Days Header */
.days-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-bottom: 8rpx;
  padding-bottom: 8rpx;
}

.day-name {
  flex: 1;
  font-size: 22rpx;
  font-weight: 600;
  color: #FFFFFF !important;
  opacity: 0.85;
  text-align: center;
}

/* Calendar Grid */
.calendar-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.day-cell-wrap {
  width: 14.2857%;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 70rpx;
}

.day-cell {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Selected day: white rounded square with dark text */
.day-cell--selected {
  background: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.12);
}

.day-num {
  font-size: 26rpx;
  font-weight: 500;
  color: #FFFFFF !important;
  text-align: center;
}

.day-cell--selected .day-num {
  color: #1A3D5C !important;
  font-weight: 800;
}

.day-num--selected {
  color: #1A3D5C !important;
  font-weight: 800;
}

/* ========== SUIVANT Button ========== */
.btn-suivant-wrap {
  background: #CEE8F8;
  padding: 32rpx 60rpx 36rpx;
}

.btn-suivant {
  background: #1A3D5C;
  border-radius: 60rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 18rpx rgba(26, 61, 92, 0.28);
}

.btn-suivant:active {
  opacity: 0.85;
}

.btn-suivant-txt {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
}

/* ========== Bottom Spacer ========== */
.bottom-spacer {
  height: 0;
}

