/* ========== Container ========== */
page {
  background: #FFFFFF;
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
}

.scroll-content {
  flex: 1;
  overflow: hidden;
}

.scroll-inner {
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
}

/* ========== Header ========== */
.header-section {
  background: #FFFFFF;
  padding-bottom: 0;
  position: relative;
  z-index: 10;
}

.header-content {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 28rpx 14rpx;
}

.back-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
}

.back-circle {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: #F0F0F0;
  display: flex;
  justify-content: center;
  align-items: center;
}

.back-arrow-txt {
  font-size: 22rpx;
  color: #333;
  font-weight: 900;
  line-height: 1;
}

.back-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}

.logo {
  width: 140rpx;
  height: 56rpx;
}

/* Circular avatar / Bubble avatar */
.avatar-container {
  position: relative;
}

.avatar-bubble {
  position: relative;
  width: 100rpx;
  height: 110rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-img {
  width: 100rpx;
  height: 110rpx;
  display: block;
}

/* ========== Hero Section ========== */
/*
 * Woman (hero-right) is a normal flex child with negative margin-top
 * so her head pokes UP into the header area.
 * align-self: flex-end anchors her to the BOTTOM of the hero.
 * overflow: visible lets her head render above the hero boundary.
 */
.hero-section {
  background: #A9D3EC;
  height: 380rpx;
  display: flex;
  flex-direction: row;
  align-items: stretch;
  padding-left: 28rpx;
  padding-right: 0;
  position: relative;
  overflow: visible;
  z-index: 2;
}

.hero-left {
  flex: 1;
  display: flex;
  align-items: center;
  padding-right: 12rpx;
}

.hero-bubble {
  background: #FAF0ED;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.hero-bubble-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #2E2A28;
  line-height: 1.5;
}

/* Woman: in-flow, aligned to bottom, fits within height without overflow */
.hero-right {
  width: 300rpx;
  height: 380rpx;
  flex-shrink: 0;
  align-self: flex-end;
  margin-top: 0;
  z-index: 5;
  overflow: visible;
}

.hero-woman {
  width: 300rpx;
  height: 380rpx;
  display: block;
}

/* ========== Calendar Section ========== */
/*
 * z-index: 3 clips woman's downward overflow.
 * BLUE background like the design — dark navy text on blue.
 */
.calendar-section {
  background: #5391C0;
  padding: 24rpx 32rpx 28rpx;
  position: relative;
  z-index: 3;
  margin-top: 0;
}

/* Month Navigation */
.month-nav {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.4);
}

.month-arrow {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.12);
}

.month-arrow-txt {
  font-size: 24rpx;
  color: #5391C0;
  font-weight: 900;
}

.month-title-wrap {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 18rpx;
}

/* JUILLET: large bold white text */
.month-name-txt {
  font-size: 44rpx;
  font-weight: 900;
  color: #FFFFFF;
  letter-spacing: 1rpx;
}

/* 2025: white text */
.year-txt {
  font-size: 30rpx;
  font-weight: 400;
  color: #FFFFFF;
}

/* Days Header */
.days-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-bottom: 12rpx;
  padding-bottom: 8rpx;
}

.day-name {
  flex: 1;
  font-size: 22rpx;
  font-weight: 600;
  color: #FFFFFF !important;
  opacity: 0.85;
  text-align: center;
}

/* Calendar Grid */
.calendar-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.day-cell-wrap {
  width: 14.2857%;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 70rpx;
}

.day-cell {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Selected day: light blue rounded square with white text */
.day-cell--selected {
  background: #84BBE4;
}

.day-num {
  font-size: 26rpx;
  font-weight: 500;
  color: #FFFFFF !important;
  text-align: center;
}

.day-cell--selected .day-num {
  color: #FFFFFF !important;
  font-weight: 800;
}

.day-num--selected {
  color: #FFFFFF !important;
  font-weight: 800;
}

/* ========== SUIVANT Button ========== */
.btn-suivant-wrap {
  background: #FFFFFF;
  padding: 36rpx 60rpx 40rpx;
}

.btn-suivant {
  background: #2A5F89;
  border-radius: 60rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(42, 95, 137, 0.2);
}

.btn-suivant:active {
  opacity: 0.85;
}

.btn-suivant-txt {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

/* ========== Bottom Spacer ========== */
.bottom-spacer {
  height: 160rpx;
  background: #FFFFFF;
}

