/* Polices Figma « Ma SANTÉ » : déposer The-Cottage.ttf et Ole.ttf dans /fonts */
@font-face {
  font-family: 'The Cottage';
  src: url('/fonts/The-Cottage.ttf');
  font-weight: 400;
  font-style: normal;
}

@font-face {
  font-family: 'Ole';
  src: url('/fonts/Ole.ttf');
  font-weight: 400;
  font-style: normal;
}

/* Figma-aligned: primary #5DAE81, mint #C8E6D1, text #1E4D3A */
/* Frame maquette 390px → rpx : rpx = px × (750 / 390) */
/* Hero : largeur 390, hauteur scalée (FIGMA_HERO_HEIGHT_PX dans dashboard.js), top 120 */
/* Avatar assets/avatar : 62×77 px, radius 38 px (ex-maquette index) */

page {
  background: #ffffff;
}

.page {
  width: 100%;
  height: 100%;
  min-height: 100%;
  background: #ffffff;
  position: relative;
  box-sizing: border-box;
}

/* Hauteur en px via WXML (windowHeight) — obligatoire pour scroll-y dans WeChat */
/* Ne pas utiliser enable-flex sur scroll-view sans flex-direction:column : le seul
   enfant .screen se retrouve en row et prend la largeur du contenu → tout tasse à gauche. */
.screen-scroll {
  box-sizing: border-box;
  padding-bottom: 180rpx;
}

.screen {
  width: 100%;
  max-width: 390px;
  margin: 0 auto;
  background: #fff;
  position: relative;
  padding-bottom: 24rpx;
  box-sizing: border-box;
}

/* Réserve la hauteur header + hero (top 120 + hauteur hero, scalés dans dashboard.js) */
.dashboard-top-stack {
  position: relative;
  width: 100%;
  box-sizing: border-box;
  overflow: visible;
}

/* Réf. maquette : fond blanc, fine barre mint ; position absolue complétée par headerGroupLayoutStyle */
.header-group {
  position: relative;
  z-index: 2;
  box-sizing: border-box;
  width: 100%;
}

.header-inner {
  width: 100%;
  background: #fff;
  box-sizing: border-box;
  border-radius: 77rpx 77rpx 0 0;
  /* visible : queue avatar / chevauchement hero (Figma) ; évite de couper le bulle */
  overflow: visible;
}

/* Bloc nav : bande menthe pleine largeur en bas (header-mint-strip, même hauteur que carrousel) */
.nav-band {
  position: relative;
  z-index: 2;
  width: 100%;
  background: #fff;
  box-sizing: border-box;
  padding-bottom: 0;
  overflow: visible;
}

.header-mint-strip {
  pointer-events: none;
  display: block;
  flex-shrink: 0;
  line-height: 0;
  font-size: 0;
  overflow: hidden;
}

/* Avatar : même bande blanche que Retour / logo (Figma) ; bas + queue chevauchent la menthe */
.nav-band-avatar {
  pointer-events: auto;
}

/*
 * Figma : Retour à gauche (flux), tiqqa au centre, avatar collé à droite (absolute).
 * Le flex seul peut inverser / tasser les blocs sur certains rendus WeChat → right: 0 pour l’avatar.
 */
.top-row {
  position: relative;
  z-index: 3;
  width: 100%;
  max-width: 100%;
  min-height: 80rpx;
  padding: 10rpx 0 12rpx 0;
  box-sizing: border-box;
  overflow: visible;
}

.top-slot-back {
  position: relative;
  z-index: 5;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  max-width: 46%;
  min-width: 0;
}

/* Position logo / avatar : styles inline depuis dashboard.js (px, fiable dans scroll-view) */
.top-logo-slot {
  pointer-events: none;
}

/* Figma « back » : 80×22 px → rpx ; cercle + flèche fine + « Retour » */
.back-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  width: 154rpx;
  height: 42rpx;
  box-sizing: border-box;
  gap: 6rpx;
  flex-shrink: 0;
}

/* Cercle Figma 22×22 : dégradé + ombre (Y 2, flou 4, noir 25 %) */
.back-circle {
  width: 42rpx;
  height: 42rpx;
  min-width: 42rpx;
  border-radius: 21rpx;
  background: linear-gradient(180deg, #e6e7e9 0%, rgba(129, 130, 131, 0.26) 100%);
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 8rpx 0 rgba(0, 0, 0, 0.25);
}

/* Flèche fine noire dans le cercle */
.back-arrow {
  font-size: 22rpx;
  font-weight: 400;
  color: #000;
  line-height: 1;
  display: block;
  margin-top: -1rpx;
  transform: scaleX(0.85);
}

.back-text {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  line-height: 42rpx;
  height: 42rpx;
  color: #000;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: clip;
}

/* Logo Figma « tiqqa » : 86,75 × 33 px → rpx = px × (750/390) */
.logo {
  width: 167rpx;
  height: 63rpx;
  max-width: 100%;
  display: block;
  flex-shrink: 0;
}

/* Slot logo dimensionné en px par JS : l’image suit la largeur utile */
.top-logo-slot .logo {
  width: 100%;
  height: 63rpx;
}

/* Avatar rond type Figma + queue de bulle (chat) */
.avatar-wrap {
  position: relative;
  width: 120rpx;
  height: 130rpx;
}

.avatar-wrap--overlap {
  position: relative;
  z-index: 4;
}

.avatar-wrap--overlap::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20rpx;
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-top: 18rpx solid #fff;
  z-index: 4;
  pointer-events: none;
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 54rpx;
  border: 5rpx solid #fff;
  display: block;
  position: relative;
  z-index: 4;
  background: #e8e8e8;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.14);
}

.hero-block {
  /* position / top / taille Figma : dashboard.js → heroBlockStyle ; fond menthe si 1 px de jeu sous l’image */
  overflow: hidden;
  background: #cde6d0;
  margin-bottom: 0;
}

.hero-img {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  display: block;
  z-index: 0;
}

/* Léger fondu bas pour le texte (sans bande verte ajoutée) */
.hero-overlay {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0) 50%, rgba(0, 0, 0, 0.35) 100%);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-end;
  padding: 28rpx 32rpx 36rpx 32rpx;
  box-sizing: border-box;
}

.hero-title {
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  text-align: left;
  letter-spacing: 1rpx;
  line-height: 1.35;
  padding: 0;
  max-width: 420rpx;
  box-sizing: border-box;
}

.hero-cta {
  margin-top: 28rpx;
  padding: 18rpx 56rpx;
  background: #fff;
  border-radius: 20rpx;
  align-self: flex-start;
}

.hero-cta-text {
  color: #1e1e1e;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

/* Barre carrousel : fond menthe #CDE6D0 ; hauteur fixée en inline (JS), ~40 px */
.hero-carousel-strip {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 2;
  flex-shrink: 0;
  border-radius: 0;
  overflow: hidden;
  margin-top: 0;
}

/* Cercles gris très clair, léger relief (réf. maquette) */
.carousel-btn {
  box-sizing: border-box;
  background: linear-gradient(180deg, #fafafa 0%, #eceff1 50%, #e2e5e9 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.08), 0 1rpx 2rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.95);
}

.carousel-arrow-txt {
  font-size: 22rpx;
  font-weight: 400;
  color: #5a5a5a;
  line-height: 1;
  margin-top: -1rpx;
  transform: scaleX(0.9);
}

.main-surface {
  width: 100%;
  background: #fff;
  padding-top: 20rpx;
  padding-bottom: 16rpx;
  box-sizing: border-box;
}

/* Ligne Ma SANTÉ : 118×18 px Figma → rpx */
.section-heading-row {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  min-height: 34.6153846154rpx;
  padding: 4rpx 24rpx 6rpx;
  opacity: 1;
}

.section-dot {
  position: absolute;
  left: 28rpx;
  top: 50%;
  margin-top: -12rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 12rpx;
  background: #fff;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.06);
}

.section-title-wrap {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  width: 226.9230769231rpx;
  height: 34.6153846154rpx;
  box-sizing: border-box;
  line-height: 1;
  overflow: hidden;
}

.section-ma-sante-logo {
  width: 226.9230769231rpx;
  height: 34.6153846154rpx;
  display: block;
  opacity: 1;
}

/* Figma : carte 116×149 px, radius 9 px, #8BBD9A → rpx (frame 390) ; gouttière 12 px = colonne 23rpx */
.service-grid {
  margin: 16rpx 24rpx 12rpx;
  padding: 0 14rpx 12rpx;
  display: grid;
  grid-template-columns: 1fr 223rpx 23rpx 223rpx 1fr;
  grid-template-rows: auto auto auto;
  row-gap: 20rpx;
  box-sizing: border-box;
  background: #fff;
}

.service-card {
  width: 223rpx;
  height: 287rpx;
  min-height: 287rpx;
  max-height: 287rpx;
  box-sizing: border-box;
  border-radius: 17rpx;
  border: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 16rpx 6rpx 12rpx;
  background: #8bbd9a;
  overflow: hidden;
}

/* Médecin de garde : cadre 116×149 px r9 #8BBD9A ; image 77×86 @ +16 px / +20 px dans le cadre */
.service-card.card-1 {
  grid-column: 2;
  grid-row: 1;
  position: relative;
  padding: 0;
  align-items: stretch;
}

.service-card.card-1 .service-card-image {
  position: absolute;
  left: 31rpx;
  top: 38rpx;
  width: 148rpx;
  height: 165rpx;
  border-radius: 17rpx;
}

.service-card.card-1 .service-card-label {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 12rpx;
  margin-top: 0;
  text-align: center;
}

/* Médecin à domicile : cadre 116×149 px r9 #6FB682 ; image 71×87 @ +23 px / +19 px (228/205, 455/436) */
.service-card.card-2 {
  grid-column: 4;
  grid-row: 1;
  position: relative;
  padding: 0;
  align-items: stretch;
  background: #6fb682;
}

.service-card.card-2 .service-card-image {
  position: absolute;
  left: 44rpx;
  top: 37rpx;
  width: 137rpx;
  height: 167rpx;
  border-radius: 17rpx;
  background: #6fb682;
}

.service-card.card-2 .service-card-label {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 12rpx;
  margin-top: 0;
  text-align: center;
}

.service-card.card-3 {
  grid-column: 2;
  grid-row: 2;
}

/* Photo Figma ~77×86 px sur frame 390 (médecins) — fond = vert carte, pas blanc */
.service-card-image {
  width: 148rpx;
  height: 165rpx;
  border-radius: 17rpx;
  background: #8bbd9a;
  flex-shrink: 0;
  display: block;
}

/* Infirmier / Urgence : libellé déjà sur l’asset — image plein cadre */
.service-card.card-3,
.service-card.card-4 {
  padding: 0;
  justify-self: center;
  align-self: start;
  overflow: hidden;
}

.service-card-image--cover {
  width: 100%;
  height: 100%;
  border-radius: inherit;
  display: block;
}

.service-card.card-3 .service-card-image--cover {
  background: #8bbd9a;
}

.service-card.card-4 .service-card-image--cover {
  background: #d4e6d9;
}

/* Figma Urgence : 114×151 px, radius ~10 px, #d4e6d9 */
.service-card.card-4 {
  grid-column: 4;
  grid-row: 2;
  width: 219rpx;
  min-width: 219rpx;
  max-width: 219rpx;
  height: 290rpx;
  min-height: 290rpx;
  max-height: 290rpx;
  border-radius: 19rpx;
}

.service-card-label {
  margin-top: 10rpx;
  font-size: 18rpx;
  text-align: center;
  color: #fff;
  font-weight: 700;
  text-transform: uppercase;
  line-height: 1.2;
  padding: 0 4rpx;
  width: 100%;
  box-sizing: border-box;
}

.service-card-label--dark {
  color: #1e4d3a;
}

.card-4 {
  background: #d4e6d9;
}

/* Suivi médicaments : même colonne que Infirmier (col. 2), ligne 3 — sous « Infirmier à domicile » */
.service-card-full {
  grid-column: 2;
  grid-row: 3;
  justify-self: center;
  align-self: start;
  width: 223rpx;
  height: 287rpx;
  min-height: 287rpx;
  max-height: 287rpx;
  box-sizing: border-box;
  position: relative;
  border-radius: 17rpx;
  background: #a9e0c1;
  border: none;
  padding: 0;
  overflow: hidden;
}

.service-card-image-full {
  position: absolute;
  left: 42rpx;
  top: 29rpx;
  width: 152rpx;
  height: 148rpx;
  border-radius: 15rpx;
  display: block;
  background: #a9e0c1;
}

.service-card-label-full {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 14rpx;
  width: auto;
  padding: 0 8rpx;
  box-sizing: border-box;
  line-height: 1.25;
  text-align: center;
  color: #fff;
  font-size: 17rpx;
  font-weight: 700;
  letter-spacing: 0.5px;
  text-transform: none;
  white-space: normal;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'Neue Montreal', sans-serif;
}

.scroll-bottom-spacer {
  height: 24rpx;
}

/*
 * Ascenseur vertical — Figma
 * Rectangle piste : 14×122 px, #FFF, rayon 20, box-shadow 0 4 8 rgba(0,0,0,.25) → dashboard.js (scrollRailTrackStyle)
 * Boutons ↑↓ : 22×22, dégradé #E6E7E9 → #818283 @ 26 %
 */
.scroll-rail {
  pointer-events: auto;
}

/* 22 px → ~42rpx */
.scroll-rail-btn {
  width: 42rpx;
  height: 42rpx;
  min-width: 42rpx;
  min-height: 42rpx;
  border-radius: 21rpx;
  background: linear-gradient(180deg, #e6e7e9 0%, rgba(129, 130, 131, 0.26) 100%);
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-sizing: border-box;
}

.scroll-rail-btn--hover {
  opacity: 0.88;
}

.scroll-rail-arrow {
  font-size: 20rpx;
  font-weight: 500;
  color: #4a4a4a;
  line-height: 1;
}

/* Piste : dimensions exactes en px via scrollRailTrackStyle (14×122 frame 390) */
.scroll-rail-track {
  margin: 8rpx 0;
}

.scroll-rail-thumb {
  position: absolute;
  left: 2rpx;
  right: 2rpx;
  height: 28%;
  min-height: 28rpx;
  background: #1e4d3a;
  border-radius: 10rpx;
  box-sizing: border-box;
}

/* Barre bas : app.wxss + utils/bottomNav.js (identique accueil / dashboard) */
