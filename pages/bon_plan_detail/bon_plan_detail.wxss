.bon-plan-detail-container {
  height: 100vh;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: hidden;
}

.mobile-card {
  width: 750rpx;
  height: 100%;
  margin: 0 auto;
  border-radius: 57.69rpx;
  overflow: hidden;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  position: relative;
  box-sizing: border-box;
}

/* Header Styles */
.horaire-header-wrap {
  flex-shrink: 0;
  background: #ffffff;
  padding-top: 10rpx;
  padding-bottom: 8rpx;
  box-sizing: border-box;
}

.status-row {
  display: flex;
  align-items: center;
  padding: 0 34rpx 0rpx;
  box-sizing: border-box;
}

.top-bar--horaire {
  position: relative;
  width: 100%;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx 0 20rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.back-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  z-index: 15;
}

.back-circle {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #f2f2f2;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #333;
  font-size: 24rpx;
  font-weight: bold;
}

.back-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #000000;
}

.logo {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 60rpx;
  z-index: 10;
}

.avatar-bubble {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  position: relative;
  z-index: 15;
}

.avatar-wrap {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: transparent;
  overflow: hidden;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-bubble-tail {
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-top: 8rpx solid #c19a89;
  margin-top: -2rpx;
}

/* Product Image Area */
.product-image-container {
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 380rpx;
  padding: 20rpx;
  box-sizing: border-box;
  flex-shrink: 0;
}

.product-image-container--full {
  padding: 0;
}

.detail-product-img {
  max-width: 90%;
  max-height: 95%;
}

.detail-product-img--full {
  width: 100%;
  height: 100%;
  max-width: 100%;
  max-height: 100%;
}

/* Gold Stripe Divider */
.gold-divider-stripe {
  height: 35rpx;
  background: #EABF27;
  width: 100%;
  flex-shrink: 0;
}

/* Content Area */
.detail-content-scroll {
  flex: 1;
  height: 0;
  background: #ffffff;
  margin-bottom: 110rpx; /* Nav bar spacer */
}

.detail-content-wrap {
  padding: 40rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #000000;
  text-align: center;
  margin-bottom: 40rpx;
  font-family: 'Poppins', sans-serif;
}

.descriptif-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.section-heading {
  font-size: 30rpx;
  font-weight: 700;
  color: #000000;
  margin-bottom: 20rpx;
  font-family: 'Poppins', sans-serif;
}

.discount-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 25rpx;
  font-family: 'Poppins', sans-serif;
}

.discount-label {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
}

.discount-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: normal;
  margin-left: 8rpx;
}

.description-paragraph {
  width: 100%;
}

.desc-text {
  font-size: 26rpx;
  color: #555555;
  line-height: 1.6;
  text-align: left;
  font-family: 'Poppins', sans-serif;
  display: block;
}

.btn-wrap {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-top: 60rpx;
  margin-bottom: 40rpx;
}

.obtain-code-btn {
  width: 480rpx;
  height: 84rpx;
  background: #EEA33D;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 10rpx rgba(238, 163, 61, 0.3);
}

.obtain-code-btn-text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}
