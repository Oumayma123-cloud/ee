.container {
  min-height: 100vh;
  background-color: #ffffff !important;
  display: flex;
  flex-direction: column;
  color: #000000;
  box-sizing: border-box;
}

/* ── Header ─────────────────────────────────────────────── */
.avatar-header {
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  background: #ffffff;
  flex-shrink: 0;
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 140rpx; /* Match spacer width */
}

.back-circle {
  width: 48rpx;
  height: 48rpx;
  background: #f4f5f7;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  font-size: 22rpx;
  color: #717277;
}

.back-text {
  font-size: 24rpx;
  color: #000000;
  font-weight: 700;
}

.logo {
  width: 150rpx;
  height: 52rpx;
}

/* ── Content ────────────────────────────────────────────── */
.content {
  flex: 1;
  padding: 60rpx 50rpx 0rpx;
  display: flex;
  flex-direction: column;
  background: #ffffff;
  width: 100%;
  box-sizing: border-box;
}

.title-container {
  width: 100%;
  margin-bottom: 80rpx;
}

.title {
  font-size: 42rpx;
  font-weight: 800;
  color: #000000;
  line-height: 1.4;
  text-align: left;
  letter-spacing: 0.5rpx;
}

/* ── Avatars ────────────────────────────────────────────── */
.avatars-row {
  display: flex;
  justify-content: space-between;
  gap: 30rpx;
  width: 100%;
  padding: 0 10rpx;
  box-sizing: border-box;
}

.avatar-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 270rpx;
}

.avatar-labels {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.script-text {
  font-family: 'Times New Roman', serif; /* Or Brush Script if available */
  font-style: italic;
  font-size: 48rpx;
  color: #333333;
  font-weight: 400;
  margin-bottom: 6rpx;
}

.bold-text {
  font-size: 20rpx;
  font-weight: 900;
  color: #000000;
  letter-spacing: 0.5rpx;
}

.avatar-img {
  width: 270rpx;
  height: 260rpx;
  border-radius: 40rpx;
  object-fit: cover;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.05);
}

/* ── Checkbox ───────────────────────────────────────────── */
.checkbox-wrapper {
  width: 100%;
  display: flex;
  justify-content: center;
}

.custom-checkbox {
  width: 34rpx;
  height: 34rpx;
  border: 2rpx solid #dcdcdc;
  border-radius: 8rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.custom-checkbox.checked {
  background: #9b6260;
  border-color: #9b6260;
}

.custom-checkbox.checked::after {
  content: '';
  width: 8rpx;
  height: 16rpx;
  border: solid white;
  border-width: 0 3rpx 3rpx 0;
  transform: rotate(45deg);
  margin-bottom: 4rpx;
}

/* ── Bottom Nav ─────────────────────────────────────────── */
.nav-bar-container {
  width: 100%;
  flex-shrink: 0;
}
