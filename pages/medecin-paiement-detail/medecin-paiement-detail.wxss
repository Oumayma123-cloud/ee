page {
  background: #ffffff;
}

.page {
  min-height: 100vh;
  background: #ffffff;
  padding: 16rpx 0 calc(20rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.mobile-card {
  width: 750rpx;
  margin: 0 auto;
  border-radius: 57.6923076923rpx;
  overflow: hidden;
  background: #ffffff;
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding-top: 8rpx;
}

.content-scroll {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
  background: transparent;
  display: flex;
  flex-direction: column;
}

/* New Header Styles from Photo */
.horaire-header-wrap {
  flex-shrink: 0;
  background: #ffffff;
  min-height: 120rpx;
  height: auto;
  padding-top: 10rpx;
  padding-bottom: 8rpx;
  box-sizing: border-box;
  position: sticky;
  top: 0;
  z-index: 100;
}

.status-row {
  display: flex;
  align-items: center;
  padding: 0 34rpx 0rpx;
  box-sizing: border-box;
  min-height: 0;
  height: auto;
}

.top-bar--horaire {
  position: relative;
  width: 100%;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx 0 20rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.back-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.back-circle {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #f2f2f2;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #333;
  font-size: 24rpx;
  font-weight: bold;
}

.back-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #000000;
}

.logo {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 60rpx;
}

.avatar-bubble {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  position: relative;
  z-index: 10;
}

.avatar-wrap {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: transparent;
}

.avatar-wrap--bubble {
  border: none;
  box-shadow: none;
  overflow: hidden;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.payment-hero {
  position: relative;
  height: 421.1538461538rpx;
  background: #c7e5d1;
  overflow: hidden;
}

.payment-hero-frame {
  width: 750rpx;
  margin: 36.5384615385rpx 0 0;
  border-radius: 0;
  border: 0;
  box-sizing: border-box;
  overflow: hidden;
  background: transparent;
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
}

.hero-strip {
  height: 28.8461538462rpx;
  flex-shrink: 0;
  background: #c7e5d1;
}

.hero-strip--bottom {
  height: 30rpx;
}

.hero-img {
  width: 750rpx;
  height: 421.1538461538rpx;
  display: block;
  opacity: 1;
}

.hero-overlay {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  padding: 0 26rpx 16rpx;
  box-sizing: border-box;
  background: transparent;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: flex-start;
}

.hero-title {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 0.5rpx;
  margin-bottom: 14rpx;
}

.hero-cta {
  height: 44rpx;
  width: 108rpx;
  border-radius: 22rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-cta-text {
  color: #000000;
  font-size: 18rpx;
  font-weight: 700;
}

.mint-from-hero {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
  background: #c7e5d1;
}

.detail-mint {
  background: #c7e5d1;
  padding: 0 0 24rpx;
  box-sizing: border-box;
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.detail-mint-spacer {
  flex: 1;
  min-height: 24rpx;
  width: 100%;
}

/*
 * Figma : largeur 309, left 38, radius 11 → rpx (×750/390)
 * Hauteur : auto — le bas du rectangle suit le contenu (jusqu’à la ligne CGU, repère rouge)
 */
.payment-detail-card {
  position: relative;
  width: 594.2307692308rpx;
  height: auto;
  margin-left: 73.0769230769rpx;
  margin-right: auto;
  margin-top: 24rpx;
  background: #ffffff;
  border-radius: 21.1538461538rpx;
  /* Espace sous le bord haut : titre sous les demi-cercles des flèches */
  padding: 36rpx 20rpx 20rpx;
  box-sizing: border-box;
  border: 2rpx solid #5b9bd5;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  flex-shrink: 0;
  overflow: visible;
  opacity: 1;
}

/* Flèches au sommet du rectangle : centre sur le bord haut → moitié au-dessus, moitié dedans */
.detail-nav-arrow--corner {
  position: absolute;
  z-index: 2;
  top: 0;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #000000;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1;
  transform: translateY(-50%);
}

.detail-nav-arrow--left {
  left: 28rpx;
  transform: translate(-50%, -50%);
}

.detail-nav-arrow--right {
  right: 28rpx;
  left: auto;
  transform: translate(50%, -50%);
}

.detail-nav-arrow--active {
  opacity: 0.75;
}

.detail-card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  margin-bottom: 14rpx;
}

.detail-card-title {
  display: block;
  text-align: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #000000;
  margin-bottom: 0;
}

.detail-card-header + .detail-divider {
  margin-top: 0;
}

.detail-divider {
  height: 1rpx;
  background: #c8c8c8;
  margin-bottom: 22rpx;
}

.method-pill {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 88rpx;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  border: 2rpx solid #1a1a1a;
  margin-bottom: 28rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.method-pill-icon {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
}

.method-pill-label {
  font-size: 32rpx;
  font-weight: 700;
  color: #000000;
}

.detail-section-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #2e7d32;
  margin-bottom: 18rpx;
}

.detail-rows {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.detail-row {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 8rpx 10rpx;
  font-size: 24rpx;
  line-height: 1.45;
}

.detail-row-k {
  font-weight: 700;
  color: #000000;
}

.detail-row-v {
  font-weight: 400;
  color: #000000;
  flex: 1;
  min-width: 200rpx;
}

.cgu-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 0;
}

.cgu-box {
  width: 34rpx;
  height: 34rpx;
  border-radius: 4rpx;
  background: #e0e0e0;
  border: 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cgu-box--on {
  background: #2d6a4f;
  border-color: #2d6a4f;
}

.cgu-check {
  color: #fff;
  font-size: 22rpx;
  font-weight: 800;
}

.cgu-text {
  font-size: 22rpx;
  color: #1a1a1a;
  flex: 1;
}

.detail-confirm-wrap {
  width: 594.2307692308rpx;
  margin: 28rpx auto 0 73.0769230769rpx;
  padding: 0;
  box-sizing: border-box;
}

.detail-confirm-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 20rpx;
  background: #2d6a4f;
  border: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  box-shadow: none;
}

.bottom-nav.bottom-nav--in-card {
  width: 100%;
  max-width: none;
  margin: 0;
  border-radius: 0 0 57.6923076923rpx 57.6923076923rpx;
  align-self: stretch;
  border-top: none;
  box-shadow: none;
}

.bottom-nav.bottom-nav--light.bottom-nav--in-card {
  background: #f5f5f5;
}

/* --- Modale Tasshilat (alignée maquette : #2C2C2E, X à cheval sur le bas) --- */
.agency-modal-root {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 56rpx 40rpx 80rpx;
  box-sizing: border-box;
  pointer-events: auto;
}

.agency-modal-mask {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.65); /* Darker for better focus */
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.agency-modal-panel {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 580rpx;
  background: #1c1c1e; /* Deeper dark background */
  border-radius: 60rpx;
  padding: 80rpx 48rpx 100rpx;
  box-sizing: border-box;
  overflow: visible;
  box-shadow: 0 40rpx 100rpx rgba(0, 0, 0, 0.8);
}

.agency-modal-text-wrap {
  width: 100%;
  padding: 0 4rpx;
  box-sizing: border-box;
}

.agency-modal-para {
  display: block;
  width: 100%;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1.65;
  text-align: center;
  font-weight: 400;
  letter-spacing: 0;
}

.agency-modal-code {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.agency-modal-close {
  position: absolute;
  left: 50%;
  bottom: -48rpx; /* Lower position */
  width: 96rpx;
  height: 96rpx;
  transform: translateX(-50%);
  border-radius: 50%;
  background: #d1d1d6; /* Matching the light grey in screenshot */
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 25rpx rgba(0, 0, 0, 0.4);
}

.agency-modal-close--active {
  opacity: 0.88;
}

.agency-modal-x {
  color: #000000;
  font-size: 48rpx;
  font-weight: 300;
  line-height: 1;
  margin-top: -8rpx;
}
