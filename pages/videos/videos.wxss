/* ============================================================
   Videos Page – videos.wxss
   ============================================================ */

.videos-container {
  height: 100vh;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: hidden;
}

.mobile-card {
  width: 750rpx;
  height: 100%;
  margin: 0 auto;
  border-radius: 57.69rpx;
  overflow: hidden;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  position: relative;
  box-sizing: border-box;
}

/* ── Header ─────────────────────────────────────────────── */
.horaire-header-wrap {
  flex-shrink: 0;
  background: #ffffff;
  padding-top: 10rpx;
  padding-bottom: 8rpx;
  box-sizing: border-box;
}

.status-row {
  display: flex;
  align-items: center;
  padding: 0 34rpx 0rpx;
  box-sizing: border-box;
}

.top-bar--horaire {
  position: relative;
  width: 100%;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx 0 20rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.back-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  z-index: 15;
}

.back-circle {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #f2f2f2;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #333;
  font-size: 24rpx;
  font-weight: bold;
}

.back-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #000000;
}

.logo {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 60rpx;
  z-index: 10;
}

.avatar-bubble {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  position: relative;
  z-index: 15;
}

.avatar-wrap {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: transparent;
  overflow: hidden;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-bubble-tail {
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-top: 8rpx solid #c19a89;
  margin-top: -2rpx;
}

/* ── Hero Section ────────────────────────────────────────── */
.videos-hero-area {
  width: 100%;
  flex-shrink: 0;
  background: #F8F9FA;
  padding-bottom: 20rpx; /* Light grey area below hero */
}

.videos-hero-main {
  position: relative;
  width: 100%;
  height: 380rpx;
}

.videos-hero-img {
  width: 100%;
  height: 100%;
}

.videos-hero-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 90rpx;
  background: rgba(0, 0, 0, 0.4); /* Translucent dark bar */
  display: flex;
  align-items: center;
  padding: 0 40rpx;
}

.hero-overlay-content {
  width: 100%;
  height: 60rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.hero-overlay-logo {
  width: 70rpx;
  height: 30rpx;
  filter: brightness(0) invert(1); /* Make logo white if it isn't */
}

.hero-overlay-divider {
  width: 2rpx;
  height: 30rpx;
  background: rgba(255, 255, 255, 0.8);
  margin: 0 16rpx;
}

.hero-overlay-text-wrap {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.hero-overlay-name {
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  line-height: 1.1;
}

.hero-overlay-role {
  color: #dddddd;
  font-size: 14rpx;
  font-weight: 500;
  text-transform: uppercase;
  line-height: 1.1;
}

/* ── Grid & Scrollable Container ─────────────────────────── */
.videos-grid-container {
  display: flex;
  flex: 1;
  min-height: 0;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 110rpx;
}

.content-scroll {
  flex: 1;
  height: 100%;
}

.videos-spacer {
  height: 30rpx;
  width: 100%;
  background: #ffffff;
}

.videos-grid {
  display: grid;
  grid-template-columns: repeat(2, 232rpx);
  gap: 24rpx;
  padding: 0 30rpx 40rpx;
  justify-content: center;
}

/* ── Videos Cards ─────────────────────────────────────── */
.videos-card {
  width: 232rpx;
  height: 298rpx;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  background: #ffffff;
}

.videos-card-img-wrap {
  width: 100%;
  flex: 1;
  background: #EAEAEA;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.videos-card-img {
  width: 100%;
  height: 100%;
}

.videos-card-footer {
  width: 100%;
  height: 60rpx;
  background: #593A2D; /* Dark brown / espresso color matching screenshot */
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.videos-card-label {
  font-size: 20rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.bottom-spacer {
  height: 100rpx;
}
