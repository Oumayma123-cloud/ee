<view class="container {{viewState === 'details' ? 'details-mode' : ''}}">
  <!-- Main Sidebar View (Figma Style) -->
  <block wx:if="{{viewState === 'main'}}">
    <!-- Right side mask (background visible) -->
    <view class="sidebar-mask" bindtap="onBack"></view>

    <!-- Sidebar Content -->
    <view class="sidebar-content">
      <!-- Decorative Background Shapes -->
      <view class="circle-deco deco-1"></view>
      <view class="circle-deco deco-2"></view>
      <view class="circle-deco deco-3"></view>
      <image class="header-motif" src="/assets/motif-tiqqa.png" mode="aspectFill"></image>

      <view class="figma-header">
        <view class="figma-back" bindtap="onBack">
          <text class="figma-back-arrow">←</text>
        </view>
        <view class="figma-user-info" bindtap="showDetails">
          <view class="figma-avatar">
            <text>{{fullName ? fullName[0] : ''}}</text>
          </view>
          <view class="figma-user-text">
            <text class="figma-user-name">{{fullName}}</text>
            <text class="figma-user-phone">{{phone}}</text>
          </view>
        </view>
      </view>

      <view class="figma-menu">
        <view class="figma-menu-item" bindtap="showDetails">
          <view class="figma-icon-placeholder">
            <image src="/assets/icons/lucide-user.svg" mode="aspectFit" class="figma-icon-img"></image>
          </view>
          <view class="figma-menu-content">
            <text class="figma-menu-label">Profil</text>
            <text class="figma-menu-arrow">></text>
          </view>
        </view>

        <view class="figma-menu-item" bindtap="onPaiementsTap">
          <view class="figma-icon-placeholder">
            <text style="color: white; font-size: 28rpx;">$</text>
          </view>
          <view class="figma-menu-content">
            <text class="figma-menu-label">Mes Paiements</text>
            <text class="figma-menu-arrow">></text>
          </view>
        </view>

        <view class="figma-menu-item" bindtap="onReglagesTap">
          <view class="figma-icon-placeholder">
            <image src="/assets/icons/lucide-cog.svg" mode="aspectFit" class="figma-icon-img"></image>
          </view>
          <view class="figma-menu-content">
            <text class="figma-menu-label">Réglages</text>
            <text class="figma-menu-arrow">></text>
          </view>
        </view>

        <view class="figma-menu-item" bindtap="onJeuxTap">
          <view class="figma-icon-placeholder">
            <image src="/assets/icons/lucide-gamepad.svg" mode="aspectFit" class="figma-icon-img"></image>
          </view>
          <view class="figma-menu-content">
            <text class="figma-menu-label">Jeux</text>
            <text class="figma-menu-arrow">></text>
          </view>
        </view>

        <view class="figma-menu-item" bindtap="onAjouterMembreTap">
          <view class="figma-icon-placeholder">
            <view style="width: 32rpx; height: 32rpx; border: 2.5rpx solid white; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 28rpx; font-weight: 300;">+</view>
          </view>
          <view class="figma-menu-content">
            <text class="figma-menu-label">Ajouter un membre de famille</text>
            <text style="opacity: 0;"></text> <!-- No arrow in the screenshot -->
          </view>
        </view>
      </view>

      <view class="figma-logout-wrap" bindtap="onLogout">
        <view class="figma-logout-btn">
          <view class="figma-logout-left">
            <image src="/assets/icons/lucide-logout.svg" mode="aspectFit" class="figma-icon-img logout-icon-img"></image>
            <text class="logout-text">Déconnexion</text>
          </view>
          <text class="figma-menu-arrow">></text>
        </view>
      </view>

      <view class="nav-bar-container">
        <bottom-nav-bar active-tab="home" variant="fixed" message-count="6" bind:navtap="onNavTap" />
      </view>
    </view>
  </block>

  <!-- Details View (Form) -->
  <block wx:if="{{viewState === 'details'}}">
    <view class="header-bg">
      <image class="header-motif" src="/assets/motif-tiqqa.png" mode="aspectFill"></image>
      <device-status-bar fillStatusBar="{{true}}" />
      <view class="header-content">
        <view class="back-btn" bindtap="onBack">
          <text class="back-arrow">←</text>
        </view>
        <image class="logo" src="/assets/logo-tiqqa-header.png" mode="aspectFit"></image>
      </view>
    </view>

    <view class="content-card">
      <!-- Tabs -->
      <view class="tabs-container">
        <view class="tab {{activeTab === 'profil' ? 'active' : ''}}" bindtap="switchTab" data-tab="profil">
          <view class="tab-icon-wrap">
            <image class="tab-icon-img" src="/assets/icons/lucide-user.svg" wx:if="{{activeTab === 'profil'}}"></image>
          </view>
          <text class="tab-label">Profil</text>
        </view>
        <view class="tab {{activeTab === 'info' ? 'active' : ''}}" bindtap="switchTab" data-tab="info">
          <view class="tab-icon-wrap">
            <text class="tab-icon-text {{activeTab === 'info' ? 'active-icon-text' : ''}}">ⓘ</text>
          </view>
          <text class="tab-label">Info clinique/contact</text>
        </view>
      </view>

      <!-- Profile Header (Detailed) -->
      <view class="profile-header">
        <view class="avatar-circle">
          <text>{{fullName ? fullName[0] : ''}}</text>
        </view>
        <text class="user-name">{{fullName}}</text>
      </view>

      <scroll-view class="form-container" scroll-y="true" wx:if="{{activeTab === 'profil'}}">
        <view class="input-group">
          <text class="label">Nom</text>
          <input class="input" placeholder="Nom" value="{{user.nom}}" bindinput="onInput" data-field="nom" />
        </view>
        <view class="input-group">
          <text class="label">Prénom</text>
          <input class="input" placeholder="Prénom" value="{{user.prenom}}" bindinput="onInput" data-field="prenom" />
        </view>
        <view class="input-group">
          <text class="label">Email</text>
          <input class="input" placeholder="example @gmail.com" value="{{user.email}}" bindinput="onInput" data-field="email" />
        </view>
        <view class="input-group">
          <text class="label">Date de naissance</text>
          <input class="input" placeholder="jj/mm/aaaa" value="{{user.dob}}" bindinput="onInput" data-field="dob" />
        </view>
        <view class="input-group">
          <text class="label">Téléphone</text>
          <view class="phone-input-wrap">
            <view class="operator-selector">
              <image class="operator-logo" src="/assets/iam.png" mode="aspectFit"></image>
              <text class="dropdown-arrow">▼</text>
            </view>
            <input class="input phone-input" placeholder="06" value="{{user.phone}}" bindinput="onInput" data-field="phone" />
          </view>
        </view>
      </scroll-view>

      <scroll-view class="form-container" scroll-y="true" wx:if="{{activeTab === 'info'}}">
        <view class="input-group">
          <text class="label">Ville</text>
          <picker mode="selector" range="{{villes}}" bindchange="onVilleChange">
            <view class="select-input">
              <text class="select-value">{{user.ville || 'Sélectionner'}}</text>
              <text class="dropdown-arrow">▼</text>
            </view>
          </picker>
        </view>
        <view class="input-group">
          <text class="label">Adresse</text>
          <picker mode="selector" range="{{adresses}}" bindchange="onAdresseChange">
            <view class="select-input">
              <text class="select-value">{{user.adresse || 'Sélectionner'}}</text>
              <text class="dropdown-arrow">▼</text>
            </view>
          </picker>
        </view>
        <view class="input-group">
          <text class="label">Clinique</text>
          <picker mode="selector" range="{{cliniques}}" bindchange="onCliniqueChange">
            <view class="select-input">
              <text class="select-value {{!user.clinique ? 'placeholder' : ''}}">{{user.clinique || 'Sélectionner'}}</text>
              <text class="dropdown-arrow">▼</text>
            </view>
          </picker>
        </view>
        <view class="separator-dots">
          <view class="dot" wx:for="{{[1,2,3,4,5,6,7,8]}}" wx:key="*this"></view>
        </view>
        <view class="emergency-section">
          <text class="section-title">Contacts d'urgence</text>
          <view class="emergency-list">
            <view class="emergency-card" wx:for="{{contacts}}" wx:key="id">
              <view class="contact-info" bindtap="openModal" data-id="{{item.id}}">
                <view class="contact-avatar">
                  <image src="/assets/icons/lucide-user.svg" mode="aspectFit" class="contact-icon-img"></image>
                </view>
                <view class="contact-details">
                  <text class="contact-name">{{item.nom}}</text>
                  <text class="contact-phone">{{item.telephone}}</text>
                </view>
              </view>
              <view class="contact-actions" catchtap="onDeleteContact" data-id="{{item.id}}">
                <view class="action-divider"></view>
                <text style="color: #FFA5A5; font-size: 28rpx; margin-left: 20rpx;">🗑</text>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>

      <view class="footer-btn-wrap">
        <button class="btn-valider" bindtap="onValider">Valider</button>
      </view>
    </view>
  </block>

  <!-- Member Info Modal -->
  <view class="modal-mask" wx:if="{{showModal}}" bindtap="closeModal"></view>
  <view class="member-modal" wx:if="{{showModal}}">
    <view class="modal-header">
      <view class="close-btn" bindtap="closeModal">×</view>
    </view>
    <view class="modal-body">
      <text class="modal-title">Informations sur le membre</text>
      <view class="input-group">
        <text class="label">Nom</text>
        <input class="input" placeholder="Nom" value="{{memberInfo.nom}}" bindinput="onMemberInput" data-field="nom" />
      </view>
      <view class="input-group">
        <text class="label">Prénom</text>
        <input class="input" placeholder="Prénom" value="{{memberInfo.prenom}}" bindinput="onMemberInput" data-field="prenom" />
      </view>
      <view class="input-group">
        <text class="label">Lien de parenté</text>
        <view class="select-input">
          <text class="select-value">fils, fille, neveu, voisin,...</text>
          <text class="dropdown-arrow">▼</text>
        </view>
      </view>
      <view class="input-group">
        <text class="label">Téléphone</text>
        <input class="input" placeholder="Prénom" value="{{memberInfo.phone}}" bindinput="onMemberInput" data-field="phone" />
      </view>
      <view class="modal-footer">
        <button class="btn-valider" bindtap="onValider">Valider</button>
      </view>
    </view>
  </view>
</view>

