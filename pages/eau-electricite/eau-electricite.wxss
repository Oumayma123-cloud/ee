/* ========== Container ========== */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F8FAFC;
}

.scroll-content {
  flex: 1;
  overflow: hidden;
}

.scroll-inner {
  display: flex;
  flex-direction: column;
}

/* ========== Header ========== */
.header-section {
  background: #ffffff;
  padding-bottom: 20rpx;
  z-index: 10;
}

.header-content {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 36rpx;
}

.back-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.back-circle {
  width: 54rpx;
  height: 54rpx;
  border-radius: 27rpx;
  background: #EEEEEE;
  display: flex;
  justify-content: center;
  align-items: center;
}

.chevron-left-black {
  width: 14rpx;
  height: 14rpx;
  border-left: 4.5rpx solid #333;
  border-bottom: 4.5rpx solid #333;
  transform: rotate(45deg);
  margin-left: 6rpx;
}

.back-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #333;
}

.logo {
  width: 150rpx;
  height: 60rpx;
}

.avatar-container {
  position: relative;
}

.avatar-bubble {
  position: relative;
  width: 100rpx;
  height: 110rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-img {
  width: 100rpx;
  height: 110rpx;
  display: block;
}

/* ========== Blue Banner ========== */
.blue-banner {
  background-color: #3B82B5;
  display: flex;
  flex-direction: row;
  align-items: baseline;
  justify-content: center;
  padding: 28rpx 40rpx;
  border-top: 16rpx solid #D4EBF8;
}

.banner-script {
  font-size: 44rpx;
  font-weight: 400;
  color: #ffffff;
  font-style: italic;
  font-family: 'Times New Roman', serif;
}

.banner-bold {
  font-size: 32rpx;
  font-weight: 900;
  color: #ffffff;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin-left: 6rpx;
}

/* ========== Category Pill ========== */
.category-pill-row {
  display: flex;
  flex-direction: row;
  justify-content: center;
  padding: 24rpx 40rpx 20rpx;
}

.category-pill {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: #E5F1FB;
  border-radius: 40rpx;
  padding: 14rpx 0;
  width: 100%;
}

.pill-icon {
  width: 36rpx;
  height: 36rpx;
}

.pill-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #1E5A88;
  letter-spacing: 0.5rpx;
}

/* ========== Operators List ========== */
.operators-list {
  padding: 24rpx 36rpx 24rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  border-left: 10rpx solid #1E68B8;
  margin-left: 24rpx;
}

.operator-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
  padding: 24rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  border: 1.5rpx solid rgba(0, 0, 0, 0.02);
  overflow: hidden;
}

.operator-card-illustration {
  width: 280rpx;
  height: 260rpx;
  margin-left: -50rpx;
  margin-top: -60rpx;
  margin-bottom: -60rpx;
  margin-right: -10rpx;
  flex-shrink: 0;
}

.operator-card:active {
  opacity: 0.95;
  background: #FAFBFF;
}

.operator-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.operator-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #1E2A3A;
  letter-spacing: 0.3rpx;
}

.operator-subtitle {
  font-size: 22rpx;
  color: #888;
  font-weight: 400;
}

.chevron-down-bold {
  width: 14rpx;
  height: 14rpx;
  border-right: 4rpx solid #1E2A3A;
  border-bottom: 4rpx solid #1E2A3A;
  transform: rotate(45deg);
  margin-right: 12rpx;
  flex-shrink: 0;
}

/* ========== Bottom Spacer ========== */
.bottom-spacer {
  height: 100rpx;
}

.operator-logo-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
  margin-right: 20rpx;
}

.operator-logo-img {
  width: 100%;
  height: 100%;
}

.chevron-right-bold {
  width: 14rpx;
  height: 14rpx;
  border-right: 4rpx solid #3B82B5;
  border-top: 4rpx solid #3B82B5;
  transform: rotate(45deg);
  margin-right: 12rpx;
  flex-shrink: 0;
}

.step-container {
  padding: 30rpx 40rpx;
}

.step-header {
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.step-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1E2A3A;
}

.step-subtitle {
  font-size: 24rpx;
  color: #3B82B5;
  font-weight: 600;
}

.services-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.service-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
  padding: 30rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.service-card:active {
  background: #FAFBFF;
}

.service-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1E2A3A;
}

.form-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.input-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #4A5568;
}

.form-input {
  height: 90rpx;
  background: #F7FAFC;
  border: 2rpx solid #E2E8F0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #1A202C;
}

.submit-btn {
  background: #3B82B5;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 45rpx;
  height: 90rpx;
  line-height: 90rpx;
  margin-top: 20rpx;
  border: none;
}

.submit-btn:active {
  opacity: 0.9;
}

.bills-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.bill-card {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.bill-details {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.bill-ref {
  font-size: 26rpx;
  font-weight: 700;
  color: #1E2A3A;
}

.bill-date {
  font-size: 22rpx;
  color: #E53E3E;
  font-weight: 500;
}

.bill-desc {
  font-size: 22rpx;
  color: #718096;
}

.bill-amount {
  font-size: 30rpx;
  font-weight: 800;
  color: #1E2A3A;
}

.total-bar {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.total-info {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.total-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A5568;
}

.total-amount {
  font-size: 36rpx;
  font-weight: 800;
  color: #E53E3E;
}

.pay-btn {
  background: #3B82B5;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 45rpx;
  height: 90rpx;
  line-height: 90rpx;
  width: 100%;
}

.success-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.success-icon-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #EBF8FF;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 30rpx;
}

.success-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #1A202C;
  margin-bottom: 12rpx;
}

.success-subtitle {
  font-size: 24rpx;
  color: #718096;
  margin-bottom: 40rpx;
}

.receipt-details {
  background: #F7FAFC;
  border-radius: 16rpx;
  width: 100%;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.receipt-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.receipt-label {
  font-size: 24rpx;
  color: #718096;
}

.receipt-value {
  font-size: 24rpx;
  font-weight: 700;
  color: #2D3748;
}

.done-btn {
  background: #3B82B5;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 45rpx;
  height: 90rpx;
  line-height: 90rpx;
  width: 100%;
}
