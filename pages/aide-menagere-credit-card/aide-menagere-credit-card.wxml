<!-- ========== Page Détail Paiement Carte Bancaire ========== -->
<view class="container">
  <scroll-view class="scroll-content" scroll-y="true" show-scrollbar="false">
    <view class="scroll-inner">

      <!-- 1. Header -->
      <view class="header-section" style="padding-top: {{statusBarHeight + 10}}px;">
        <view class="header-content">
          <view class="back-btn" bindtap="onBack">
            <view class="back-circle">
              <text class="back-arrow-txt">←</text>
            </view>
            <text class="back-label">Retour</text>
          </view>
          <image src="/assets/logtiqqa.png" class="logo" mode="aspectFit"></image>
          <view class="avatar-container">
            <view class="avatar-bubble">
              <image src="/assets/avatar/avatar-user.png" class="avatar-img" mode="aspectFit"></image>
            </view>
          </view>
        </view>
      </view>

      <!-- 2. Hero Slider Section (Grandfather holding credit card) -->
      <view class="hero-section">
        <view class="banner-container">
          <!-- Mockup Browser Header Bar -->
          <view class="browser-header">
            <view class="dot-container">
              <view class="slide-dot slide-dot--active"></view>
              <view class="slide-dot"></view>
              <view class="slide-dot"></view>
              <view class="slide-dot"></view>
            </view>
          </view>

          <!-- Grandfather image background -->
          <image class="banner-img" src="/assets/payment_image_2.png" mode="aspectFill"></image>

          <!-- Navigation Arrow Circles on the sides -->
          <view class="nav-arrow nav-arrow-left">
            <text class="arrow-char">←</text>
          </view>
          <view class="nav-arrow nav-arrow-right">
            <text class="arrow-char">→</text>
          </view>

          <!-- Text Overlay (No Access button here) -->
          <view class="banner-text-overlay">
            <text class="banner-overlay-title">EFFECTUEZ VOTRE PAIEMENT</text>
            <text class="banner-overlay-title">EN TOUTE SÉCURITÉ</text>
          </view>
        </view>
      </view>

      <!-- 3. Form Section -->
      <view class="form-section">
        <!-- Title 1: Le mode de paiement -->
        <view class="section-title-wrap">
          <text class="section-title">Le mode de paiement</text>
          <view class="title-underline"></view>
        </view>

        <!-- Credit Card Type Selector Preview -->
        <view class="card-type-box">
          <text class="card-type-label">Carte de crédit</text>
          <image class="card-type-icon" src="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%235391C0' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><rect x='2' y='5' width='20' height='14' rx='2'/><line x1='2' y1='10' x2='22' y2='10'/><line x1='6' y1='15' x2='10' y2='15'/></svg>" mode="aspectFit"></image>
        </view>

        <!-- Title 2: Détail de paiement -->
        <view class="section-title-wrap no-underline-margin">
          <text class="section-title">Détail de paiement</text>
        </view>

        <!-- Read-only payment details -->
        <view class="details-list">
          <view class="detail-row">
            <text class="detail-label">Numéro de carte :</text>
            <text class="detail-value">0598 550 993 34</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">Date d'expiration :</text>
            <text class="detail-value">21/06/2030</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">CVC :</text>
            <text class="detail-value">435</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">Adresse facturation :</text>
            <text class="detail-value">Espèces</text>
          </view>
        </view>

        <!-- Checkbox CGU -->
        <view class="cgu-row" bindtap="onToggleCheckbox">
          <view class="checkbox-box {{cguChecked ? 'checked' : ''}}">
            <text class="check-icon" wx:if="{{cguChecked}}">✔</text>
          </view>
          <text class="cgu-text">Confirmer l'acceptation de CGU</text>
        </view>

        <!-- Confirm Button -->
        <view class="confirm-btn-wrap">
          <view class="submit-btn" bindtap="onSubmit">
            <text class="submit-btn-txt">CONFIRMEZ</text>
          </view>
        </view>
      </view>

      <view class="bottom-spacer"></view>
    </view>
  </scroll-view>

  <bottom-nav-bar variant="fixed" message-count="0" bind:navtap="onNavTap" />
</view>
