/* ========== Container ========== */
page {
  background: #C7E2F2; /* Soft light blue page background */
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #C7E2F2;
}

.scroll-content {
  flex: 1;
  overflow: hidden;
}

.scroll-inner {
  display: flex;
  flex-direction: column;
  background: #C7E2F2;
}

/* ========== Header ========== */
.header-section {
  background: #FFFFFF;
  padding-bottom: 0;
  position: relative;
  z-index: 10;
}

.header-content {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 80rpx 14rpx 28rpx;
  height: 110rpx;
  box-sizing: border-box;
}

.back-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  z-index: 10;
}

.back-circle {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: #F0F0F0;
  display: flex;
  justify-content: center;
  align-items: center;
}

.back-arrow-txt {
  font-size: 26rpx;
  color: #333;
  font-weight: normal;
  line-height: 1;
}

.back-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}

.logo {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 140rpx;
  height: 56rpx;
  z-index: 5;
}

/* Bubble avatar */
.avatar-container {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
}

.avatar-bubble {
  position: relative;
  width: 100rpx;
  height: 110rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-img {
  width: 100rpx;
  height: 110rpx;
  display: block;
}

/* ========== Hero Slider Section ========== */
.hero-section {
  background: #3A7EA7; /* Medium steel blue */
  padding: 24rpx 40rpx; /* Matches mockup margins */
  position: relative;
  z-index: 2;
}

.banner-container {
  width: 100%;
  height: 300rpx;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.banner-img {
  width: 100%;
  height: calc(100% - 40rpx);
  margin-top: 40rpx;
  display: block;
}

/* Browser mockup header */
.browser-header {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 40rpx;
  background: #A9D3EC;
  display: flex;
  align-items: center;
  z-index: 4;
}

/* Navigation arrows */
.nav-arrow {
  position: absolute;
  top: calc(50% + 20rpx);
  transform: translateY(-50%);
  width: 50rpx;
  height: 50rpx;
  border-radius: 25rpx;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 5;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.nav-arrow-left {
  left: 20rpx;
}

.nav-arrow-right {
  right: 20rpx;
}

.arrow-char {
  font-size: 26rpx;
  color: #777777;
  font-weight: bold;
  line-height: 1;
}

/* Dots in top right of browser header */
.dot-container {
  position: absolute;
  top: 14rpx;
  right: 24rpx;
  display: flex;
  flex-direction: row;
  gap: 8rpx;
  z-index: 5;
}

.slide-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: #FFFFFF;
}

.slide-dot--active {
  background: #4E82A5;
}

/* Text and Button Overlays */
.banner-text-overlay {
  position: absolute;
  left: 36rpx;
  bottom: 24rpx;
  z-index: 6;
  display: flex;
  flex-direction: column;
}

.banner-overlay-title {
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: bold;
  line-height: 1.25;
  letter-spacing: 0.5rpx;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.4);
}

/* ========== Form Card Section ========== */
.form-section {
  background: #FFFFFF;
  margin: 36rpx 40rpx;
  border-radius: 28rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.section-title-wrap {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.no-underline-margin {
  margin-top: 36rpx;
  margin-bottom: 24rpx;
}

.section-title {
  color: #5391C0; /* Soft steel blue titles */
  font-size: 32rpx;
  font-weight: bold;
  display: inline-block;
}

.section-title-wrap:first-child .section-title {
  border-bottom: 3rpx solid #5391C0;
  padding-bottom: 6rpx;
}

.title-underline {
  display: none;
}

/* Card Type Box */
.card-type-box {
  background: #EBF3F8;
  border-radius: 18rpx;
  height: 84rpx;
  padding: 0 32rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.03);
}

.card-type-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #5391C0;
}

.card-type-icon {
  width: 90rpx;
  height: 60rpx;
}

/* Inputs Form */
.inputs-container {
  display: flex;
  flex-direction: column;
  gap: 24rpx; /* Increased vertical space between rows */
}

.input-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
}

.input-label {
  font-size: 28rpx; /* Matches mockup scale */
  font-weight: bold;
  color: #000000;
  white-space: nowrap;
}

.input-field {
  background: transparent;
  border: none;
  height: 48rpx;
  font-size: 28rpx; /* Matches mockup scale */
  color: #000000; /* Deep black text like labels */
  flex: 1;
}

/* Checkbox CGU */
.cgu-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  margin-top: 36rpx;
  margin-bottom: 24rpx;
}

.checkbox-box {
  width: 38rpx;
  height: 38rpx;
  border-radius: 8rpx; /* Rounded corners */
  border: none; /* No border like mockup */
  background: #D5E7F3; /* Light blue solid fill */
  display: flex;
  justify-content: center;
  align-items: center;
  transition: all 0.2s ease;
}

.checkbox-box.checked {
  background: #5FA1CD; /* Darker blue on check */
}

.check-icon {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: bold;
  line-height: 1;
}

.cgu-text {
  font-size: 26rpx; /* More readable size */
  font-weight: 500;
  color: #000000;
}

/* Confirm Button */
.confirm-btn-wrap {
  display: flex;
  justify-content: center;
  margin-top: 36rpx;
}

.submit-btn {
  background: #5FA1CD;
  border-radius: 60rpx;
  height: 86rpx; /* Taller button */
  width: 520rpx; /* Wider button stretching across form */
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(95, 161, 205, 0.35);
}

.submit-btn:active {
  opacity: 0.85;
}

.submit-btn-txt {
  color: #FFFFFF;
  font-size: 28rpx; /* Larger text */
  font-weight: bold;
  letter-spacing: 2rpx;
}

/* Spacer */
.bottom-spacer {
  height: 160rpx;
}

/* Saved Cards Styles */
.saved-cards-section {
  margin-bottom: 36rpx;
}

.saved-cards-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 16rpx;
}

.saved-card-item {
  background: #F4F8FB;
  border: 2rpx solid #E1EDF4;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: all 0.2s ease;
}

.saved-card-item--selected {
  border-color: #5FA1CD;
  background: #EBF3F8;
}

.card-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.card-icon {
  width: 60rpx;
  height: 40rpx;
}

.card-name {
  font-size: 26rpx;
  color: #333333;
  font-weight: 600;
}

.card-radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  border: 2rpx solid #B0C4DE;
  display: flex;
  justify-content: center;
  align-items: center;
}

.card-radio--selected {
  border-color: #5FA1CD;
  background: #5FA1CD;
}

.radio-check {
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: bold;
}

.plus-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background: #5FA1CD;
  color: #FFFFFF;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 28rpx;
  font-weight: bold;
}

