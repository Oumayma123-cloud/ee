.login-page {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #B38F7F; /* Standard tiqqa background */
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
}

.login-header {
  padding: 100rpx 48rpx 80rpx;
  text-align: center;
}

.login-logo {
  width: 220rpx;
  display: block;
  margin: 0 auto;
}

.login-card {
  background: #FFFFFF;
  border-radius: 60rpx 60rpx 0 0;
  padding: 60rpx 50rpx 80rpx;
  box-shadow: 0 -15rpx 40rpx rgba(0, 0, 0, 0.08);
  flex: 1;
  display: flex;
  flex-direction: column;
}

.login-title-wrap {
  margin-bottom: 60rpx;
}

.login-title {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: #000000;
  margin-bottom: 12rpx;
}

.login-field {
  margin-bottom: 30rpx;
}

.login-label {
  display: block;
  font-size: 30rpx;
  color: #000000;
  margin-bottom: 16rpx;
  font-weight: 600;
}

.login-input-container {
  position: relative;
  width: 100%;
}

.login-input {
  width: 100%;
  height: 90rpx;
  padding: 0 30rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333333;
  background: #FFFFFF;
  border: 2rpx solid #E5E5E5;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.login-placeholder {
  color: #999999;
}

.login-eye {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 20rpx;
  z-index: 5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-eye-img {
  width: 40rpx;
  height: 40rpx;
}

.login-forgot-wrap {
  text-align: right;
  margin-bottom: 60rpx;
}

.login-forgot {
  font-size: 28rpx;
  color: #9BA5B1;
  font-weight: 500;
}

.login-actions {
  margin-top: auto;
}

.login-btn {
  width: 100% !important;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 50rpx;
  margin-bottom: 30rpx;
}

.login-btn--primary {
  background: #B38F7F;
  color: #FFFFFF;
  border: none;
}

.login-btn--outline {
  background: #FFFFFF;
  color: #B38F7F;
  border: 2rpx solid #B38F7F;
}

.home-indicator {
  position: absolute;
  bottom: 12rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 134rpx;
  height: 10rpx;
  background: rgba(0, 0, 0, 0.1);
  border-radius: 5rpx;
}
