.page {
  height: 100vh;
  background: #B88E7E;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

/* HEADER */
.header {
  padding-top: 80rpx;
  padding-bottom: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-container {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 30rpx;
  position: relative;
  z-index: 10;
}

.logo-img {
  width: 200rpx;
  display: block;
}

/* CARD */
.card {
  flex: 1;
  background: #B88E7E;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 60rpx 40rpx;
}

/* IMAGE CONTAINER */
.image-container {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-bottom: 60rpx;
}

.phone-image {
  width: 300rpx;
  height: 300rpx;
}

/* SUCCESS MESSAGE */
.success-title {
  font-size: 40rpx;
  font-weight: 500;
  color: #FFFFFF;
  text-align: center;
  margin-bottom: 80rpx;
  line-height: 1.4;
}

/* BUTTON CONTAINER */
.button-container {
  display: flex;
  justify-content: center;
}

.btn-arrow {
  width: 120rpx;
  height: 120rpx;
  border: 3rpx solid #FFFFFF;
  border-radius: 25rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.arrow-icon {
  font-size: 60rpx;
  color: #FFFFFF;
  font-weight: 300;
}
