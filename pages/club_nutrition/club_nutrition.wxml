<view class="nutrition-container">
  <view class="mobile-card">

    <!-- Standardized Header -->
    <view class="horaire-header-wrap">
      <view class="status-row">
        <device-status-bar fillStatusBar="{{true}}" edgePadding="{{false}}" />
      </view>
      <view class="top-bar top-bar--horaire">
        <view class="back-wrap" bindtap="onBack">
          <view class="back-circle">←</view>
          <text class="back-text">Retour</text>
        </view>
        <image class="logo" src="/assets/logo/logo-tiqqa.png" mode="aspectFit"></image>
        <view class="avatar-bubble" bindtap="onProfileTap">
          <view class="avatar-wrap avatar-wrap--bubble">
            <image class="avatar" src="/assets/profile.png" mode="aspectFill"></image>
          </view>
          <view class="avatar-bubble-tail"></view>
        </view>
      </view>
    </view>

    <!-- Hero Section -->
    <view class="nutrition-hero-area">
      <view class="nutrition-hero-main">
        <image class="nutrition-hero-img" src="/assets/club.png" mode="aspectFill"></image>
        <view class="nutrition-hero-overlay">
          <text class="nutrition-hero-title">DÉCOUVREZ NOS CLUBS TIQQA</text>
          <view class="nutrition-hero-btn" bindtap="onHeroCta">
            <text class="nutrition-hero-btn-txt">ACCÉDER</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Date Navigation Strip -->
    <view class="nutrition-date-strip">
      <view class="date-arrow-btn" bindtap="onPrevDate">←</view>
      <view class="date-center">
        <image class="date-calendar-icon" src="/assets/vocale.png" mode="aspectFit"></image>
        <text class="date-text">{{currentDate}}</text>
      </view>
      <view class="date-arrow-btn" bindtap="onNextDate">→</view>
    </view>

    <!-- Main Title -->
    <view class="nutrition-main-header">
      <view class="nutrition-title-row">
        <image class="nutrition-title-img-script" src="/assets/Clubs.png" mode="heightFix"></image>
        <text class="nutrition-title-text">NUTRITION</text>
      </view>
    </view>

    <!-- Scrollable Cards & Scrollbar Area -->
    <view class="nutrition-grid-container">

      <scroll-view class="content-scroll" scroll-y bindscroll="onScroll" show-scrollbar="{{false}}" enhanced="{{true}}">
        <view class="nutrition-grid">

          <!-- Activités Card -->
          <view class="nutrition-card" bindtap="onCardTap" data-type="activites">
            <view class="nutrition-card-img-wrap">
              <image class="nutrition-card-img" src="/assets/N1.png" mode="aspectFill"></image>
            </view>
            <view class="nutrition-card-footer">
              <text class="nutrition-card-label">ACTIVITÉS</text>
            </view>
          </view>

          <!-- Communauté Card -->
          <view class="nutrition-card" bindtap="onCardTap" data-type="communaute">
            <view class="nutrition-card-img-wrap">
              <image class="nutrition-card-img" src="/assets/N2.png" mode="aspectFill"></image>
            </view>
            <view class="nutrition-card-footer">
              <text class="nutrition-card-label">COMMUNAUTÉ</text>
            </view>
          </view>

          <!-- Vidéos Card -->
          <view class="nutrition-card" bindtap="onCardTap" data-type="videos">
            <view class="nutrition-card-img-wrap">
              <image class="nutrition-card-img" src="/assets/N3.png" mode="aspectFill"></image>
            </view>
            <view class="nutrition-card-footer">
              <text class="nutrition-card-label">VIDÉOS</text>
            </view>
          </view>

          <!-- Coach Card -->
          <view class="nutrition-card" bindtap="onCardTap" data-type="coach">
            <view class="nutrition-card-img-wrap">
              <image class="nutrition-card-img" src="/assets/N4.png" mode="aspectFill"></image>
            </view>
            <view class="nutrition-card-footer">
              <text class="nutrition-card-label">COACH</text>
            </view>
          </view>

        </view>
        <view class="bottom-spacer"></view>
      </scroll-view>

      <!-- Dynamic Functional Scrollbar -->
      <view class="nutrition-scrollbar">
        <view class="nutrition-scroll-arrow">↑</view>
        <view class="nutrition-scroll-track">
          <view class="nutrition-scroll-thumb" style="top: calc({{scrollPercent}}% - {{scrollPercent * 0.8}}rpx);"></view>
        </view>
        <view class="nutrition-scroll-arrow">↓</view>
      </view>

    </view>

    <!-- Bottom Navigation Bar -->
    <bottom-nav-bar variant="fixed" message-count="6" bind:navtap="onNavTap" />
  </view>
</view>
