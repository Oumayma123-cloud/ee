/* ========== Page Démarches Administratives ========== */
page {
  background: #ffffff;
}

.container {
  width: 100%;
  min-height: 100vh;
  position: relative;
  background: #ffffff;
  margin: 0 auto;
  box-sizing: border-box;
}

.scroll-content {
  width: 100%;
  height: 100%;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}



.scroll-inner {
  width: 100%;
}

/* ========== 1. Header (White) ========== */
.header-section {
  background: #ffffff;
  width: 100%;
}

.header-content {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 32rpx 12rpx;
}

.back-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.back-circle {
  width: 54rpx;
  height: 54rpx;
  border-radius: 27rpx;
  background: #EEEEEE;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.1);
}

.back-arrow-txt {
  font-size: 24rpx;
  color: #333;
  font-weight: normal;
  line-height: 1;
}

.back-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #333;
}

.logo {
  width: 150rpx;
  height: 60rpx;
}

.avatar-container {
  position: relative;
}

.avatar-bubble {
  position: relative;
  width: 100rpx;
  height: 110rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-img {
  width: 100rpx;
  height: 110rpx;
  display: block;
}

.avatar-tail {
  display: none; /* Hide the artificial HTML tail as it is already beautifully built into the Group PNG */
}

/* ========== 2. Top Strip (Maroonish Beige) ========== */
.top-strip {
  background-color: #D6C2B8;
  height: 20rpx;
  width: 100%;
}

/* ========== 3. Maroon Zone (Hero) ========== */
.hero-section {
  background-color: #925D59;
  padding: 36rpx 0 44rpx;
}

.hero-window {
  margin: 0 44rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.2);
}

.hero-window-header {
  background-color: #D6C2B8;
  height: 52rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  padding: 0 32rpx;
}

.window-dots {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.window-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 9rpx;
  background-color: #ffffff;
}

.window-dot--active {
  background-color: #593532;
}

.hero-window-body {
  position: relative;
  height: 360rpx;
  background: #fff;
  overflow: hidden;
}

.hero-bg {
  width: 100%;
  height: calc(100% + 60rpx);
  margin-top: -60rpx;
  display: block;
}

.hero-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 170rpx;
  padding: 0 32rpx 36rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.5) 0%, transparent 100%);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: flex-start;
}

.hero-title {
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
  line-height: 1.2;
}

.hero-btn {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 12rpx 36rpx;
}

.hero-btn-txt {
  color: #000;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

/* ========== 4. Spacer Zone (Light Blue/Greyish) ========== */
.date-zone {
  background-color: #EDF3F5;
  height: 60rpx;
}

/* ========== 5. Services Section (White) ========== */
.services-section {
  background: #ffffff;
  padding-top: 10rpx;
}

.section-title-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  justify-content: flex-start;
  width: 510rpx; 
  margin: 58rpx 0 58rpx 130rpx; 
}

.section-title-script {
  font-family: 'The Cottage', cursive;
  font-weight: 400;
  font-style: normal;
  font-size: 28rpx; /* 14px * 1.923 */
  line-height: 100%;
  letter-spacing: 2rpx; /* 1px * 1.923 */
  text-transform: capitalize;
  color: #98766B; 
}

.section-title-bold {
  font-family: 'Poppins', sans-serif;
  font-weight: 700;
  font-style: normal;
  font-size: 28rpx; /* 14px * 1.923 */
  line-height: 100%;
  letter-spacing: 2rpx; /* 1px * 1.923 */
  text-transform: uppercase;
  color: #98766B; 
  margin-left: 12rpx; /* 6px * 1.923 */
}

.grid-container {
  display: flex;
  flex-direction: row;
  padding-left: 150rpx; 
  padding-right: 0;
  align-items: flex-start;
  justify-content: flex-start; 
}

.services-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  gap: 28rpx; 
}

/* ========== Service Card ========== */
.service-card {
  width: 200rpx; /* Reduced card size */
  height: 256rpx; 
  border-radius: 18rpx; 
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0;
  box-sizing: border-box;
  background-color: #A98072; 
  overflow: hidden;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.08); 
  margin-bottom: 0;
}

/* No zebra striping in this version */
.service-card:nth-child(even) {
  background-color: #A98072;
}

.service-card-photo-wrap {
  width: 100%;
  height: 146rpx; 
  background: transparent;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 16rpx 10rpx 8rpx; 
  box-sizing: border-box;
}

.service-card-footer {
  width: 100%;
  background-color: rgba(0, 0, 0, 0.2); 
  padding: 10rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  flex: 1;
}

.service-card-label {
  color: #fff;
  font-size: 18rpx; 
  font-weight: 800;
  text-align: center;
  letter-spacing: 1rpx;
  line-height: 1.3;
  text-transform: uppercase;
  white-space: pre-line;
}

.doc-image {
  width: 85%;
  height: 85%;
  display: block;
  filter: drop-shadow(0 2rpx 4rpx rgba(0,0,0,0.1));
}

/* Mockups for documents */
.doc-mockup {
  width: 100%;
  height: 100%;
  position: relative;
  border-radius: 10rpx;
  box-shadow: 0 4rpx 8rpx rgba(0,0,0,0.1);
  overflow: hidden;
}

.cnie-mockup {
  background: #E8E2D6;
}

.passport-mockup {
  background: #3B5E4F;
}

.permis-mockup {
  background: #F2D2BD;
}

.doc-photo {
  width: 40rpx;
  height: 50rpx;
  background: #D1CAC0;
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  border-radius: 4rpx;
}

.doc-lines {
  position: absolute;
  top: 20rpx;
  left: 80rpx;
  right: 20rpx;
}

.doc-line {
  height: 6rpx;
  background: #C4B9AA;
  margin-bottom: 10rpx;
  border-radius: 3rpx;
}

.doc-line:last-child {
  width: 60%;
}

.doc-flag {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  width: 30rpx;
  height: 20rpx;
  background: #C8102E;
}

.passport-emblem {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #E5C07B;
  border-radius: 50%;
  position: absolute;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.passport-text {
  position: absolute;
  bottom: 20rpx;
  width: 100%;
  text-align: center;
  color: #E5C07B;
  font-size: 14rpx;
  font-weight: bold;
}

.service-card-label {
  color: #fff;
  font-size: 18rpx;
  font-weight: 800;
  text-align: center;
  letter-spacing: 0.5rpx;
  line-height: 1.2;
  text-transform: uppercase;
  white-space: pre-line;
  margin-top: 4rpx;
}

/* ========== Scroll Indicator ========== */
.scroll-indicator {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-left: 24rpx; 
  padding-top: 40rpx;
  flex-shrink: 0;
}

.scroll-arrow {
  width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  background: #F0F0F0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.05);
}

.scroll-arrow-text {
  font-size: 18rpx;
  color: #888;
  font-weight: bold;
}

.scroll-track {
  width: 10rpx;
  height: 240rpx;
  background: #F8F8F8;
  border-radius: 5rpx;
  position: relative;
  box-shadow: inset 0 1rpx 3rpx rgba(0,0,0,0.05);
  border: 1rpx solid #EBEBEB;
}

.scroll-thumb {
  position: absolute;
  left: 0;
  right: 0;
  height: 60rpx;
  background: #925D59;
  border-radius: 5rpx;
  top: 0;
}

/* ========== Bottom Spacer ========== */
.bottom-spacer {
  height: 0;
}

/* ========== Centering Modifiers for Passport Renewal View ========== */
.section-title-row--centered {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  justify-content: center !important;
  margin: 58rpx auto !important;
  width: auto !important;
}

.grid-container--centered {
  display: flex;
  flex-direction: row;
  padding: 0 !important;
  align-items: center !important;
  justify-content: center !important; 
}

.services-grid--centered {
  display: flex;
  justify-content: center !important;
  gap: 0 !important;
}

.service-card-photo {
  width: 100%;
  height: 100%;
  display: block;
}
