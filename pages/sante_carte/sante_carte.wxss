page {
  background-color: #ffffff !important;
  width: 750rpx !important;
  max-width: 100% !important;
  margin: 0 !important;
  padding: 0 !important;
  box-sizing: border-box !important;
}

@font-face {
  font-family: 'The Cottage';
  src: url('/fonts/The-Cottage.ttf');
  font-weight: 400;
  font-style: normal;
}

.container {
  background-color: #ffffff !important;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 0 !important;
  margin: 0 !important;
  width: 750rpx !important;
  max-width: 100% !important;
  display: flex !important;
  flex-direction: column !important;
  justify-content: stretch;
  align-items: stretch;
}

.shell {
  width: 750rpx !important;
  max-width: 100% !important;
  height: 100vh;
  max-height: 100vh;
  background: #ffffff !important;
  border-radius: 0rpx !important;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  padding-top: 8rpx;
  padding-bottom: 140rpx; /* Space for bottom nav */
  box-sizing: border-box;
  margin: 0 !important;
}

/* New Header Styles from Photo */
.horaire-header-wrap {
  flex-shrink: 0;
  background: #ffffff;
  min-height: 120rpx;
  height: auto;
  padding-top: 10rpx;
  padding-bottom: 8rpx;
  box-sizing: border-box;
  position: sticky;
  top: 0;
  z-index: 100;
  width: 750rpx !important;
  max-width: 100% !important;
  margin: 0 !important;
}

.status-row {
  display: flex;
  align-items: center;
  padding: 0 34rpx 0rpx;
  box-sizing: border-box;
  min-height: 0;
  height: auto;
}

.top-bar--horaire {
  position: relative;
  width: 100%;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx 0 20rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.back-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.back-circle {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #f2f2f2;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #333;
  font-size: 24rpx;
  font-weight: bold;
}

.back-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #000000;
}

.logo {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 60rpx;
}

.avatar-bubble {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  position: relative;
  z-index: 10;
}

.avatar-wrap {
  position: relative;
  width: 120rpx;
  height: 130rpx;
}

.avatar-wrap--bubble {
  position: relative;
  z-index: 4;
}

.avatar-wrap--bubble::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20rpx;
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-top: 18rpx solid #fff;
  z-index: 4;
  pointer-events: none;
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 54rpx;
  border: 5rpx solid #fff;
  display: block;
  position: relative;
  z-index: 4;
  background: #e8e8e8;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.14);
}

.banner-area {
  width: 750rpx !important;
  max-width: 100% !important;
  margin: 0 !important;
  padding: 0 !important;
  box-sizing: border-box !important;
}

.banner-top-bar {
  background-color: #b8d8c1;
  height: 22rpx;
  width: 100% !important;
}

.banner-section {
  position: relative;
  height: 310rpx;
  overflow: hidden;
  width: 100% !important;
  margin: 0 !important;
  padding: 0 !important;
}

.banner-img {
  width: 100% !important;
  height: 100%;
  display: block;
}

.banner-content {
  position: absolute;
  bottom: 16rpx;
  left: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.banner-title {
  color: #fff;
  font-weight: 700;
  font-size: 22rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.35);
  margin-bottom: 8rpx;
}

.btn-acceder {
  background: #fff;
  color: #222;
  font-size: 16rpx;
  font-weight: 700;
  border-radius: 30rpx;
  width: 110rpx;
  height: 38rpx;
  line-height: 38rpx;
  text-align: center;
}

.banner-nav-bar {
  background-color: #b8d8c1;
  height: 54rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 180rpx;
  width: 750rpx !important;
  max-width: 100% !important;
  box-sizing: border-box !important;
}

.nav-arrow-wrapper {
  background: #d9dfdb;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.nav-arrow-icon {
  width: 12rpx;
  height: 12rpx;
  opacity: 1;
  filter: brightness(0);
}

.section-title {
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 24rpx 0 20rpx;
}

.thin {
  font-family: 'The Cottage', 'Brush Script MT', cursive;
  font-weight: 400;
  color: #123a53;
  font-size: 56rpx;
  margin-right: 12rpx;
}

.bold {
  font-family: "Poppins", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  font-weight: 700;
  font-size: 38rpx;
  text-transform: uppercase;
  color: #1c7a61;
}

.main-content-wrapper {
  display: flex;
  flex: 1;
  min-height: 0; /* Ensures the flex item can shrink and scroll-view overflows */
  position: relative;
  padding: 20rpx 20rpx 12rpx;
  box-sizing: border-box;
  justify-content: center;
  overflow: hidden;
}

.grid-scroll-view {
  flex: 1;
  height: 100%;
  width: 100%;
  box-sizing: border-box;
}

.cards-grid {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-content: flex-start;
  width: 100%;
  row-gap: 30rpx;
  column-gap: 32rpx;
  padding-right: 20rpx; /* Pour compenser la scrollbar */
  padding-bottom: 120rpx; /* Pour permettre un defilement suffisant et voir les cartes completement */
}

.pay-card {
  width: 232rpx;   /* 116px * 2 */
  height: 298rpx;  /* 149px * 2 */
  border-radius: 18rpx; /* ~9px * 2 */
  background: #8bbd9a;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 12rpx 12rpx;
  box-sizing: border-box;
}

.card-image {
  width: 150rpx;
  height: 150rpx;
}

.card-title {
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  text-align: center;
  line-height: 1.2;
  min-height: 42rpx;
  letter-spacing: 1rpx;
}

.confirm-btn {
  width: 148rpx !important;
  height: 52rpx !important;
  line-height: 52rpx !important;
  border-radius: 26rpx !important;
  background: #2f8550 !important;
  color: #fff !important;
  font-size: 17rpx !important;
  font-weight: 700 !important;
  padding: 0 !important;
}

.confirm-btn::after {
  border: none !important;
}

.side-scrollbar {
  position: absolute;
  right: 20rpx;
  top: 40rpx;
  width: 60rpx;
  height: 480rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.scroll-track {
  width: 32rpx;
  flex: 1;
  background: #ffffff;
  border-radius: 16rpx;
  position: relative;
  box-sizing: border-box;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  border: none;
}

.scroll-handle {
  width: 100%;
  height: 120rpx;
  background: #3c7d58;
  border-radius: 16rpx;
  position: absolute;
  top: 0;
  box-shadow: none;
}

.scroll-arrow-up,
.scroll-arrow-down {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(180deg, #f0f0f0 0%, #dcdcdc 100%);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
  border: none;
}

.scroll-arrow-up .arrow-text,
.scroll-arrow-down .arrow-text {
  font-size: 32rpx;
  color: #727c80;
  font-weight: 400;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}
