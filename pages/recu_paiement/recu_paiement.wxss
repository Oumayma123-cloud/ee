/* Styles for Recu Paiement page - Updated to trigger compile */
.container {
  height: 100vh;
  width: 100%;
  background: #1a1a1a;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.mobile-card {
  width: 750rpx;
  margin: 0 auto;
  border-radius: 57.69rpx;
  overflow: hidden;
  background: #ffffff;
  flex: 1;
  display: flex;
  flex-direction: column;
  position: relative;
  padding-top: 8rpx;
}

.content-scroll {
  flex: 1;
  overflow-y: auto;
  background: #ffffff;
}

/* Header Styles */
.horaire-header-wrap {
  flex-shrink: 0;
  background: #ffffff;
  min-height: 120rpx;
  height: auto;
  padding-top: 10rpx;
  padding-bottom: 8rpx;
  box-sizing: border-box;
}

.status-row {
  display: flex;
  align-items: center;
  padding: 0 34rpx 0rpx;
  box-sizing: border-box;
  min-height: 0;
  height: auto;
}

.top-bar--horaire {
  position: relative;
  width: 100%;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx 0 20rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.back-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.back-circle {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #fcfcfc;
  border: 1px solid #eeeeee;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #333;
  font-size: 24rpx;
}

.back-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #000000;
}

.logo {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 60rpx;
}

.avatar-bubble {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  position: relative;
  z-index: 10;
}

.avatar-wrap {
  width: 150rpx;
  height: 150rpx;
  background: transparent;
}

.avatar {
  width: 100%;
  height: 100%;
}

/* Page Content */
.page-content {
  padding: 0 40rpx;
  display: flex;
  flex-direction: column;
}

.page-title-wrap {
  margin-top: 20rpx;
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #d05a73; /* Pink */
  letter-spacing: 1rpx;
}

.title-separator {
  width: 100%;
  height: 2rpx;
  background: #d05a73;
  margin-top: 10rpx;
  opacity: 0.5;
}

/* Success Box */
.success-box {
  background: #fbf5d9;
  border-radius: 12rpx;
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  margin-bottom: 40rpx;
}

.success-text {
  font-size: 26rpx;
  color: #73684a;
  font-weight: 600;
  line-height: 1.5;
  margin-bottom: 15rpx;
}

.success-link {
  font-size: 22rpx;
  color: #5b9bd5;
  text-decoration: none;
  font-weight: 600;
}

/* Sections */
.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #d05a73;
  margin-bottom: 15rpx;
  display: block;
}

.detail-card {
  border: 2rpx solid #f0dcdc;
  border-radius: 12rpx;
  padding: 24rpx;
  background: #ffffff;
}

.detail-row {
  display: flex;
  margin-bottom: 12rpx;
  font-size: 22rpx;
}

.detail-row:last-child {
  margin-bottom: 0;
}

.detail-label {
  width: 240rpx;
  color: #333333;
  font-weight: 700;
  flex-shrink: 0;
}

.detail-colon {
  width: 20rpx;
  color: #333333;
  font-weight: 700;
  flex-shrink: 0;
}

.detail-value {
  flex: 1;
  color: #555555;
  word-break: break-all;
}

.bottom-spacer {
  height: 120rpx;
}
