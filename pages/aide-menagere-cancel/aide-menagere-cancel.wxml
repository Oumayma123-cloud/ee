<view class="container tierce-bg cancel-page">
  <view class="header-section {{showModal1 || showModal2 || showSuccessModal || showConfirmModal || showFinalCancelModal || showLastInfoModal ? 'page-blur' : ''}}">
    <view class="status-row">
      <device-status-bar fillStatusBar="{{true}}" edgePadding="{{false}}" />
    </view>
    <view class="header-content">
      <view class="back-btn" bindtap="onBackTap">
        <view class="back-circle">
          <text class="back-arrow-txt">←</text>
        </view>
        <text class="back-label">Retour</text>
      </view>
      <image class="logo" src="/assets/logo/logo-tiqqa.png" mode="aspectFit"></image>
      <view class="avatar-container" bindtap="onProfileTap">
        <view class="avatar-bubble">
          <image class="avatar-img" src="/assets/avatar/avatar-user.png" mode="aspectFit"></image>
        </view>
      </view>
    </view>
  </view>

  <scroll-view class="scroll-content {{showModal1 || showModal2 || showSuccessModal || showConfirmModal || showFinalCancelModal || showLastInfoModal ? 'page-blur' : ''}}" scroll-y="true">
    <view class="scroll-inner">
      <!-- 1. Blue Zone (Top part) -->
      <view class="blue-zone">
        <!-- Title and Check badge -->
        <view class="title-row">
          <text class="cancel-title">RENDEZ VOUS ANNULÉ</text>
          <view class="check-badge">
            <text class="check-text">✓</text>
          </view>
        </view>

        <!-- Subtitle message -->
        <view class="subtitle-wrap">
          <text class="cancel-subtitle">Suite à l'annulation de votre rendez-vous, une notification vous sera envoyée dès que le remboursement sera effectué. ou vous pouvez reprogrammer un autre RDV</text>
        </view>

        <!-- Recap Card -->
        <view class="recap-card">
          <view class="recap-header">
            <text class="recap-title">Récapitulatif</text>
            <view class="recap-underline"></view>
          </view>
          <view class="recap-body">
            <view class="recap-row">
              <text class="recap-label">Date : </text>
              <text class="recap-val">{{dateVal}}</text>
            </view>
            <view class="recap-row">
              <text class="recap-label">Adresse d'intervention : </text>
              <text class="recap-val">{{addressVal}}</text>
            </view>
            <view class="recap-row">
              <text class="recap-label">Le montant à payer : </text>
              <text class="recap-val">{{amountVal}}</text>
            </view>
            <view class="recap-row">
              <text class="recap-label">Mode de paiement : </text>
              <text class="recap-val">{{paymentVal}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 2. White Zone (Bottom part) -->
      <view class="white-zone">
        <view class="lady-container">
          <image class="lady-img" src="/assets/aide-menagere-woman-transparent-v2.png" mode="aspectFit"></image>
        </view>

        <!-- Action Buttons -->
        <view class="action-btn-wrap">
          <view class="btn-share" bindtap="onModify">
            <text class="btn-share-txt">REPROGRAMMER UN RDV</text>
          </view>
          <view class="btn-cancel-order" bindtap="onCancelExit">
            <text class="btn-cancel-txt">ANNULEZ</text>
          </view>
        </view>

        <!-- Bottom nav spacer -->
        <view class="bottom-spacer"></view>
      </view>
    </view>
  </scroll-view>

  <bottom-nav-bar class="{{showModal1 || showModal2 || showSuccessModal || showConfirmModal || showFinalCancelModal || showLastInfoModal ? 'page-blur' : ''}}" variant="fixed" active-tab="services" message-count="6" bind:navtap="onNavTap" />

  <!-- Custom Cancel Confirmation Modal 1 -->
  <view wx:if="{{showModal1}}" class="modal-overlay" bindtap="onModal1Close">
    <view class="modal-card" catchtap="onPreventBubble">
      <text class="modal-icon">?</text>
      <text class="modal-text">Vous êtes sur\nde bien vouloir annuler ?</text>
      <view class="modal-buttons-row">
        <view class="modal-btn btn-oui" bindtap="onModal1Confirm">
          <text class="modal-btn-txt btn-oui-txt">OUI</text>
        </view>
        <view class="modal-btn btn-non" bindtap="onModal1Close">
          <text class="modal-btn-txt btn-non-txt">NON</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Custom Cancel Confirmation Modal 2 (Warning) -->
  <view wx:if="{{showModal2}}" class="modal-overlay" bindtap="onModal2Close">
    <view class="modal-card" catchtap="onPreventBubble">
      <text class="modal-icon">?</text>
      <text class="modal-text">Souhaitez-vous annuler le\nrendez-vous ?\n<text class="modal-warning-sub">Attention : cette action n'entraîne pas de remboursement.</text></text>
      <view class="modal-buttons-row">
        <view class="modal-btn btn-oui" bindtap="onModal2Confirm">
          <text class="modal-btn-txt btn-oui-txt">OUI</text>
        </view>
        <view class="modal-btn btn-non" bindtap="onModal2Close">
          <text class="modal-btn-txt btn-non-txt">NON</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Custom Success Modal (Modal 3) -->
  <view wx:if="{{showSuccessModal}}" class="modal-overlay" bindtap="onSuccessModalClose">
    <view class="success-card" catchtap="onPreventBubble">
      <text class="success-title">Vos modifications\nont bien été enregistrées</text>
      <text class="success-subtitle">Vous recevrez une notification\nde rappel la veille du RDV.</text>
      <view class="success-close-btn" bindtap="onSuccessModalClose">
        <text class="success-close-txt">✕</text>
      </view>
    </view>
  </view>

  <!-- Custom Confirm Modal (Modal 4) -->
  <view wx:if="{{showConfirmModal}}" class="modal-overlay" bindtap="onConfirmModalClose">
    <view class="success-card" catchtap="onPreventBubble">
      <text class="success-title">Votre nouveau rendez-vous\na bien été enregistré.</text>
      <text class="success-subtitle">Vous recevrez une notification\nde rappel la veille du RDV.</text>
      <view class="success-close-btn" bindtap="onConfirmModalClose">
        <text class="success-close-txt">✕</text>
      </view>
    </view>
  </view>

  <!-- Custom Final Cancel Modal (Modal 5) -->
  <view wx:if="{{showFinalCancelModal}}" class="modal-overlay" bindtap="onFinalCancelModalClose">
    <view class="modal-card" catchtap="onPreventBubble">
      <text class="modal-icon">?</text>
      <text class="modal-text">Votre rendez-vous a été annulé\navec succès.</text>
      <view class="modal-buttons-row" style="justify-content: center;">
        <view class="modal-btn btn-oui" style="max-width: 280rpx;" bindtap="onFinalCancelModalClose">
          <text class="modal-btn-txt btn-oui-txt">OK</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Custom Last Info Modal (Modal 6) -->
  <view wx:if="{{showLastInfoModal}}" class="modal-overlay" bindtap="onLastInfoModalClose">
    <view class="success-card" catchtap="onPreventBubble">
      <text class="success-title" style="margin-bottom: 50rpx;">Votre demande a bien été\nprise en compte ! [leila xxx]\ninterviendra à l'adresse\nindiquée dans les délais\nprévus. Vous recevrez une\nnotification avant son arrivée.</text>
      <view class="success-close-btn" bindtap="onLastInfoModalClose">
        <text class="success-close-txt">✕</text>
      </view>
    </view>
  </view>
</view>
