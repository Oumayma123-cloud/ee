/* ========== Container & Scroll ========== */
.cancel-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #C7E2F2;
}

.cancel-page .scroll-content {
  flex: 1;
  overflow: hidden;
}

.cancel-page .scroll-inner {
  display: flex;
  flex-direction: column;
  background: #C7E2F2;
}

/* ========== Header ========== */
.cancel-page .header-section {
  background: #FFFFFF;
  position: relative;
  z-index: 10;
}

.cancel-page .header-content {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 80rpx 14rpx 28rpx;
  height: 110rpx;
  box-sizing: border-box;
}

.cancel-page .back-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  z-index: 10;
}

.cancel-page .back-circle {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: #F0F0F0;
  display: flex;
  justify-content: center;
  align-items: center;
}

.cancel-page .back-arrow-txt {
  font-size: 26rpx;
  color: #333;
  font-weight: normal;
  line-height: 1;
}

.cancel-page .back-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}

.cancel-page .logo {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 140rpx;
  height: 56rpx;
  z-index: 5;
}

/* Bubble avatar */
.cancel-page .avatar-container {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
}

.cancel-page .avatar-bubble {
  position: relative;
  width: 100rpx;
  height: 110rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cancel-page .avatar-img {
  width: 100rpx;
  height: 110rpx;
  display: block;
}

/* ========== Blue Zone (Top part) ========== */
.cancel-page .blue-zone {
  background: #C7E2F2;
  display: flex;
  flex-direction: column;
}

.cancel-page .title-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-top: 20rpx;
  margin-bottom: 24rpx;
}

.cancel-page .cancel-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #000000;
  letter-spacing: 0.5rpx;
  text-align: center;
}

.cancel-page .check-badge {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background: #4CD964;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(76, 217, 100, 0.3);
  flex-shrink: 0;
}

.cancel-page .check-text {
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: bold;
  line-height: 1;
}

.cancel-page .subtitle-wrap {
  padding: 0 40rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.cancel-page .cancel-subtitle {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.6;
}

/* ========== Recap Card ========== */
.cancel-page .recap-card {
  background: #EDF4F9;
  margin: 0 54rpx 20rpx 54rpx;
  border-radius: 40rpx;
  padding: 36rpx 44rpx;
  box-shadow: none;
}

.cancel-page .recap-header {
  margin-bottom: 24rpx;
}

.cancel-page .recap-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #5993BA;
}

.cancel-page .recap-underline {
  width: 320rpx;
  height: 3rpx;
  background: #5993BA;
  margin-top: 8rpx;
}

.cancel-page .recap-body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.cancel-page .recap-row {
  display: block;
  line-height: 1.5;
}

.cancel-page .recap-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #000000;
  margin-right: 8rpx;
}

.cancel-page .recap-val {
  font-size: 28rpx;
  font-weight: normal;
  color: #000000;
}

/* ========== White Zone (Bottom part) ========== */
.cancel-page .white-zone {
  background: #FFFFFF;
  padding-top: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.cancel-page .lady-container {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  margin-bottom: 20rpx;
}

.cancel-page .lady-img {
  width: 380rpx;
  height: 300rpx;
}

/* ========== Action Buttons ========== */
.cancel-page .action-btn-wrap {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  align-items: center;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.cancel-page .btn-share {
  background: #5FA1CD;
  border-radius: 60rpx;
  height: 86rpx;
  width: 640rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(95, 161, 205, 0.25);
}

.cancel-page .btn-share:active {
  opacity: 0.85;
}

.cancel-page .btn-share-txt {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
  letter-spacing: 1rpx;
}

.cancel-page .btn-cancel-order {
  background: #234D6F;
  border-radius: 60rpx;
  height: 86rpx;
  width: 640rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(35, 77, 111, 0.25);
}

.cancel-page .btn-cancel-order:active {
  opacity: 0.85;
}

.cancel-page .btn-cancel-txt {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
  letter-spacing: 1rpx;
}

.cancel-page .bottom-spacer {
  height: 180rpx;
  background: #FFFFFF;
}

/* ========== Custom Modal Styles ========== */
.page-blur {
  filter: blur(5px);
  pointer-events: none;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 9999;
  display: flex;
  justify-content: center;
  align-items: center;
  box-sizing: border-box;
}

.modal-card {
  width: 580rpx;
  background: #2D6F9E; /* Solid steel blue background matching the mockup */
  border-radius: 40rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 12rpx 36rpx rgba(0, 0, 0, 0.25);
  box-sizing: border-box;
}

.modal-icon {
  font-size: 140rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1;
  margin-bottom: 30rpx;
}

.modal-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
  text-align: center;
  line-height: 1.4;
  margin-bottom: 50rpx;
  white-space: pre-line;
}

.modal-buttons-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  width: 100%;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.btn-oui {
  background: #FFFFFF;
}

.btn-non {
  background: rgba(255, 255, 255, 0.25); /* Lighter blue/transparent style */
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.modal-btn:active {
  opacity: 0.85;
}

.modal-btn-txt {
  font-size: 28rpx;
  font-weight: bold;
  letter-spacing: 1rpx;
}

.btn-oui-txt {
  color: #2D6F9E;
}

.btn-non-txt {
  color: #FFFFFF;
}

/* ========== Custom Success Modal (Modal 3) Styles ========== */
.success-card {
  width: 580rpx;
  background: rgba(62, 62, 62, 0.95); /* Sleek semi-transparent dark charcoal grey */
  border-radius: 40rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 12rpx 36rpx rgba(0, 0, 0, 0.3);
  box-sizing: border-box;
}

.success-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #FFFFFF;
  text-align: center;
  line-height: 1.4;
  margin-bottom: 30rpx;
  white-space: pre-line;
}

.success-subtitle {
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
  opacity: 0.9;
  text-align: center;
  line-height: 1.4;
  margin-bottom: 50rpx;
  white-space: pre-line;
}

.success-close-btn {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  border: 4rpx solid #FFFFFF;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.success-close-btn:active {
  opacity: 0.7;
}

.success-close-txt {
  color: #FFFFFF;
  font-size: 44rpx;
  font-weight: bold;
  line-height: 1;
}
