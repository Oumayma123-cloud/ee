/* Même coque que medecin-paiement-detail (750rpx, hero, bandes, vert jusqu’à la barre) */

page {
  background: #ffffff;
}

.page {
  min-height: 100vh;
  background: #ffffff;
  padding: 16rpx 0 calc(20rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.mobile-card {
  width: 750rpx;
  margin: 0 auto;
  border-radius: 57.6923076923rpx;
  overflow: hidden;
  background: #ffffff;
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.content-scroll {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
  background: transparent;
  display: flex;
  flex-direction: column;
}

/* New Header Styles from Photo */
.horaire-header-wrap {
  flex-shrink: 0;
  background: #ffffff;
  min-height: 120rpx;
  height: auto;
  padding-top: 10rpx;
  padding-bottom: 8rpx;
  box-sizing: border-box;
  position: sticky;
  top: 0;
  z-index: 100;
}

.status-row {
  display: flex;
  align-items: center;
  padding: 0 34rpx 0rpx;
  box-sizing: border-box;
  min-height: 0;
  height: auto;
}

.top-bar--horaire {
  position: relative;
  width: 100%;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx 0 20rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.back-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.back-circle {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #f2f2f2;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #333;
  font-size: 24rpx;
  font-weight: bold;
}

.back-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #000000;
}

.logo {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 60rpx;
}

.avatar-bubble {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  position: relative;
  z-index: 10;
}

.avatar-wrap {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: transparent;
}

.avatar-wrap--bubble {
  border: none;
  box-shadow: none;
  overflow: hidden;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}


.payment-hero {
  position: relative;
  height: 421.1538461538rpx;
  background: #b8dacc;
}

.payment-hero-frame {
  width: 750rpx;
  margin: 36.5384615385rpx 0 0;
  border-radius: 0;
  border: 0;
  box-sizing: border-box;
  overflow: hidden;
  background: transparent;
  flex-shrink: 0;
}

.hero-strip-top {
  position: relative;
  width: 100%;
  height: 24.375rpx;
  box-sizing: border-box;
  background-color: #cee6d5;
  border-left: 2rpx solid #000000;
  border-right: 2rpx solid #000000;
  border-top: 1rpx solid #ffffff;
}

.hero-strip-top-caret {
  position: absolute;
  right: 11%;
  top: 0;
  width: 0;
  height: 0;
  border-left: 7rpx solid transparent;
  border-right: 7rpx solid transparent;
  border-top: 9rpx solid #ffffff;
}

.hero-img {
  width: 100%;
  height: 100%;
  display: block;
}

.hero-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 0 26rpx 16rpx;
  box-sizing: border-box;
  background: transparent;
}

.hero-title {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 0.5rpx;
  margin-bottom: 14rpx;
}

.hero-cta {
  height: 44rpx;
  width: 108rpx;
  border-radius: 22rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-cta-text {
  color: #000000;
  font-size: 18rpx;
  font-weight: 700;
}

.hero-strip {
  position: relative;
  width: 100%;
  height: 24.375rpx;
  flex-shrink: 0;
  box-sizing: border-box;
  background-color: #cee6d5;
  border-left: 2rpx solid #000000;
  border-right: 2rpx solid #000000;
  border-top: 1rpx solid #ffffff;
}

.hero-strip-caret {
  position: absolute;
  right: 11%;
  top: 0;
  width: 0;
  height: 0;
  border-left: 7rpx solid transparent;
  border-right: 7rpx solid transparent;
  border-top: 9rpx solid #ffffff;
}

.mint-from-hero {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
  background: #cee6d5;
}

.detail-mint {
  background: #cee6d5;
  padding: 0 0 24rpx;
  box-sizing: border-box;
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.detail-mint-spacer {
  flex: 1;
  min-height: 120rpx;
  width: 100%;
}

/*
 * Carte « paiement effectué » — Figma (390 px de large) :
 * width 309, height 256, left 38, top 368, radius 11, opacity 1, background #F3F9F5
 * → rpx : px × (750 / 390)
 */
.statut-card {
  width: 594.2307692308rpx;
  height: 420rpx;
  margin-left: 73.0769230769rpx;
  margin-right: auto;
  /* Figma top: 368 px — position absolue dans le frame ; ici décalage sous le hero */
  margin-top: 36rpx;
  background: #f3f9f5;
  border-radius: 21.1538461538rpx;
  padding: 38.4615384615rpx;
  box-sizing: border-box;
  opacity: 1;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.05);
  flex-shrink: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.statut-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.statut-card-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: #1c1b1f;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  text-transform: lowercase;
  line-height: 1.25;
}

.statut-check-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #9e9e9e;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.statut-check {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1;
  margin-top: 2rpx;
}

.statut-body {
  display: block;
}

/*
 * Bloc texte Figma : 252×58 px, left 67 px (écran), top 453 px — rpx × (750/390)
 * 67 − 38 (carte) − 20 (padding) ≈ 9 px → marge intérieure gauche
 */
.statut-body-inner {
  width: 484.6153846154rpx;
  min-height: 111.5384615385rpx;
  margin-left: 17.3076923077rpx;
  box-sizing: border-box;
  opacity: 1;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.statut-txt {
  color: #1c1b1f;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

/* 14 px Regular, line-height 20 px */
.statut-txt--14 {
  font-size: 26.9230769231rpx;
  font-weight: 400;
  line-height: 38.4615384615rpx;
  letter-spacing: 0;
}

/* 20 px Medium, line-height 20 px */
.statut-txt--20 {
  font-size: 38.4615384615rpx;
  font-weight: 500;
  line-height: 38.4615384615rpx;
  letter-spacing: 0;
}

.statut-actions {
  width: 594.2307692308rpx;
  margin: 28rpx auto 0 73.0769230769rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  box-sizing: border-box;
  flex-shrink: 0;
}

.statut-btn {
  min-height: 88rpx;
  padding: 24rpx 20rpx;
  border-radius: 999rpx;
  background: #70B682;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
  line-height: 1.3;
  box-sizing: border-box;
  box-shadow: 0 6rpx 18rpx rgba(112, 182, 130, 0.28);
}

.statut-btn--hover {
  opacity: 0.9;
}

.bottom-nav.bottom-nav--in-card {
  width: 100%;
  max-width: none;
  margin: 0;
  border-radius: 0 0 57.6923076923rpx 57.6923076923rpx;
  align-self: stretch;
  border-top: none;
  box-shadow: none;
}

.bottom-nav.bottom-nav--light.bottom-nav--in-card {
  background: #f5f5f5;
}
/* --- Modale Tasshilat (alignée maquette : #2C2C2E, X à cheval sur le bas) --- */
.agency-modal-root {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 56rpx 40rpx 80rpx;
  box-sizing: border-box;
  pointer-events: auto;
}

.agency-modal-mask {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.65); /* Darker for better focus */
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.agency-modal-panel {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 580rpx;
  background: #1c1c1e; /* Deeper dark background */
  border-radius: 60rpx;
  padding: 80rpx 48rpx 100rpx;
  box-sizing: border-box;
  overflow: visible;
  box-shadow: 0 40rpx 100rpx rgba(0, 0, 0, 0.8);
}

.agency-modal-text-wrap {
  width: 100%;
  padding: 0 4rpx;
  box-sizing: border-box;
}

.agency-modal-para {
  display: block;
  width: 100%;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1.65;
  text-align: center;
  font-weight: 400;
  letter-spacing: 0;
}

.agency-modal-code {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.agency-modal-close {
  position: absolute;
  left: 50%;
  bottom: -48rpx; /* Lower position */
  width: 96rpx;
  height: 96rpx;
  transform: translateX(-50%);
  border-radius: 50%;
  background: #d1d1d6; /* Matching the light grey in screenshot */
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 25rpx rgba(0, 0, 0, 0.4);
}

.agency-modal-close--active {
  opacity: 0.88;
}

.agency-modal-x {
  color: #000000;
  font-size: 48rpx;
  font-weight: 300;
  line-height: 1;
  margin-top: -8rpx;
}
