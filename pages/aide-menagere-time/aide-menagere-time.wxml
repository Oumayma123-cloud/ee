<!-- ========== Page Sélection Horaire Aide Ménagère ========== -->
<view class="container">
  <scroll-view class="scroll-content" scroll-y="true" show-scrollbar="false">
    <view class="scroll-inner">

      <!-- 1. Header -->
      <view class="header-section" style="padding-top: {{statusBarHeight + 10}}px;">
        <view class="header-content">
          <view class="back-btn" bindtap="onBack">
            <view class="back-circle">
              <text class="back-arrow-txt">←</text>
            </view>
            <text class="back-label">Retour</text>
          </view>
          <image src="/assets/logtiqqa.png" class="logo" mode="aspectFit"></image>
          <view class="avatar-container">
            <view class="avatar-bubble">
              <image src="/assets/assets/avatar/Group 1000000900.png" class="avatar-img" mode="aspectFit"></image>
            </view>
          </view>
        </view>
      </view>

      <!-- 2. Hero Section -->
      <view class="hero-section">
        <view class="hero-left">
          <view class="hero-bubble">
            <text class="hero-bubble-text">{{bubbleText}}</text>
          </view>
        </view>
        <view class="hero-right">
          <image class="hero-woman" src="/assets/aide-menagere-woman-transparent-v2.png" mode="aspectFit"></image>
        </view>
      </view>

      <!-- 3. Time Selection Section -->
      <view class="time-selection-section">
        <view class="time-section-content">
          <!-- Timeline Vertical Column -->
          <view class="timeline-column">
            <view class="timeline-line"></view>
            <view class="timeline-dot" style="top: {{timelineDotTop}}rpx;"></view>
          </view>

          <!-- Times List Column -->
          <view class="time-list">
            <block wx:for="{{timeSlots}}" wx:key="index">
              <view
                class="time-item {{selectedIndex === index ? 'time-item--selected' : ''}}"
                bindtap="onTimeTap"
                data-index="{{index}}"
              >
                <text class="time-text">{{item.start}}</text>
                <text class="time-separator">-</text>
                <text class="time-text">{{item.end}}</text>
              </view>
            </block>
          </view>
        </view>
      </view>

      <!-- 4. SUIVANT Button -->
      <view class="btn-suivant-wrap">
        <view class="btn-suivant" bindtap="onSuivant">
          <text class="btn-suivant-txt">SUIVANT</text>
        </view>
      </view>

      <view class="bottom-spacer"></view>
    </view>
  </scroll-view>

  <bottom-nav-bar message-count="6" bind:navtap="onNavTap" />
</view>
