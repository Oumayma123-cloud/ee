/* ========== Container ========== */
page {
  background: #FFFFFF;
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
}

.scroll-content {
  flex: 1;
  overflow: hidden;
}

.scroll-inner {
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
}

/* ========== Header ========== */
.header-section {
  background: #FFFFFF;
  padding-bottom: 0;
  position: relative;
  z-index: 10;
}

.header-content {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 28rpx 14rpx;
}

.back-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
}

.back-circle {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: #F0F0F0;
  display: flex;
  justify-content: center;
  align-items: center;
}

.back-arrow-txt {
  font-size: 26rpx;
  color: #333;
  font-weight: normal;
  line-height: 1;
}

.back-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}

.logo {
  width: 140rpx;
  height: 56rpx;
}

/* Bubble avatar */
.avatar-container {
  position: relative;
}

.avatar-bubble {
  position: relative;
  width: 100rpx;
  height: 110rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-img {
  width: 100rpx;
  height: 110rpx;
  display: block;
}

/* ========== Hero Section ========== */
.hero-section {
  background: #A9D3EC;
  height: 300rpx;
  display: flex;
  flex-direction: row;
  align-items: stretch;
  padding-left: 28rpx;
  padding-right: 0;
  position: relative;
  overflow: visible;
  z-index: 2;
}

.hero-left {
  flex: 1;
  display: flex;
  align-items: center;
  padding-right: 12rpx;
}

.hero-bubble {
  background: #FAF0ED;
  border-radius: 20rpx;
  padding: 16rpx 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
  width: 320rpx;
}

.hero-bubble-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #1A1A1A;
  line-height: 1.3;
}

.hero-right {
  width: 330rpx;
  height: 300rpx;
  flex-shrink: 0;
  align-self: flex-end;
  margin-top: 0;
  z-index: 5;
  overflow: visible;
}

.hero-woman {
  width: 330rpx;
  height: 300rpx;
  display: block;
}

/* ========== Time Selection Section ========== */
.time-selection-section {
  background: #5391C0;
  padding: 40rpx 32rpx;
  position: relative;
  z-index: 3;
}

.time-section-content {
  display: flex;
  flex-direction: row;
}

/* Timeline Column on the left */
.timeline-column {
  width: 40rpx;
  position: relative;
  margin-right: 18rpx;
}

.timeline-line {
  position: absolute;
  left: 18rpx;
  top: 24rpx;
  bottom: 24rpx;
  width: 3rpx;
  background: rgba(255, 255, 255, 0.4);
}

.timeline-dot {
  position: absolute;
  left: 12rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
  background: #FFFFFF;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
  transition: top 0.25s ease-in-out;
}

/* Time List on the right */
.time-list {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.time-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  background: #E5F0F7;
  border-radius: 20rpx;
  height: 80rpx;
  padding: 0 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.time-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #000000;
  width: 120rpx;
  text-align: center;
}

.time-separator {
  font-size: 28rpx;
  font-weight: 700;
  color: #000000;
  margin: 0 40rpx;
}

/* Selected active slot style */
.time-item--selected {
  background: #3E7AA4;
}

.time-item--selected .time-text,
.time-item--selected .time-separator {
  color: #FFFFFF;
}

/* ========== SUIVANT Button ========== */
.btn-suivant-wrap {
  background: #FFFFFF;
  padding: 36rpx 60rpx 40rpx;
  display: flex;
  justify-content: center;
}

.btn-suivant {
  background: #5FA1CD; /* Lighter steel blue as shown in Image */
  border-radius: 60rpx;
  height: 90rpx;
  width: 480rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(95, 161, 205, 0.25);
}

.btn-suivant:active {
  opacity: 0.85;
}

.btn-suivant-txt {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

/* ========== Bottom Spacer ========== */
.bottom-spacer {
  height: 160rpx;
  background: #FFFFFF;
}
