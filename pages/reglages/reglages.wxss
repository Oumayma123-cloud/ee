/* Styles for Reglages page */
.container {
  min-height: 100vh;
  background: #1a1a1a;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.mobile-card {
  width: 750rpx;
  margin: 0 auto;
  border-radius: 57.69rpx;
  overflow: hidden;
  background: #ffffff;
  flex: 1;
  display: flex;
  flex-direction: column;
  position: relative;
  padding-top: 8rpx;
}

.content-scroll {
  flex: 1;
  overflow-y: auto;
  background: #ffffff;
}

/* Header Styles */
.horaire-header-wrap {
  flex-shrink: 0;
  background: #ffffff;
  min-height: 120rpx;
  height: auto;
  padding-top: 10rpx;
  padding-bottom: 8rpx;
  box-sizing: border-box;
}

.status-row {
  display: flex;
  align-items: center;
  padding: 0 34rpx 0rpx;
  box-sizing: border-box;
  min-height: 0;
  height: auto;
}

.top-bar--horaire {
  position: relative;
  width: 100%;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx 0 20rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.back-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.back-circle {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #fcfcfc;
  border: 1px solid #eeeeee;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #333;
  font-size: 24rpx;
}

.back-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #000000;
}

.logo {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 60rpx;
}

.avatar-bubble {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  position: relative;
  z-index: 10;
}

.avatar-wrap {
  width: 150rpx;
  height: 150rpx;
  background: transparent;
}

.avatar {
  width: 100%;
  height: 100%;
}

/* Hero Section */
.hero-section {
  width: 100%;
  display: flex;
  flex-direction: column;
}

.hero-image-wrap {
  position: relative;
  width: 100%;
  height: 380rpx;
}

.hero-img {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 40rpx;
  box-sizing: border-box;
}

.hero-title {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.hero-btn {
  width: 220rpx;
  height: 60rpx;
  background: #ffffff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-btn-text {
  color: #000000;
  font-size: 24rpx;
  font-weight: 800;
}

.hero-nav-bar {
  width: 100%;
  height: 60rpx;
  background: #aab8c6;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.nav-arrow {
  width: 44rpx;
  height: 44rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #666;
  font-size: 24rpx;
  font-weight: bold;
}

/* Title Section */
.section-title-wrap {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 15rpx;
  margin-top: 40rpx;
  margin-bottom: 30rpx;
}

.title-script {
  font-family: cursive, 'Brush Script MT', serif;
  font-size: 50rpx;
  color: #333333;
}

.title-bold {
  font-size: 38rpx;
  font-weight: 800;
  color: #9cb0c4;
  letter-spacing: 2rpx;
}

/* Grid Section */
.settings-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 0 50rpx;
}

.grid-card {
  background: #D6D6CA;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
  height: 320rpx;
}

.grid-card:nth-child(2) {
  background: #D5E0DC;
}

.grid-card:nth-child(3) {
  background: #e8f1ec;
  grid-column: 1 / 2;
}

.card-img {
  width: 100%;
  height: 200rpx;
}

.card-label-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 10rpx;
}

.card-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #7b7167;
  text-align: center;
}

.bottom-spacer {
  height: 120rpx;
}
