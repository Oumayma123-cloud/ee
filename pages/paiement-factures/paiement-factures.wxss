/* ========== Page Paiement Factures ========== */
page {
  background: #ffffff;
}

.container {
  width: 100%;
  min-height: 100vh;
  background: #ffffff;
  position: relative;
}

.scroll-content {
  width: 100%;
  height: 100vh;
  padding-bottom: 130rpx;
  box-sizing: border-box;
}

.scroll-inner {
  width: 100%;
}

/* ========== 1. Header (White) ========== */
.header-section {
  background: #ffffff;
  width: 100%;
}

.header-content {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 32rpx 12rpx;
}

.back-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.back-circle {
  width: 54rpx;
  height: 54rpx;
  border-radius: 27rpx;
  background: #EEEEEE;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.1);
}

.chevron-left-black {
  width: 14rpx;
  height: 14rpx;
  border-left: 4.5rpx solid #333;
  border-bottom: 4.5rpx solid #333;
  transform: rotate(45deg);
  margin-left: 6rpx;
}

.back-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #333;
}

.logo {
  width: 150rpx;
  height: 60rpx;
}

/* Avatar avec queue de bulle */
.avatar-container {
  position: relative;
}

.avatar-bubble {
  position: relative;
  width: 100rpx;
  height: 110rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-img {
  width: 100rpx;
  height: 110rpx;
  display: block;
}

.avatar-tail {
  display: none;
}

/* ========== 2. Top Strip ========== */
.top-strip {
  background-color: #D4EBF8;
  height: 20rpx;
  width: 100%;
}

/* ========== 3. Full-bleed Hero Zone ========== */
.hero-section {
  background-color: #3B82B5;
  padding: 0;
  width: 100%;
}

.hero-banner-container {
  position: relative;
  width: 100%;
  height: 380rpx;
  background: #fff;
}

.hero-bg {
  width: 100%;
  height: 100%;
  display: block;
}

.hero-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 140rpx;
  padding: 0 44rpx 32rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.55) 0%, transparent 100%);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: flex-start;
}

.hero-nav-bar {
  background-color: #3B82B5;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 44rpx;
}

.hero-nav-btn {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
}

.hero-nav-btn:active {
  opacity: 0.8;
  transform: scale(0.9);
}

.chevron-left-blue {
  width: 12rpx;
  height: 12rpx;
  border-left: 4rpx solid #3B82B5;
  border-bottom: 4rpx solid #3B82B5;
  transform: rotate(45deg);
  margin-left: 4rpx;
}

.chevron-right-blue {
  width: 12rpx;
  height: 12rpx;
  border-right: 4rpx solid #3B82B5;
  border-top: 4rpx solid #3B82B5;
  transform: rotate(45deg);
  margin-right: 4rpx;
}

.hero-title {
  color: #fff;
  font-size: 26rpx;
  font-weight: 800;
  letter-spacing: 1.5rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
}

/* ========== 4. Spacer Zone (Light Blue) ========== */
.date-zone {
  background-color: #D4EBF8;
  height: 50rpx;
}

/* ========== 5. Paiement Factures Section ========== */
.services-section {
  background: #ffffff;
  padding-top: 10rpx;
}

.section-title-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  justify-content: center;
  margin: 32rpx 0 28rpx;
}

.section-title-script {
  font-size: 42rpx;
  font-weight: 400;
  color: #333;
  font-style: italic;
  font-family: 'Times New Roman', serif;
}

.section-title-bold {
  font-size: 28rpx;
  font-weight: 800;
  color: #1E5A88;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin-left: 6rpx;
  text-decoration: underline;
  text-underline-offset: 6rpx;
  text-decoration-color: #1E5A88;
}

/* ========== Grid Container ========== */
.grid-container {
  display: flex;
  flex-direction: row;
  padding: 0 48rpx;
  align-items: flex-start;
}

.services-grid {
  flex: 1;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

/* ========== Paiement Factures Card ========== */
.pf-card {
  background: #ffffff;
  border-radius: 24rpx;
  height: 260rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 16rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(0, 0, 0, 0.03);
}

.pf-card-icon-wrap {
  margin-bottom: 0rpx;
}

.pf-icon-circle {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: #8CC5E3;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(30, 90, 136, 0.2);
}

.pf-icon-img {
  width: 58rpx;
  height: 58rpx;
}

.pf-card-label {
  color: #1E5A88;
  font-size: 18rpx;
  font-weight: 700;
  text-align: center;
  letter-spacing: 0.5rpx;
  line-height: 1.3;
  text-transform: uppercase;
  white-space: pre-line;
}

/* ========== Scroll Indicator ========== */
.scroll-indicator {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-left: 24rpx;
  padding-top: 80rpx;
  flex-shrink: 0;
}

.scroll-arrow {
  width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  background: #F0F0F0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.05);
}

.chevron-up-gray {
  width: 10rpx;
  height: 10rpx;
  border-left: 3rpx solid #888;
  border-top: 3rpx solid #888;
  transform: rotate(45deg);
  margin-top: 4rpx;
}

.chevron-down-gray {
  width: 10rpx;
  height: 10rpx;
  border-left: 3rpx solid #888;
  border-bottom: 3rpx solid #888;
  transform: rotate(45deg);
  margin-top: -4rpx;
}

.scroll-track {
  width: 12rpx;
  height: 600rpx;
  background: #F5F5F5;
  border-radius: 6rpx;
  position: relative;
  box-shadow: inset 0 1rpx 3rpx rgba(0,0,0,0.05);
  border: 1rpx solid #E5E5E5;
}

.scroll-thumb {
  position: absolute;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #1E5A88;
  border-radius: 50rpx;
  top: 0;
}

/* ========== Bottom Spacer ========== */
.bottom-spacer {
  height: 0;
}

/* ========== Image 2 Overlay Modal ========== */
.image2-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99999;
}

.image2-modal {
  position: relative;
  width: 80%;
  background: #ffffff;
  border-radius: 36rpx;
  padding: 50rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 30rpx 70rpx rgba(0, 0, 0, 0.35);
  animation: modalScaleIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes modalScaleIn {
  from {
    transform: scale(0.85);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.image2 {
  width: 100%;
  height: 480rpx;
  border-radius: 20rpx;
}

.close-btn {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #f0f2f5;
  color: #666;
  font-size: 38rpx;
  line-height: 52rpx;
  text-align: center;
  font-weight: bold;
  transition: all 0.2s ease;
}

.close-btn:active {
  background: #e1e4e8;
  transform: scale(0.9);
}
