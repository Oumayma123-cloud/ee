<!-- ========== Page Détail Paiement Tashilat/Chaabi ========== -->
<view class="container">
  <scroll-view class="scroll-content" scroll-y="true" show-scrollbar="false">
    <view class="scroll-inner">

      <!-- 1. Header -->
      <view class="header-section" style="padding-top: {{statusBarHeight + 10}}px;">
        <view class="header-content">
          <view class="back-btn" bindtap="onBack">
            <view class="back-circle">
              <text class="back-arrow-txt">←</text>
            </view>
            <text class="back-label">Retour</text>
          </view>
          <image src="/assets/logtiqqa.png" class="logo" mode="aspectFit"></image>
          <view class="avatar-container">
            <view class="avatar-bubble">
              <image src="/assets/avatar/avatar-user.png" class="avatar-img" mode="aspectFit"></image>
            </view>
          </view>
        </view>
      </view>

      <!-- 2. Hero Section Banner (Tashilat Storefront) -->
      <view class="hero-section">
        <view class="banner-container">
          <!-- Mockup Browser Header Bar -->
          <view class="browser-header">
            <view class="dot-container">
              <view class="slide-dot"></view>
              <view class="slide-dot"></view>
              <view class="slide-dot slide-dot--active"></view>
              <view class="slide-dot"></view>
            </view>
          </view>

          <!-- Storefront image background -->
          <image class="banner-img" src="/assets/tashilat_agency_store.jpg" mode="aspectFill"></image>

          <!-- Navigation Arrow Circles on the sides -->
          <view class="nav-arrow nav-arrow-left">
            <text class="arrow-char">←</text>
          </view>
          <view class="nav-arrow nav-arrow-right">
            <text class="arrow-char">→</text>
          </view>

          <!-- Text Overlay and Button -->
          <view class="banner-text-overlay">
            <text class="banner-overlay-title">TROUVEZ FACILEMENT LES AGENCES</text>
            <text class="banner-overlay-title">TASSHILAT PRÈS DE CHEZ VOUS</text>
            <view class="banner-overlay-btn" bindtap="onFindAgency">
              <text class="banner-overlay-btn-txt">TROUVER UNE AGENCE</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 3. Form Section -->
      <view class="form-section">
        <!-- Title 1: Le mode de paiement -->
        <view class="section-title-wrap">
          <text class="section-title">Le mode de paiement</text>
          <view class="title-underline"></view>
        </view>

        <!-- Payment Type Selector Preview (Logo left, Text right) -->
        <view class="card-type-box">
          <image class="card-type-logo-left" src="{{paymentLogo}}" mode="aspectFit"></image>
          <text class="card-type-label-right">{{paymentName}}</text>
        </view>

        <!-- Description text right below the card type box -->
        <view class="payment-desc-row">
          <text class="payment-desc-txt">{{paymentDesc}}</text>
        </view>

        <!-- Title 2: Détail de paiement -->
        <view class="section-title-wrap no-underline-margin">
          <text class="section-title">Détail de paiement</text>
        </view>

        <!-- Read-only details list (No input borders, matching credit card style) -->
        <view class="details-list">
          <view class="detail-row">
            <text class="detail-label">Code de paiement :</text>
            <text class="detail-value">{{paymentCode}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">Le montant à payer est :</text>
            <text class="detail-value">{{amountVal}} Dhs</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">Mode de paiement :</text>
            <text class="detail-value">{{paymentMode}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">Temps restant pour le paiement :</text>
            <text class="detail-value">{{paymentTime}}</text>
          </view>
        </view>

        <!-- Confirm Button -->
        <view class="confirm-btn-wrap">
          <view class="submit-btn" bindtap="onProceedPayment">
            <text class="submit-btn-txt">PROCÉDER AU PAIEMENT</text>
          </view>
        </view>
      </view>

      <view class="bottom-spacer"></view>
    </view>
  </scroll-view>

  <!-- Custom Modal Popup (Image 2 Success modal style) -->
  <view class="modal-overlay" wx:if="{{showSuccessModal}}">
    <view class="modal-card">
      <text class="modal-text">Rendez-vous dans l'agence Tasshilate la plus proche avec votre code de paiement pour finaliser la réservation. Veuillez vous y présenter muni(e) de ce code {{paymentCode}}</text>
      <view class="modal-close-btn" bindtap="onCloseModal">
        <text class="modal-close-icon">×</text>
      </view>
    </view>
  </view>

  <bottom-nav-bar variant="fixed" message-count="0" bind:navtap="onNavTap" />
</view>
