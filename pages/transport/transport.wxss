/* Force compile update */
/* ========== Container ========== */
.transport-container {
  min-height: 100vh;
  background: #ffffff;
  color: #333333;
  display: flex;
  flex-direction: column;
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F8FAFC;
  color: #333333;
}

.scroll-content {
  flex: 1;
  overflow: hidden;
}

.scroll-inner {
  display: flex;
  flex-direction: column;
}

/* ========== Header ========== */
.header-section {
  background: #ffffff;
  padding-bottom: 20rpx;
  z-index: 10;
}

.header-content {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 36rpx;
}

.back-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.back-circle {
  width: 54rpx;
  height: 54rpx;
  border-radius: 27rpx;
  background: #EEEEEE;
  display: flex;
  justify-content: center;
  align-items: center;
}

.chevron-left-black {
  width: 14rpx;
  height: 14rpx;
  border-left: 4.5rpx solid #333;
  border-bottom: 4.5rpx solid #333;
  transform: rotate(45deg);
  margin-left: 6rpx;
}

.back-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #333;
}

.logo {
  width: 150rpx;
  height: 60rpx;
}

.avatar-container {
  position: relative;
}

.avatar-bubble {
  position: relative;
  width: 100rpx;
  height: 110rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-img {
  width: 100rpx;
  height: 110rpx;
  display: block;
}

/* ========== Blue Banner ========== */
.blue-banner {
  background-color: #3B82B5;
  display: flex;
  flex-direction: row;
  align-items: baseline;
  justify-content: center;
  padding: 28rpx 40rpx;
  border-top: 16rpx solid #D4EBF8;
}

.banner-script {
  font-size: 44rpx;
  font-weight: 400;
  color: #ffffff;
  font-style: italic;
  font-family: 'Times New Roman', serif;
}

.banner-bold {
  font-size: 32rpx;
  font-weight: 900;
  color: #ffffff;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin-left: 6rpx;
}

/* ========== Category Pill ========== */
.category-pill-row {
  display: flex;
  flex-direction: row;
  justify-content: center;
  padding: 24rpx 40rpx 20rpx;
}

.category-pill {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: #E5F1FB;
  border-radius: 40rpx;
  padding: 14rpx 0;
  width: 100%;
}

.pill-icon {
  width: 36rpx;
  height: 36rpx;
}

.pill-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #1E5A88;
  letter-spacing: 0.5rpx;
}

/* ========== Operators List ========== */
.operators-list {
  padding: 24rpx 36rpx 24rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  border-left: 10rpx solid #1E68B8;
  margin-left: 24rpx;
}

.operator-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
  padding: 24rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  border: 1.5rpx solid rgba(0, 0, 0, 0.02);
}

.card-bracket {
  width: 24rpx;
  height: 120rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
}

/* Operator logo square */
.operator-logo-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 14rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 20rpx;
  border: 1.5rpx solid #EEEEEE;
}

.operator-logo {
  width: 82rpx;
  height: 82rpx;
}

.operator-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.operator-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #1E2A3A;
  letter-spacing: 0.3rpx;
}

.operator-subtitle {
  font-size: 22rpx;
  color: #888;
  font-weight: 400;
}

.chevron-down-bold {
  width: 14rpx;
  height: 14rpx;
  border-right: 4rpx solid #1E2A3A;
  border-bottom: 4rpx solid #1E2A3A;
  transform: rotate(45deg);
  margin-right: 12rpx;
  flex-shrink: 0;
}

.operator-card:active {
  opacity: 0.95;
  background: #FAFBFF;
}

/* ========== Bottom Spacer ========== */
.bottom-spacer {
  height: 0;
}
