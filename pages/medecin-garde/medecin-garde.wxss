/* ==============================
   CONTAINER
============================== */
.container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #FFFFFF;
  position: relative;
  overflow: hidden;
}

.scroll-content {
  flex: 1;
  height: 100%;
  overflow-y: auto;
}


/* ==============================
   HEADER
============================== */
.header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  background-color: #FFFFFF;
  padding: 20rpx 30rpx 20rpx 30rpx;
  height: 110rpx;
  overflow: visible; /* Pour que l'avatar déborde vers le bas */
  position: relative;
  z-index: 20;
}

/* Bouton Retour */
.back-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.back-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: #EBEBEB;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
}

.back-arrow-txt {
  font-size: 28rpx;
  color: #444444;
  line-height: 1;
}

.back-label {
  font-size: 28rpx;
  color: #444444;
  font-weight: 400;
}

/* Logo tiqqa */
.logo {
  width: 200rpx;
  height: 70rpx;
}

/* Avatar (déborde sous le header) */
.avatar-outer {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  /* Le avatar dépasse en bas du header */
  margin-top: 30rpx;
}

.avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.15);
}

/* Bulle blanche sous l'avatar (pointe vers le bas-gauche) */
.bubble-tail {
  position: absolute;
  bottom: -18rpx;
  left: 20rpx;
  width: 0;
  height: 0;
  border-left: 18rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 22rpx solid #FFFFFF;
  filter: drop-shadow(0 2rpx 2rpx rgba(0,0,0,0.08));
}

/* ==============================
   BANDE VERTE SEPARATRICE
============================== */
.green-strip {
  width: 100%;
  height: 26rpx;
  background-color: #C8E6C9;
  /* Légèrement derrière l'avatar qui déborde */
  z-index: 10;
}

/* Hero Banner */
.banner-section {
  position: relative;
  width: 100%;
  height: 420rpx;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  bottom: 30rpx;
  left: 30rpx;
  right: 30rpx;
  width: auto;
}

.banner-title {
  display: block;
  color: #FFFFFF;
  font-family: 'Neue Montreal', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-size: 13px;
  font-weight: 700;
  font-style: normal;
  line-height: 100%;
  letter-spacing: 1px;
  text-transform: uppercase;
  margin-bottom: 16rpx;
  text-shadow: 0 1px 4px rgba(0,0,0,0.35);
}

.btn-acceder {
  display: inline-block;
  background-color: #FFFFFF;
  padding: 8px 24px;
  border-radius: 6px;
}

.btn-acceder-txt {
  font-family: 'Neue Montreal', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-size: 11px;
  font-weight: 700;
  color: #333333;
  text-transform: uppercase;
  letter-spacing: 1px;
}

/* ==============================
   BANDE VERTE NAVIGATION (fleches)
============================== */
.nav-strip {
  width: 100%;
  height: 80rpx;
  background-color: #C8E6C9;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 50rpx;
  box-sizing: border-box;
}

.nav-arrow-circle {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background-color: #EBEBEB;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-arrow-txt {
  font-size: 26rpx;
  color: #888888;
}

/* ==============================
   MAIN CONTENT (medecin + bouton)
============================== */
.main-content {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
  padding-bottom: 20rpx;
  background-color: #FFFFFF;
}

.doctor-display {
  width: 138px;
  height: 185px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.doctor-hero-img {
  width: 138px;
  height: 185px;
}

.action-area {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-top: 40rpx;
}

.btn-demande {
  background-color: #4CAF7D;
  border-radius: 60rpx;
  padding: 22rpx 50rpx;
}

.btn-demande-txt {
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
}

/* Espace pour éviter que le contenu soit caché par la bottom nav */
.bottom-spacer {
  height: 0;
}

