.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #ffffff;
  overflow: hidden;
}

/* Header Section */
/* New Header Styles from Photo */
.horaire-header-wrap {
  flex-shrink: 0;
  background: #ffffff;
  min-height: 120rpx;
  height: auto;
  padding-top: 10rpx;
  padding-bottom: 8rpx;
  box-sizing: border-box;
  position: sticky;
  top: 0;
  z-index: 100;
}

.status-row {
  display: flex;
  align-items: center;
  padding: 0 34rpx 0rpx;
  box-sizing: border-box;
  min-height: 0;
  height: auto;
}

.top-bar--horaire {
  position: relative;
  width: 100%;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx 0 20rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.back-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.back-circle {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #f2f2f2;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #333;
  font-size: 24rpx;
  font-weight: bold;
}

.back-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #000000;
}

.logo {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 60rpx;
}

.avatar-bubble {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  position: relative;
  z-index: 10;
}

.avatar-wrap {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: transparent;
}

.avatar-wrap--bubble {
  border: none;
  box-shadow: none;
  overflow: hidden;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}


/* Content Card */
.content-card {
  flex: 1;
  background-color: #ffffff;
  position: relative;
  overflow: hidden;
  padding: 0 !important;
  border-radius: 0 !important;
}

.card-scroll {
  height: 100%;
  width: 100%;
}

.hero-section {
  display: flex;
  background-color: #BCE3C9; /* Light green */
  padding: 24rpx 40rpx 0;
  position: relative;
  overflow: hidden;
  align-items: center;
}

.hero-text-wrap {
  flex: 1;
  padding-right: 20rpx;
  padding-bottom: 24rpx;
}

.page-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #000000;
  line-height: 1.4;
}

.hero-image-wrap {
  width: 260rpx;
  display: flex;
  align-items: flex-end;
}

.hero-image {
  width: 100%;
  height: 320rpx;
  display: block;
}

/* Calendar Widget */
.calendar-section {
  background-color: #77B080; /* Darker green */
  padding: 24rpx 40rpx 24rpx;
}

.calendar-widget {
  background: transparent;
  border: none;
  box-shadow: none;
  padding: 0;
  margin: 0;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.5);
  padding-bottom: 12rpx;
}

.header-left, .header-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.month-nav {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border-radius: 50%;
}

.nav-arrow {
  font-size: 32rpx;
  color: #77B080;
  font-weight: bold;
}

.month-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
  text-transform: uppercase;
}

.year-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
}

.weekdays {
  display: flex;
  margin-bottom: 12rpx;
}

.weekday {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 400;
}

.days-grid {
  display: flex;
  flex-wrap: wrap;
}

.day-cell-wrap {
  width: 14.28%;
  display: flex;
  justify-content: center;
  margin-bottom: 12rpx;
}

.day-cell {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  background: transparent;
  transition: all 0.2s;
}

.day-num {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 400;
}

.day-cell.selected {
  background-color: #497E5B; /* Dark green for selected */
}

.day-cell.selected .day-num {
  color: #ffffff;
  font-weight: bold;
}

.day-cell.disabled {
  opacity: 0.5;
}

.day-empty {
  width: 72rpx;
  height: 72rpx;
}

/* Action Footer */
.action-footer {
  padding: 30rpx 40rpx;
  background-color: #ffffff;
}

.btn-valider {
  width: 100% !important;
  height: 90rpx;
  background-color: #77B080;
  color: #ffffff;
  border-radius: 45rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: none;
}

.bottom-spacer {
  height: 40rpx;
}
