<view class="container">
  <!-- Brand Header -->
  <view class="horaire-header-wrap">
    <view class="status-row">
      <device-status-bar fillStatusBar="{{true}}" edgePadding="{{false}}" />
    </view>
    <view class="top-bar top-bar--horaire">
      <view class="back-wrap" bindtap="onBack">
        <view class="back-circle">←</view>
        <text class="back-text">Retour</text>
      </view>
      <image class="logo" src="/assets/logo/logo-tiqqa.png" mode="aspectFit"></image>
      <view class="avatar-bubble" bindtap="onProfileTap">
        <view class="avatar-wrap avatar-wrap--bubble">
          <image class="avatar" src="/assets/profile.png" mode="aspectFill"></image>
        </view>
        <view class="avatar-bubble-tail"></view>
      </view>
    </view>
  </view>

  <!-- Main Content Card -->
  <view class="content-card">
    <scroll-view class="card-scroll" scroll-y="true">
      
      <view class="hero-section" style="align-items: flex-end; min-height: 280rpx;">
        <view class="hero-image-wrap" style="width: 320rpx; margin-bottom: -10rpx;">
          <image src="/assets/medecin1.png" class="hero-image" mode="widthFix" style="width: 100%; height: auto; display: block;"></image>
        </view>
        <view class="hero-text-wrap" style="padding-left: 20rpx; padding-right: 0; padding-bottom: 50rpx; text-align: left; align-self: center;">
          <text class="page-title" style="font-size: 32rpx;">Choisissez une date pour la visite du médecin chez vous</text>
        </view>
      </view>

      <!-- Calendar Widget -->
      <view class="calendar-section">
        <view class="calendar-widget">
          <view class="calendar-header">
            <view class="header-left">
              <view class="month-nav" bindtap="changeMonth" data-dir="-1">
                <text class="nav-arrow">←</text>
              </view>
              <text class="month-text">{{currentMonthLabel}}</text>
            </view>
            <view class="header-right">
              <text class="year-text">{{currentYear}}</text>
              <view class="month-nav" bindtap="changeMonth" data-dir="1">
                <text class="nav-arrow">→</text>
              </view>
            </view>
          </view>

          <view class="weekdays">
            <text wx:for="{{weeks}}" wx:key="index" class="weekday">{{item}}</text>
          </view>

          <view class="days-grid">
            <block wx:for="{{calendarDays}}" wx:key="index">
              <view class="day-cell-wrap">
                <view wx:if="{{item}}" 
                  class="day-cell {{item === selectedDay ? 'selected' : ''}} {{item < todayDay && isCurrentMonth ? 'disabled' : ''}}" 
                  bindtap="selectDay" 
                  data-day="{{item}}">
                  <text class="day-num">{{item}}</text>
                </view>
                <view wx:else class="day-empty"></view>
              </view>
            </block>
          </view>
        </view>
      </view>

      <view class="action-footer">
        <button class="btn-valider" bindtap="onNext">Suivant</button>
      </view>

      <view class="bottom-spacer"></view>
    </scroll-view>
  </view>

  <!-- Navigation Footer -->
  <bottom-nav-bar active-tab="calendar" variant="fixed" message-count="6" bind:navtap="onNavTap" />
</view>
<!-- trigger recompile -->
