<view class="container">
  <view class="shell">
    <view class="horaire-header-wrap">
      <view class="status-row">
        <device-status-bar fillStatusBar="{{true}}" edgePadding="{{false}}" />
      </view>
      <view class="top-bar top-bar--horaire">
        <view class="back-wrap" bindtap="onBack">
          <view class="back-circle">←</view>
          <text class="back-text">Retour</text>
        </view>
        <image class="logo" src="/assets/logo/logo-tiqqa.png" mode="aspectFit"></image>
        <view class="avatar-bubble" bindtap="onProfileTap">
          <view class="avatar-wrap avatar-wrap--bubble">
            <image class="avatar" src="/assets/profile.png" mode="aspectFill"></image>
          </view>
        </view>
      </view>
    </view>


    <!-- Banner (shared style with carte) -->
    <view class="banner-area">
      <view class="banner-top-bar"></view>
      <view class="banner-section">
        <image src="/assets/banner1.png" class="banner-img" mode="aspectFill"></image>
        <view class="banner-content">
          <text class="banner-title">PRÉSERVEZ VOTRE CAPITAL SANTÉ</text>
          <view class="btn-acceder">ACCÉDER</view>
        </view>
      </view>
      <view class="banner-nav-bar">
        <view class="nav-arrow-wrapper" bindtap="onPrev">
          <text class="arrow-text">←</text>
        </view>
        <view class="nav-arrow-wrapper" bindtap="onNext">
          <text class="arrow-text">→</text>
        </view>
      </view>
    </view>

    <!-- Main Payment Container -->
    <view class="payment-wrapper">
      <view class="payment-card">
        
        <view class="payment-title">Mode de paiement</view>
        <view class="divider"></view>
        
        <view class="method-box">
          <image src="/assets/Tashilate.png" class="method-icon" mode="aspectFit" wx:if="{{paymentMethod.toLowerCase() === 'tashilat' || paymentMethod === 'Tashilate'}}"></image>
          <image src="/assets/Tashilate.png" class="method-icon" mode="aspectFit" wx:else></image>
          <text class="method-name">{{paymentMethod}}</text>
        </view>

        <view class="detail-title">Détail de paiement</view>

        <view class="detail-row">
          <text class="label">Numéro de carte : </text>
          <text class="value">{{cardNumber}}</text>
        </view>

        <view class="detail-row">
          <text class="label">Date d'expiration : </text>
          <text class="value">{{expDate}}</text>
        </view>

        <view class="detail-row">
          <text class="label">CVC : </text>
          <text class="value">{{cvc}}</text>
        </view>

        <view class="detail-row">
          <text class="label">Adresse facturation : </text>
          <text class="value">{{billingAddress}}</text>
        </view>

        <view class="cgu-row" bindtap="toggleCGU">
          <view class="checkbox {{acceptedCGU ? 'checked' : ''}}">
             <view class="checkmark" wx:if="{{acceptedCGU}}"></view>
          </view>
          <text class="cgu-text">Confirmer l'acceptation de CGU</text>
        </view>

        <button class="btn-confirm" bindtap="onConfirmPayment">CONFIRMEZ</button>

      </view>
    </view>



    <bottom-nav-bar variant="fixed" message-count="6" bind:navtap="onNavTap" />
  </view>
</view>
