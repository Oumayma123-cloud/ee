/* ========== Page Récapitulatif de votre RDV Style ========== */
page {
  background: #C7E2F2; /* Soft light blue page background */
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #C7E2F2;
  position: relative;
}

.scroll-content {
  flex: 1;
  height: 0;
}

.scroll-inner {
  display: flex;
  flex-direction: column;
  padding-bottom: 40rpx;
}

/* ========== 1. Header Styles ========== */
.header-section {
  padding: 20rpx 40rpx;
  background: transparent;
}

.header-content {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  position: relative;
}

.back-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  background: #FFFFFF;
  padding: 8rpx 24rpx 8rpx 12rpx;
  border-radius: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.back-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background: #EBF3F8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow-txt {
  font-size: 24rpx;
  color: #777777;
  font-weight: bold;
}

.back-label {
  font-size: 24rpx;
  color: #333333;
  font-weight: 500;
}

.logo {
  width: 140rpx;
  height: 60rpx;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.avatar-container {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.avatar-bubble {
  width: 90rpx;
  height: 90rpx;
  border-radius: 45rpx;
  background: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: visible;
  position: relative;
}

.avatar-bubble::after {
  content: "";
  position: absolute;
  bottom: -6rpx;
  right: 16rpx;
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 12rpx solid #FFFFFF;
  transform: rotate(-15deg);
}

.avatar-img {
  width: 76rpx;
  height: 76rpx;
  border-radius: 38rpx;
}

/* ========== 2. Recap Card Styles ========== */
.recap-card-wrap {
  padding: 30rpx 40rpx;
}

.recap-card {
  background: #FFFFFF;
  border-radius: 36rpx;
  padding: 44rpx 40rpx;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.06);
}

.recap-title-wrap {
  margin-bottom: 40rpx;
  border-bottom: 3rpx solid #5391C0;
  padding-bottom: 12rpx;
  display: inline-block;
}

.recap-title {
  color: #5391C0;
  font-size: 32rpx;
  font-weight: bold;
}

.recap-info-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.recap-row {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.recap-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #000000;
}

.recap-value {
  font-size: 28rpx;
  color: #333333;
}

/* ========== 3. Action Buttons ========== */
.buttons-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 40rpx;
  gap: 20rpx;
}

.btn-confirm {
  background: #5FA1CD;
  border-radius: 60rpx;
  height: 86rpx;
  width: 520rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(95, 161, 205, 0.35);
}

.btn-confirm:active {
  opacity: 0.85;
}

.btn-confirm-txt {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}

.btn-cancel {
  background: #2D5B7B;
  border-radius: 60rpx;
  height: 86rpx;
  width: 520rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(45, 91, 123, 0.25);
}

.btn-cancel:active {
  opacity: 0.85;
}

.btn-cancel-txt {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}

.bottom-spacer {
  height: 160rpx;
}

/* ========== 4. Modal Popup Overlay ========== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 9999;
  backdrop-filter: blur(5px);
}

.blur-content {
  filter: blur(4px);
}

.modal-card {
  width: 540rpx;
  background: #4A4A4A;
  border-radius: 40rpx;
  padding: 50rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.3);
  box-sizing: border-box;
}

.modal-text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.6;
  text-align: center;
  margin-bottom: 40rpx;
}

.modal-close-wrap {
  display: flex;
  justify-content: center;
  width: 100%;
}

.modal-close-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: #FFFFFF;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.2);
}

.close-icon-x {
  color: #5FA1CD;
  font-size: 56rpx;
  font-weight: bold;
  line-height: 1;
}