/* ========== Page Récapitulatif de votre RDV Style ========== */
page {
  background: #FFFFFF; /* White page background like mockup */
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
  position: relative;
}

.scroll-content {
  flex: 1;
  height: 0;
}

.scroll-inner {
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
}

/* ========== 1. Header Styles (White Background) ========== */
.header-section {
  padding: 20rpx 40rpx;
  background: #FFFFFF;
  position: relative;
  z-index: 10;
}

.header-content {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  position: relative;
  height: 110rpx;
}

.back-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  background: #FFFFFF;
  padding: 8rpx 24rpx 8rpx 12rpx;
  border-radius: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.back-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background: #EBF3F8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow-txt {
  font-size: 24rpx;
  color: #777777;
  font-weight: bold;
}

.back-label {
  font-size: 24rpx;
  color: #333333;
  font-weight: 500;
}

.logo {
  width: 140rpx;
  height: 60rpx;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

/* Scoped Speech Bubble Avatar on the Right */
.recap-avatar-container {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 100 !important;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.recap-avatar-bubble {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  background: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  border: 3rpx solid #FFFFFF;
}

.recap-avatar-img {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  display: block;
}

.recap-avatar-tail {
  width: 0;
  height: 0;
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-top: 16rpx solid #8B6554; /* Beautiful brown tail pointing down-left */
  margin-top: -2rpx;
  filter: drop-shadow(0 4rpx 4rpx rgba(0,0,0,0.1));
}

/* ========== 2. Blue Card Section ========== */
.blue-card-section {
  background: #C7E2F2; /* Soft blue background band behind card */
  padding: 40rpx 0;
  width: 100%;
}

.recap-card-wrap {
  padding: 0 40rpx;
}

.recap-card {
  background: #FFFFFF;
  border-radius: 36rpx;
  padding: 44rpx 40rpx;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.06);
}

.recap-title-wrap {
  margin-bottom: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center; /* Center the title horizontally */
  justify-content: center;
  position: relative;
  width: 100%;
}

.recap-title {
  color: #5391C0;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
}

.recap-title-underline {
  height: 4rpx;
  background: #5391C0;
  width: 90%; /* Let underline span nicely across the centered text */
  margin-top: 8rpx;
}

.recap-info-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.recap-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.recap-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #000000; /* Pure Black */
}

.recap-value {
  font-size: 28rpx;
  color: #000000; /* Pure Black */
  font-weight: 500;
}

/* ========== 3. White Buttons Section ========== */
.buttons-section {
  background: #FFFFFF;
  width: 100%;
  display: flex;
  justify-content: center;
}

.buttons-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 36rpx;
  gap: 24rpx;
}

.btn-confirm {
  background: #5FA1CD;
  border-radius: 60rpx;
  height: 86rpx;
  width: 600rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(95, 161, 205, 0.35);
  position: relative;
  z-index: 100;
  pointer-events: auto;
}

.btn-confirm:active {
  opacity: 0.85;
}

.btn-confirm-txt {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}

.btn-cancel {
  background: #2D5B7B;
  border-radius: 60rpx;
  height: 86rpx;
  width: 600rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(45, 91, 123, 0.25);
  position: relative;
  z-index: 100;
  pointer-events: auto;
}

.btn-cancel:active {
  opacity: 0.85;
}

.btn-cancel-txt {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}

.bottom-spacer {
  height: 160rpx;
}

/* ========== Custom Modal Styles ========== */
.page-blur {
  filter: blur(5px);
  pointer-events: none;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 9999;
  display: flex;
  justify-content: center;
  align-items: center;
  box-sizing: border-box;
}

.modal-card {
  width: 580rpx;
  background: #2D6F9E; /* Solid steel blue background matching the mockup */
  border-radius: 40rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 12rpx 36rpx rgba(0, 0, 0, 0.25);
  box-sizing: border-box;
}

.modal-icon {
  font-size: 140rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1;
  margin-bottom: 30rpx;
}

.modal-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
  text-align: center;
  line-height: 1.4;
  margin-bottom: 50rpx;
  white-space: pre-line;
}

.modal-buttons-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  width: 100%;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.btn-oui {
  background: #FFFFFF;
}

.btn-non {
  background: rgba(255, 255, 255, 0.25); /* Lighter blue/transparent style */
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.modal-btn:active {
  opacity: 0.85;
}

.modal-btn-txt {
  font-size: 28rpx;
  font-weight: bold;
  letter-spacing: 1rpx;
}

.btn-oui-txt {
  color: #2D6F9E;
}

.btn-non-txt {
  color: #FFFFFF;
}