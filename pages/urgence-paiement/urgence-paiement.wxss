.urgence-container {
  height: 100vh;
  background-color: #ffffff;
  color: #333333;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
}

.body-scroll {
  flex: 1;
  width: 100%;
  height: 0;
}

/* Header Styles */
.header {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  background: white;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.back-circle {
  width: 50rpx;
  height: 50rpx;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  font-size: 24rpx;
  color: #666;
}

.back-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.logo {
  width: 180rpx;
  height: 60rpx;
  display: block;
  flex-shrink: 0;
  margin: 0 auto;
}

.avatar-bubble {
  position: absolute;
  right: 20rpx;
  top: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 100;
}

.avatar-wrap {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: transparent;
  overflow: hidden;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-bubble-tail {
  width: 0;
  height: 0;
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-top: 15rpx solid #ffffff;
  margin-top: -5rpx;
}

/* Hero Section */
.hero-section {
  background-color: #D6998A;
  height: 420rpx;
  position: relative;
  display: flex;
  align-items: flex-end;
  padding: 0;
  margin-top: 0;
  overflow: visible;
}

.operator-container {
  width: 300rpx;
  height: 350rpx;
  position: absolute;
  left: 40rpx;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.warning-img {
  width: 280rpx;
  height: 280rpx;
  display: block;
}

.question-bubble {
  position: absolute;
  right: 40rpx;
  top: 80rpx;
  background: white;
  padding: 25rpx 35rpx;
  border-radius: 40rpx;
  width: 50%;
  box-shadow: 0 10rpx 20rpx rgba(0,0,0,0.1);
}

.bubble-text {
  font-size: 32rpx;
  color: #333;
  line-height: 1.4;
  font-weight: 800;
}

.bubble-text-small {
  font-size: 24rpx;
}

/* Separator Bar */
.separator-bar {
  height: 60rpx;
  background-color: #F8DCD9;
  width: 100%;
}

/* Denied Content */
.denied-content {
  padding: 80rpx 40rpx;
  background-color: #E8E8E8;
  display: flex;
  gap: 30rpx;
  min-height: 800rpx;
}

.timeline-track-denied {
  width: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.timeline-line-denied {
  width: 4rpx;
  height: 100%;
  background: #E63946;
  opacity: 0.2;
}

.timeline-dot-denied {
  width: 30rpx;
  height: 30rpx;
  background: white;
  border: 4rpx solid #E63946;
  border-radius: 50%;
  position: absolute;
  top: 40rpx; /* Adjusted to align with taller button */
}

.step-item-denied {
  background: #FF9F43; /* Orange */
  width: 572rpx; /* 286 * 2 */
  height: 130rpx; /* 65 * 2 */
  border-radius: 32rpx; /* 16 * 2 */
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 40rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 20rpx rgba(255,159,67,0.3);
}

.step-text-white {
  font-family: 'Neue Montreal', sans-serif;
  font-weight: 700;
  font-size: 28rpx; /* 14px * 2 */
  line-height: 38rpx; /* 19px * 2 */
  letter-spacing: 2rpx; /* 1px * 2 */
  color: white;
  flex: 1;
}

.close-icon-circle {
  width: 44rpx;
  height: 44rpx;
  background: white;
  color: #FF9F43;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.bottom-spacer {
  height: 180rpx;
}
