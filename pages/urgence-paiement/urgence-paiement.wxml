<view class="urgence-container" style="padding-top: {{statusBarHeight}}px;">
  <!-- Header -->
  <view class="header">
    <view class="back-btn" bindtap="onBackTap">
      <view class="back-circle">
        <text class="back-arrow">←</text>
      </view>
      <text class="back-text">Retour</text>
    </view>
    
    <image class="logo" src="../../assets/logo-tiqqa-header.png" mode="aspectFit"></image>

    <view class="avatar-bubble" bindtap="onProfileTap">
      <view class="avatar-wrap avatar-wrap--bubble">
        <image class="avatar" src="/assets/prof.png" mode="aspectFill"></image>
      </view>
      <view class="avatar-bubble-tail"></view>
    </view>
  </view>

  <!-- Body -->
  <scroll-view class="body-scroll" scroll-y="true">
    <!-- Top Separator -->
    <view class="separator-bar"></view>

    <!-- Hero Section (Warning) -->
    <view class="hero-section">
      <view class="operator-container">
        <!-- Warning Asset instead of emoji -->
        <image class="warning-img" src="../../assets/Calque.png" mode="aspectFit"></image>
      </view>
      <view class="question-bubble">
        <text class="bubble-text bubble-text-small">nous somme arrivés à l’adresse que vous nous avez indiqué mais la loi ne nous permet pas de vous prendre en charge.</text>
      </view>
    </view>

    <!-- Bottom Separator -->
    <view class="separator-bar"></view>

    <!-- Content Section -->
    <view class="denied-content">
      <view class="timeline-track-denied">
        <view class="timeline-line-denied"></view>
        <view class="timeline-dot-denied"></view>
      </view>

      <view class="steps-list">
        <view class="step-item-denied" bindtap="onRedirectionTap">
          <text class="step-text-white">Redirection : El Mansour - capacités limitées, transfert vers Narjiss</text>
          <view class="close-icon-circle" bindtap="onCloseTap">✕</view>
        </view>
      </view>
    </view>

    <view class="bottom-spacer"></view>
  </scroll-view>

  <!-- Bottom Navigation -->
  <bottom-nav-bar variant="fixed" active-tab="emergency" message-count="{{messageCount}}" bind:navtap="onNavTap" />
</view>
