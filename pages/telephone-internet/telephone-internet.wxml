<!-- ========== Page Téléphonie et Internet ========== -->
<view class="container">
  <scroll-view class="scroll-content" scroll-y="true" enhanced="true" show-scrollbar="false">
    <view class="scroll-inner">

      <!-- 1. Header -->
      <tiqqa-header bind:back="onBack" />

      <!-- 2. Blue Banner -->
      <view class="blue-banner">
        <text class="banner-script">Paiement</text>
        <text class="banner-bold"> FACTURES</text>
      </view>

      <!-- 3. Category Pill -->
      <view class="category-pill-row">
        <view class="category-pill">
          <image class="pill-icon" src="/assets/icons/icon-telephone.svg" mode="aspectFit"></image>
          <text class="pill-label">Téléphonie et Internet</text>
        </view>
      </view>

      <!-- 4. Operators List -->
      <view class="operators-list">

        <view class="operator-card" bindtap="onOperatorTap" data-id="orange">
          <image class="card-bracket" src="/assets/icons/bracket-blue.svg" mode="aspectFit"></image>
          <view class="operator-logo-wrap">
            <image class="operator-logo" src="/assets/icons/logo-orange.png" mode="aspectFit"></image>
          </view>
          <view class="operator-info">
            <text class="operator-name">ORANGE</text>
            <text class="operator-subtitle">Telecom</text>
          </view>
          <view class="chevron-down-bold"></view>
        </view>

        <view class="operator-card" bindtap="onOperatorTap" data-id="orange-recharge">
          <image class="card-bracket" src="/assets/icons/bracket-green.svg" mode="aspectFit"></image>
          <view class="operator-logo-wrap">
            <image class="operator-logo" src="/assets/icons/logo-orange.png" mode="aspectFit"></image>
          </view>
          <view class="operator-info">
            <text class="operator-name">Orange Recharge</text>
            <text class="operator-subtitle">Telecom</text>
          </view>
          <view class="chevron-down-bold"></view>
        </view>

        <view class="operator-card" bindtap="onOperatorTap" data-id="inwi-recharge">
          <image class="card-bracket" src="/assets/icons/bracket-cyan.svg" mode="aspectFit"></image>
          <view class="operator-logo-wrap">
            <image class="operator-logo" src="/assets/icons/logo-inwi.png" mode="aspectFit"></image>
          </view>
          <view class="operator-info">
            <text class="operator-name">INWI Recharge</text>
            <text class="operator-subtitle">Telecom</text>
          </view>
          <view class="chevron-down-bold"></view>
        </view>

        <view class="operator-card" bindtap="onOperatorTap" data-id="iam-direct">
          <image class="card-bracket" src="/assets/icons/bracket-cyan.svg" mode="aspectFit"></image>
          <view class="operator-logo-wrap">
            <image class="operator-logo" src="/assets/icons/logo-maroc-telecom.png" mode="aspectFit"></image>
          </view>
          <view class="operator-info">
            <text class="operator-name">IAM_Recharge_Direct</text>
            <text class="operator-subtitle">Telecom</text>
          </view>
          <view class="chevron-down-bold"></view>
        </view>

      </view>

      <view class="bottom-spacer"></view>
    </view>
  </scroll-view>

  <bottom-nav-bar variant="fixed" message-count="6" bind:navtap="onNavTap" />
</view>
