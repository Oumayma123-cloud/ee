.page {
  height: 100vh;
  background: #B88E7E;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.header {
  padding-top: 120rpx;
  padding-bottom: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-container {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 50rpx;
  position: relative;
  z-index: 10;
}

.logo-img {
  width: 260rpx;
  display: block;
}

.progress-wrapper {
  width: 100%;
  position: relative;
  display: flex;
  justify-content: center; 
  align-items: center;
}

.progress-bar {
  width: 200rpx;
  height: 7rpx;
  background: #2E2E2E;
  border-radius: 20rpx;
  overflow: hidden;
}

.progress-active {
  width: 33%;
  height: 100%;
  background: #FFFFFF;
  border-radius: 20rpx;
}

.step {
  position: absolute;
  right: 90rpx;  
  color: white;
  font-size: 22rpx;
}

.card {
  flex: 1;
  background: #F2F2F2;
  border-top-left-radius: 50rpx;
  border-top-right-radius: 50rpx;
  padding: 60rpx 50rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #10275A;
  margin-bottom: 15rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #10275A;
  margin-bottom: 50rpx;
}

.input {
  height: 90rpx;
  border: 1rpx solid #DADADA;
  border-radius: 18rpx;
  padding: 0 30rpx;
  margin-bottom: 30rpx;
  background: #FFFFFF;
  font-size: 28rpx;
  color: #10275A;
}

.ph {
  color: #10275A;
}

.phone-box {
  display: flex;
  align-items: center;
  height: 90rpx;
  border: 1rpx solid #DADADA;
  border-radius: 18rpx;
  padding: 0 20rpx;
  margin-bottom: 30rpx;
  background: #FFFFFF;
}

.operator-logo {
  width: 70rpx;
  height: 70rpx;
  margin-right: 15rpx;
}

.phone-input {
  flex: 1;
  font-size: 28rpx;
  color: #10275A;
}

.check-row {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
}

.check-text {
  font-size: 22rpx;
  color: #7D8CA3;
  margin-left: 15rpx;
}

.btn {
  margin-top: 90rpx;
  height: 95rpx;
  background: #B88E7E;
  color: white;
  border-radius: 60rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  justify-content: center;
  align-items: center;
}

.footer-line {
  width: 100%;
  height: 7rpx;
  background: #1F1F1F;
}