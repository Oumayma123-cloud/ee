<view class="urgence-container" style="padding-top: {{statusBarHeight}}px;">
  <!-- Header -->
  <view class="header">
    <view class="back-btn" bindtap="onBackTap">
      <view class="back-circle">
        <text class="back-arrow">←</text>
      </view>
      <text class="back-text">Retour</text>
    </view>
    
    <image class="logo" src="/assets/logo-tiqqa-header.png" mode="aspectFit"></image>

    <view class="avatar-bubble" bindtap="onProfileTap">
      <view class="avatar-wrap avatar-wrap--bubble">
        <image class="avatar" src="/assets/profile.png" mode="aspectFill"></image>
      </view>
    </view>
  </view>

  <!-- Body -->
  <scroll-view class="body-scroll" scroll-y="true">
    <!-- Top Separator -->
    <view class="separator-bar"></view>

    <!-- Hero Section (Dynamic) -->
    <view class="hero-section {{isRetour && currentStep === 4 ? 'hero-section-nurse' : ''}}">
      <block wx:if="{{isRetour && currentStep === 4}}">
        <!-- Special Nurse Card/Banner -->
        <view class="nurse-card">
          <!-- Brown top bar of the card window -->
          <view class="nurse-card-header">
            <view class="nurse-dots">
              <view class="nurse-dot"></view>
              <view class="nurse-dot"></view>
              <view class="nurse-dot"></view>
            </view>
          </view>
          
          <!-- Image and Content section -->
          <view class="nurse-card-body">
            <!-- Banner Image -->
            <image class="nurse-bg-img" src="/assets/services/service-nurse.png" mode="aspectFill"></image>
            <!-- Card Content Overlay -->
            <view class="nurse-overlay">
              <view class="nurse-content">
                <text class="nurse-title">PARCE QUE LE SOIN NE S’ARRÊTE PAS À L’HÔPITAL...</text>
                <text class="nurse-subtitle">soins infirmiers à domicile offerts – prenez rendez-vous dès maintenant.</text>
                <view class="nurse-btn" bindtap="onReserveNurse">RÉSERVER</view>
              </view>
            </view>
          </view>
        </view>
      </block>
      <block wx:else>
        <view class="operator-container">
          <!-- Operator -->
          <image wx:if="{{stepsData[currentStep-1].heroType === 'operator'}}" class="operator-img" src="/assets/center-appel.png" mode="aspectFit"></image>
          <!-- Ambulance -->
          <image wx:elif="{{stepsData[currentStep-1].heroType === 'ambulance'}}" class="ambulance-hero-img" src="/assets/urg.png" mode="aspectFit"></image>
          <!-- Warning triangle -->
          <view wx:elif="{{stepsData[currentStep-1].heroType === 'warning'}}" class="warning-icon">
            <view class="warning-triangle-css">
              <text class="warning-excl">!</text>
            </view>
          </view>
        </view>
        <view class="question-bubble">
          <text class="bubble-text bubble-text-small">{{stepsData[currentStep-1].message}}</text>
        </view>
      </block>
    </view>

    <!-- Bottom Separator -->
    <view class="separator-bar"></view>

    <!-- Timeline Content (Dynamic) -->
    <view class="timeline-container">
      <view class="timeline-track">
        <view class="timeline-line"></view>
        <!-- The dot moves based on the current step. Each step is roughly 100rpx + gap. -->
        <view class="timeline-dot-active" style="top: 30rpx"></view>
      </view>

      <view class="steps-list">
        <block wx:for="{{stepsData}}" wx:key="id">
          <view
            wx:if="{{item.id >= currentStep}}"
            class="step-item {{item.id === currentStep && item.heroType !== 'warning' ? 'step-active' : ''}} {{item.id === currentStep && item.heroType === 'warning' ? 'step-warning' : ''}} {{item.id === 7 ? 'orange' : ''}}"
            bindtap="onStepTap"
            data-step="{{item.id}}"
          >
            <view class="step-content-row">
              <text class="step-text">{{item.title}}</text>
              <view class="check-mark-circle" wx:if="{{item.id === currentStep && item.heroType !== 'warning'}}">✓</view>
              <view class="cancel-mark-circle" wx:if="{{item.id === currentStep && item.heroType === 'warning'}}">✕</view>
            </view>
          </view>
        </block>
      </view>
    </view>

    <view class="bottom-spacer"></view>
  </scroll-view>

  <!-- Bottom Navigation -->
  <bottom-nav-bar variant="fixed" active-tab="emergency" message-count="0" bind:navtap="onNavTap" />
</view>
