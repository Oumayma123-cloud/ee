.urgence-container {
  height: 100vh;
  background-color: #ffffff;
  color: #333333;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
}

.body-scroll {
  flex: 1;
  width: 100%;
  height: 0;
}

/* Header Styles */
.header {
  position: relative;
  width: 100%;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx 0 20rpx;
  box-sizing: border-box;
  background: #ffffff;
  z-index: 100;
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.back-circle {
  width: 50rpx;
  height: 50rpx;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  font-size: 24rpx;
  color: #666;
}

.back-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.logo {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 60rpx;
}

.avatar-bubble {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 100;
}

.avatar-wrap {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: transparent;
}

.avatar-wrap--bubble {
  border: none;
  box-shadow: none;
  overflow: hidden;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

/* Hero Section */
.hero-section {
  background-color: #D6998A;
  height: 420rpx;
  position: relative;
  display: flex;
  align-items: flex-end;
  padding: 0;
  margin-top: 0;
  overflow: visible;
}

.operator-container {
  width: 300rpx;
  height: 350rpx;
  position: absolute;
  left: 40rpx;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  z-index: 2;
}

.operator-img, .ambulance-hero-img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.ambulance-hero-img {
  transform: scale(1.2) translateY(-20rpx);
}

.question-bubble {
  position: absolute;
  right: 40rpx;
  top: 80rpx;
  background: white;
  padding: 25rpx 35rpx;
  border-radius: 40rpx;
  width: 50%;
  box-shadow: 0 10rpx 20rpx rgba(0,0,0,0.1);
}

.bubble-text {
  font-size: 32rpx;
  color: #333;
  line-height: 1.4;
  font-weight: 800;
}

.bubble-text-small {
  font-size: 24rpx;
}

.text-red {
  color: #E63946;
  font-weight: 600;
}

/* Separator Bar */
.separator-bar {
  height: 60rpx;
  background-color: #F8DCD9;
  width: 100%;
}

/* Timeline Container */
.timeline-container {
  background-color: #E8E8E8;
  padding: 60rpx 40rpx;
  display: flex;
  gap: 30rpx;
  min-height: 800rpx;
}

.timeline-track {
  width: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.timeline-line {
  width: 4rpx;
  height: 90%;
  background: #E63946;
  opacity: 0.3;
}

.timeline-dot-active {
  width: 36rpx;
  height: 36rpx;
  background: white;
  border: 4rpx solid #E63946;
  border-radius: 50%;
  position: absolute;
  top: 30rpx;
  z-index: 2;
}

.steps-list {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.step-item {
  background: white;
  padding: 20rpx 40rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
}

.step-active {
  background: #FF3B30;
  box-shadow: 0 6rpx 15rpx rgba(255,59,48,0.3);
}

.step-text {
  font-family: 'Neue Montreal', sans-serif;
  font-weight: 700;
  font-size: 28rpx;
  line-height: 38rpx;
  letter-spacing: 2rpx;
  color: #999; /* Gray for inactive */
  display: block;
}

.step-active .step-text {
  color: white;
}

.step-completed .step-text {
  color: #666; /* Slightly darker gray for completed but not active */
}

.step-content-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.check-mark-circle {
  width: 44rpx;
  height: 44rpx;
  background: white;
  color: #FF3B30;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
}

/* Orange warning step */
.step-warning {
  background: #FF9500;
  box-shadow: 0 6rpx 15rpx rgba(255,149,0,0.35);
}

.step-warning .step-text {
  color: white;
}

.cancel-mark-circle {
  width: 44rpx;
  height: 44rpx;
  background: white;
  color: #FF9500;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
}

/* Warning triangle hero */
.warning-icon {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 280rpx;
  height: 280rpx;
}

/* CSS-only triangle using border trick */
.warning-triangle-css {
  width: 0;
  height: 0;
  border-left: 140rpx solid transparent;
  border-right: 140rpx solid transparent;
  border-bottom: 240rpx solid #FF9500;
  position: relative;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.warning-excl {
  position: absolute;
  bottom: -210rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 130rpx;
  font-weight: 900;
  color: white;
  line-height: 1;
}

/* Nurse Card Styles for Step 4 of Retour */
.hero-section-nurse {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.nurse-card {
  width: 650rpx;
  height: 360rpx;
  border-radius: 32rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.2);
}

.nurse-card-header {
  height: 64rpx;
  background-color: #6C4C3E;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 0 32rpx;
}

.nurse-dots {
  display: flex;
  gap: 16rpx;
}

.nurse-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background-color: #ffffff;
}

.nurse-card-body {
  position: relative;
  flex: 1;
  width: 100%;
  height: 100%;
}

.nurse-bg-img {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}

.nurse-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.38); /* Subtle overlay for text readability */
  z-index: 2;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 24rpx 36rpx;
  box-sizing: border-box;
}

.nurse-content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  max-width: 95%;
}

.nurse-title {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 34rpx;
  margin-bottom: 8rpx;
  letter-spacing: 1.5rpx;
}

.nurse-subtitle {
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 500;
  line-height: 28rpx;
  margin-bottom: 16rpx;
}

.nurse-btn {
  background-color: #ffffff;
  color: #000000;
  font-size: 22rpx;
  font-weight: 800;
  padding: 10rpx 28rpx;
  border-radius: 14rpx;
  text-align: center;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.15);
}
