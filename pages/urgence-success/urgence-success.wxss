.urgence-container {
  height: 100vh;
  background-color: #ffffff;
  color: #333333;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
}

.body-scroll {
  flex: 1;
  width: 100%;
  height: 0;
}

/* Header Styles */
.header {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  background: white;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.back-circle {
  width: 50rpx;
  height: 50rpx;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  font-size: 24rpx;
  color: #666;
}

.back-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.logo {
  width: 180rpx;
  height: 60rpx;
  display: block;
  flex-shrink: 0;
  margin: 0 auto;
}

.avatar-bubble {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  position: relative;
  z-index: 10;
}

.avatar-wrap {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: transparent;
}

.avatar-wrap--bubble {
  border: none;
  box-shadow: none;
  overflow: hidden;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

/* Hero Section */
.hero-section {
  background-color: #D6998A;
  height: 420rpx;
  position: relative;
  display: flex;
  align-items: flex-end;
  padding: 0;
  margin-top: 0;
  overflow: visible;
}

.operator-container {
  width: 300rpx;
  height: 350rpx;
  position: absolute;
  left: 40rpx;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  z-index: 2;
}

.operator-img, .ambulance-hero-img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.ambulance-hero-img {
  transform: scale(1.2) translateY(-20rpx);
}

.question-bubble {
  position: absolute;
  right: 40rpx;
  top: 80rpx;
  background: white;
  padding: 25rpx 35rpx;
  border-radius: 40rpx;
  width: 50%;
  box-shadow: 0 10rpx 20rpx rgba(0,0,0,0.1);
}

.bubble-text {
  font-size: 32rpx;
  color: #333;
  line-height: 1.4;
  font-weight: 800;
}

.bubble-text-small {
  font-size: 24rpx;
}

.text-red {
  color: #E63946;
  font-weight: 600;
}

/* Separator Bar */
.separator-bar {
  height: 60rpx;
  background-color: #F8DCD9;
  width: 100%;
}

/* Timeline Container */
.timeline-container {
  background-color: #E8E8E8;
  padding: 60rpx 40rpx;
  display: flex;
  gap: 30rpx;
  min-height: 800rpx;
}

.timeline-track {
  width: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.timeline-line {
  width: 4rpx;
  height: 90%;
  background: #E63946;
  opacity: 0.3;
}

.timeline-dot-active {
  width: 36rpx;
  height: 36rpx;
  background: white;
  border: 4rpx solid #E63946;
  border-radius: 50%;
  position: absolute;
  top: 30rpx;
  z-index: 2;
}

.steps-list {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.step-item {
  background: white;
  padding: 20rpx 40rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
}

.step-active {
  background: #FF3B30;
  box-shadow: 0 6rpx 15rpx rgba(255,59,48,0.3);
}

.step-text {
  font-family: 'Neue Montreal', sans-serif;
  font-weight: 700;
  font-size: 28rpx;
  line-height: 38rpx;
  letter-spacing: 2rpx;
  color: #999; /* Gray for inactive */
  display: block;
}

.step-active .step-text {
  color: white;
}

.step-completed .step-text {
  color: #666; /* Slightly darker gray for completed but not active */
}

.step-content-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.check-mark-circle {
  width: 44rpx;
  height: 44rpx;
  background: white;
  color: #FF3B30;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
}

.demo-controls {
  margin: 40rpx;
  padding: 20rpx;
  background: rgba(0,0,0,0.05);
  text-align: center;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666;
}
