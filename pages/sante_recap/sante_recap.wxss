.container {
  min-height: 100vh;
  background: #d0d0d0;
  display: flex;
}

.shell {
  width: 100%;
  min-height: 100vh;
  background: #ffffff;
  display: flex;
  flex-direction: column;
}

/* Custom Header (Reusable) */
.horaire-header-wrap {
  flex-shrink: 0;
  background: #ffffff;
  min-height: 120rpx;
  height: auto;
  padding-top: 10rpx;
  padding-bottom: 8rpx;
  box-sizing: border-box;
  position: sticky;
  top: 0;
  z-index: 100;
}

.status-row {
  display: flex;
  align-items: center;
  padding: 0 34rpx 0rpx;
  box-sizing: border-box;
  min-height: 0;
  height: auto;
}

.top-bar--horaire {
  position: relative;
  width: 100%;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx 0 20rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.back-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.back-circle {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #f2f2f2;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #333;
  font-size: 24rpx;
  font-weight: bold;
}

.back-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #000000;
}

.logo {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 60rpx;
}

.avatar-bubble {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  position: relative;
  z-index: 10;
}

.avatar-wrap {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: transparent;
}

.avatar-wrap--bubble {
  border: none;
  box-shadow: none;
  overflow: hidden;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}



/* Green Top Section */
.recap-top-section {
  background-color: #C1E2CB;
  padding: 40rpx 40rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.section-title {
  color: #111;
  font-size: 34rpx;
  font-weight: 800;
  margin-bottom: 40rpx;
  letter-spacing: 1rpx;
}

.recap-card {
  background: #f7faf8;
  width: 100%;
  border-radius: 30rpx;
  padding: 40rpx 40rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}

.card-header {
  color: #3c7d58;
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.card-divider {
  width: 100%;
  height: 2rpx;
  background: #2b2b2b;
  margin-bottom: 30rpx;
}

.info-group {
  margin-bottom: 24rpx;
}

.info-label {
  font-size: 28rpx;
  font-weight: 800;
  color: #111;
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 26rpx;
  color: #666;
}

/* Bottom White Section */
.recap-bottom-section {
  background: #ffffff;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 40rpx 40rpx;
}

.nurse-img {
  width: 400rpx;
  height: 400rpx;
  margin-bottom: 20rpx;
}

.action-buttons {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn {
  width: 100% !important;
  height: 90rpx !important;
  border-radius: 45rpx !important;
  font-size: 30rpx !important;
  font-weight: 800 !important;
  display: flex;
  align-items: center;
  justify-content: center;
  text-transform: none;
}

.btn-confirm {
  background-color: #70b682 !important;
  color: #ffffff !important;
}

.btn-cancel {
  background-color: #4b5d54 !important;
  color: #ffffff !important;
}

/* Modal */
.modal-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(8px); /* Effet flou sur le fond */
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  background: #333333;
  width: 580rpx;
  border-radius: 46rpx;
  padding: 70rpx 40rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-text {
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 600;
  text-align: center;
  line-height: 1.5;
  margin-bottom: 60rpx;
}

.modal-close {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #e6e6e6;
  display: flex;
  justify-content: center;
  align-items: center;
}

.close-icon {
  font-size: 36rpx;
  color: #333;
  font-weight: 400;
}

