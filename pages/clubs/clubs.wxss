/* ============================================================
   Clubs Tiqqa Page – clubs.wxss
   ============================================================ */

.clubs-container {
  height: 100vh;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: hidden;
}

.mobile-card {
  width: 750rpx;
  height: 100%;
  margin: 0 auto;
  border-radius: 57.69rpx;
  overflow: hidden;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  position: relative;
  box-sizing: border-box;
}

/* ── Header ─────────────────────────────────────────────── */
.horaire-header-wrap {
  flex-shrink: 0;
  background: #ffffff;
  padding-top: 10rpx;
  padding-bottom: 8rpx;
  box-sizing: border-box;
}

.status-row {
  display: flex;
  align-items: center;
  padding: 0 34rpx 0rpx;
  box-sizing: border-box;
}

.top-bar--horaire {
  position: relative;
  width: 100%;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx 0 20rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.back-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  z-index: 15;
}

.back-circle {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #f2f2f2;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #333;
  font-size: 24rpx;
  font-weight: bold;
}

.back-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #000000;
}

.logo {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 60rpx;
  z-index: 10;
}

.avatar-bubble {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  position: relative;
  z-index: 15;
}

.avatar-wrap {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: transparent;
  overflow: hidden;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-bubble-tail {
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-top: 8rpx solid #c19a89;
  margin-top: -2rpx;
}

/* ── Hero Section ────────────────────────────────────────── */
.clubs-hero-area {
  width: 100%;
  flex-shrink: 0;
}

.clubs-hero-main {
  position: relative;
  width: 100%;
  height: 350rpx;
}

.clubs-hero-img {
  width: 100%;
  height: 100%;
}

.clubs-hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.18);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding-left: 40rpx;
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

.clubs-hero-title {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 800;
  max-width: 500rpx;
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
  letter-spacing: 1rpx;
}

.clubs-hero-btn {
  width: 180rpx;
  height: 54rpx;
  background: #ffffff;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.clubs-hero-btn-txt {
  color: #000000;
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

/* ── Date Navigation Strip ───────────────────────────────── */
.clubs-date-strip {
  height: 75rpx;
  background: #D4A49E;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
  box-sizing: border-box;
  flex-shrink: 0;
}

.date-arrow-btn {
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #9c7661;
  font-weight: bold;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.08);
  flex-shrink: 0;
}

.date-center {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex: 1;
  justify-content: center;
}

.date-calendar-icon {
  width: 40rpx;
  height: 40rpx;
}

.date-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #3a3a3a;
  letter-spacing: 1rpx;
}

/* ── Main Title Section ──────────────────────────────────── */
.clubs-main-header {
  flex-shrink: 0;
  padding: 28rpx 40rpx 16rpx;
  display: flex;
  flex-direction: column;
}

.clubs-title-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  width: 100%;
}

/* Image replacing the 'Clubs' script text */
.clubs-title-clubs-img {
  width: 120rpx;
  height: 52rpx;
}

.clubs-title-logo {
  width: 200rpx;
  height: 52rpx;
}

/* ── Grid & Scrollable Container ─────────────────────────── */
.clubs-grid-container {
  display: flex;
  flex: 1;
  min-height: 0;
  padding: 0 30rpx;
  box-sizing: border-box;
  gap: 20rpx;
  margin-bottom: 110rpx;
}

.content-scroll {
  flex: 1;
  height: 100%;
}

.clubs-grid {
  display: grid;
  grid-template-columns: repeat(2, 232rpx);
  gap: 18rpx;
  padding-bottom: 30rpx;
  justify-content: center;
}

/* ── Club Cards ──────────────────────────────────────────── */
/* Figma: width 116px × height 149px × radius 9px → ×2 rpx */
.club-card {
  width: 232rpx;
  height: 298rpx;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding-bottom: 20rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.club-card--sport {
  background: #A8C94A; /* Olive green */
}

.club-card--cuisine {
  background: #C9A050; /* Warm golden */
}

.club-card--finances {
  background: #5BA8A0; /* Teal */
}

.club-card--jardinage {
  background: #7A9E6E; /* Earthy green */
}

.club-card--beaute {
  background: #A58BA8; /* purple-grey */
}

.club-card--culture {
  background: #A76A65; /* muted reddish brown */
}

.club-card--nutrition {
  background: #F4A273; /* peach/orange */
}

.club-card--voyages {
  background: #DC9A8F; /* light coral/pinkish */
}

.club-card--sante {
  background: #B3CBB7; /* light sage green */
}

.club-card--bienetre {
  background: #66949C; /* muted teal */
}

.club-card--religion {
  background: #AEC6CA; /* light blue/greyish */
}

.club-card--solidarite {
  background: #C7B5C7; /* light mauve */
}

.club-card--technologie {
  background: #6D9E9F; /* Teal */
}

.club-card--voyages {
  background: #E0A395; /* Peach */
}

.club-card--jardinage {
  background: #8CA18C; /* Sage Green */
}

.club-card--finances {
  background: #86B9BA; /* Teal */
}

.club-card--artisanat {
  background: #83B7B3; /* Light Teal */
}

.club-card--cuisine {
  background: #CFAB54; /* Mustard Yellow / Gold */
}

.club-card--sport {
  background: #BBD030; /* Lime Green */
}

.club-card-img {
  width: 95%;
  flex: 1;
  margin-bottom: 15rpx;
}

.club-card-label {
  position: relative;
  z-index: 2;
  font-size: 24rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 2rpx;
  text-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.35);
}

/* ── Custom Scrollbar ────────────────────────────────────── */
.clubs-scrollbar {
  width: 54rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  height: 380rpx; /* Reduced length significantly */
  margin-top: 120rpx; /* Pushed down to center it nicely */
  padding-bottom: 0;
  box-sizing: border-box;
}

.clubs-scroll-arrow {
  width: 54rpx;
  height: 54rpx;
  background: linear-gradient(145deg, #f6f6f6, #e6e6e6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #6b6b6b;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.15);
  flex-shrink: 0;
}

.clubs-scroll-track {
  width: 28rpx; /* Increased width slightly */
  flex: 1;
  background: #ffffff;
  border-radius: 14rpx;
  position: relative;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid #f2f2f2;
}

.clubs-scroll-thumb {
  position: absolute;
  left: 0;
  width: 100%;
  height: 110rpx;
  background: #9b6260; /* Exact brown/mauve color from Image 2 */
  border-radius: 14rpx;
  transition: top 0.05s linear;
}

.bottom-spacer {
  height: 100rpx;
}
