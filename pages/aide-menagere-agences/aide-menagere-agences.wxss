/* ========== Container ========== */
page {
  background: #FFFFFF;
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
}

.scroll-content {
  flex: 1;
  overflow: hidden;
}

.scroll-inner {
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
}

/* ========== Header ========== */
.header-section {
  background: #FFFFFF;
  padding-bottom: 0;
  position: relative;
  z-index: 10;
}

.header-content {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 80rpx 14rpx 28rpx;
  height: 110rpx;
  box-sizing: border-box;
}

.back-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  z-index: 10;
}

.back-circle {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: #F0F0F0;
  display: flex;
  justify-content: center;
  align-items: center;
}

.back-arrow-txt {
  font-size: 26rpx;
  color: #333;
  font-weight: normal;
  line-height: 1;
}

.back-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}

.logo {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 140rpx;
  height: 56rpx;
  z-index: 5;
}

/* Bubble avatar */
.avatar-container {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
}

.avatar-bubble {
  position: relative;
  width: 100rpx;
  height: 110rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-img {
  width: 100rpx;
  height: 110rpx;
  display: block;
}

/* ========== Hero Slider Section ========== */
.hero-section {
  background: #3A7EA7; /* Medium steel blue */
  padding: 24rpx 40rpx;
  position: relative;
  z-index: 2;
}

.banner-container {
  width: 100%;
  height: 300rpx;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.banner-img {
  width: 100%;
  height: calc(100% - 40rpx);
  margin-top: 40rpx;
  display: block;
}

/* Browser mockup header */
.browser-header {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 40rpx;
  background: #A9D3EC;
  display: flex;
  align-items: center;
  z-index: 4;
}

/* Navigation arrows */
.nav-arrow {
  position: absolute;
  top: calc(50% + 20rpx);
  transform: translateY(-50%);
  width: 50rpx;
  height: 50rpx;
  border-radius: 25rpx;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 5;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.nav-arrow-left {
  left: 20rpx;
}

.nav-arrow-right {
  right: 20rpx;
}

.arrow-char {
  font-size: 26rpx;
  color: #777777;
  font-weight: bold;
  line-height: 1;
}

/* Dots in top right of browser header */
.dot-container {
  position: absolute;
  top: 14rpx;
  right: 24rpx;
  display: flex;
  flex-direction: row;
  gap: 8rpx;
  z-index: 5;
}

.slide-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: #FFFFFF;
}

.slide-dot--active {
  background: #4E82A5;
}

/* Text overlays */
.banner-text-overlay {
  position: absolute;
  left: 36rpx;
  bottom: 24rpx;
  z-index: 6;
  display: flex;
  flex-direction: column;
}

.banner-overlay-title {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: bold;
  line-height: 1.25;
  letter-spacing: 0.5rpx;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.4);
}

.banner-overlay-btn {
  background: #FFFFFF;
  border-radius: 24rpx;
  min-width: 200rpx;
  padding: 0 24rpx;
  height: 48rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 14rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.15);
  box-sizing: border-box;
}

.banner-overlay-btn-txt {
  color: #1A1A1A;
  font-size: 18rpx;
  font-weight: bold;
  letter-spacing: 0.5rpx;
}

/* ========== Content Card ========== */
.content-card {
  background: #CBE0EE; /* Soft pastel blue-gray matching mockup exactly */
  padding: 40rpx 40rpx 20rpx;
  display: flex;
  flex-direction: column;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #5FA1CD; /* Exactly sky blue from mockup */
  margin-bottom: 28rpx;
}

.agency-item {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 10rpx 30rpx rgba(46, 97, 136, 0.12); /* Beautiful soft blue-gray shadow matching mockup */
}

.agency-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.agency-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #000000;
}

.agency-distance {
  font-size: 24rpx;
  font-weight: bold;
  color: #000000;
}

.map-view {
  width: 100%;
  height: 220rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  background: #FFFFFF;
  border: 8rpx solid #FFFFFF; /* Thick white border around map like mockup */
  box-shadow: 0 6rpx 18rpx rgba(46, 97, 136, 0.15); /* Soft drop shadow under the map */
}

.map-bg-img {
  width: 100%;
  height: 100%;
  opacity: 0.65;
}

.map-lbl {
  position: absolute;
  font-weight: bold;
  color: #5C7F99;
  line-height: 1.2;
}

.map-lbl-hospital {
  top: 20rpx;
  left: 36rpx;
  font-size: 28rpx;
}

.map-lbl-avenue {
  bottom: 75rpx;
  right: 60rpx;
  transform: rotate(-15deg);
  font-size: 24rpx;
}

.map-lbl-avenue2 {
  bottom: 60rpx;
  right: 50rpx;
  transform: rotate(-15deg);
  font-size: 24rpx;
}

.map-pin-tashilat {
  position: absolute;
  bottom: 20rpx;
  left: 50rpx;
  width: 76rpx;
  height: 76rpx;
  z-index: 3;
}

.map-pin-tashilat2 {
  position: absolute;
  bottom: 85rpx;
  right: 200rpx;
  width: 76rpx;
  height: 76rpx;
  z-index: 3;
}

.map-badge-n1 {
  position: absolute;
  bottom: 24rpx;
  left: 50rpx;
  background: #E63946;
  border-radius: 8rpx;
  padding: 4rpx 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 3;
}

.n1-txt {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: bold;
}

/* ========== Return Button ========== */
.btn-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
}

.btn-return {
  background: #5FA1CD;
  border-radius: 44rpx;
  height: 88rpx;
  width: 500rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(95, 161, 205, 0.3);
}

.btn-return:active {
  opacity: 0.9;
}

.btn-return-txt {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: bold;
  letter-spacing: 1.5rpx;
}

/* Spacer */
.bottom-spacer {
  height: 180rpx;
  background: #CBE0EE;
}
