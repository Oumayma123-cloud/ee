.page {
  height: 100vh;
  background: #B88E7E;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

/* HEADER */
.header {
  padding-top: 120rpx;
  padding-bottom: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-container {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 50rpx;
  position: relative;
  z-index: 10;
}

.logo-img {
  width: 260rpx;
  display: block;
}

.progress-wrapper {
  width: 100%;
  position: relative;
  display: flex;
  justify-content: center; 
  align-items: center;
}

.progress-bar {
  width: 200rpx;
  height: 7rpx;
  background: #2E2E2E;
  border-radius: 20rpx;
  overflow: hidden;
}

.progress-active {
  width: 33%;
  height: 100%;
  background: #FFFFFF;
  border-radius: 20rpx;
}

.step3 {
  width: 100%;
}

.step {
  position: absolute;
  right: 90rpx;
  color: white;
  font-size: 22rpx;
}

.card {
  flex: 1;
  background: #F2F2F2;
  border-top-left-radius: 50rpx;
  border-top-right-radius: 50rpx;
  padding: 60rpx 50rpx;
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #10275A;
  margin-bottom: 40rpx;
}

.input {
  height: 90rpx;
  border: 1rpx solid #DADADA;
  border-radius: 18rpx;
  padding: 0 30rpx;
  margin-bottom: 30rpx;
  background: #FFFFFF;
  font-size: 28rpx;
  color: #10275A;
}

.ph {
  color: #10275A;
}

/* BUTTON */
.btn {
  margin-top: auto;
  height: 95rpx;
  background: #B88E7E;
  color: white;
  border-radius: 60rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 30rpx;
}

.footer-line {
  width: 100%;
  height: 7rpx;
  background: #1F1F1F;
}