.container {
  min-height: 100vh;
  background-color: #ffffff;
  display: flex;
  flex-direction: column;
  color: #333333;
}

.header {
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  padding-top: 20rpx;
  background: white;
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.back-circle {
  width: 50rpx;
  height: 50rpx;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  font-size: 24rpx;
  color: #666;
}

.back-text {
  font-size: 26rpx;
  color: #000;
  font-weight: 600;
}

.logo {
  width: 150rpx;
  height: 60rpx;
}

.avatar-bubble {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  overflow: hidden;
}

.avatar {
  width: 100%;
  height: 100%;
}

.title-wrap {
  display: flex;
  justify-content: center;
  padding: 30rpx 0;
  background: white;
}

.title {
  font-size: 36rpx;
  font-weight: 800;
  color: #8F6E61;
}

.video-container {
  flex: 1;
  position: relative;
  background: #000;
  width: 100%;
  border-radius: 60rpx 60rpx 0 0;
  overflow: hidden;
  margin-bottom: 120rpx; /* Space for nav bar */
}

.video-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.controls-overlay {
  position: absolute;
  bottom: 60rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  gap: 40rpx;
  z-index: 10;
}

.control-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10px);
}

.control-btn.disabled {
  opacity: 0.5;
}

.control-icon {
  width: 50rpx;
  height: 50rpx;
  filter: brightness(0) invert(1);
}

.hangup {
  background: rgba(0, 0, 0, 0.4);
}

.hangup-icon {
  color: white;
  font-size: 44rpx;
  font-weight: 300;
}

/* Modal Overlay */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dialog-box {
  background: white;
  width: 80%;
  border-radius: 40rpx;
  padding: 50rpx 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.dialog-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #000;
  margin-bottom: 20rpx;
}

.dialog-text {
  font-size: 28rpx;
  color: #333;
  text-align: center;
  line-height: 1.4;
  margin-bottom: 40rpx;
}

.welcome-controls {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx solid #eee;
  padding-top: 20rpx;
}

.timer {
  font-size: 24rpx;
  color: #999;
}

.welcome-actions {
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.w-icon {
  width: 36rpx;
  height: 36rpx;
  filter: brightness(0);
  opacity: 0.6;
}

.w-text {
  font-size: 40rpx;
  color: #666;
  font-weight: 300;
}

.fullscreen-icon {
  width: 24rpx;
  height: 24rpx;
  border: 2rpx solid #666;
  border-radius: 4rpx;
}
