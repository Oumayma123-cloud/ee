.urgence-container {
  height: 100vh;
  background-color: #ffffff;
  color: #333333;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
  position: relative;
}

.body-scroll {
  flex: 1;
  width: 100%;
  height: 0;
}

.blur-bg {
  filter: blur(10rpx);
  pointer-events: none;
}

/* Header Styles */
.header {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  background: white;
  position: sticky;
  top: 0;
  z-index: 100;
  flex-shrink: 0;
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 15rpx;
  flex-shrink: 0;
}

.back-circle {
  width: 50rpx;
  height: 50rpx;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  font-size: 24rpx;
  color: #666;
}

.back-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.logo {
  width: 180rpx;
  height: 60rpx;
  max-width: 180rpx;
  max-height: 60rpx;
  display: block;
  flex-shrink: 0;
  margin: 0 auto;
}

.avatar-bubble {
  position: absolute;
  right: 20rpx;
  top: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 100;
}

.avatar-wrap {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: transparent;
  overflow: hidden;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-bubble-tail {
  width: 0;
  height: 0;
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-top: 15rpx solid #ffffff;
  margin-top: -5rpx;
}

/* Hero Section */
.hero-section {
  background-color: #D6998A;
  height: 420rpx;
  position: relative;
  display: flex;
  align-items: flex-end;
  padding: 0;
  margin-top: 0;
  overflow: visible;
}

.operator-container {
  width: 300rpx;
  height: 350rpx;
  position: absolute;
  left: 40rpx;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  z-index: 2;
}

.ambulance-hero-img {
  width: 100%;
  height: 100%;
  display: block;
  max-width: 350rpx;
  max-height: 350rpx;
  object-fit: contain;
  transform: scale(1.2) translateY(-20rpx);
}

.question-bubble {
  position: absolute;
  right: 40rpx;
  top: 80rpx;
  background: white;
  padding: 30rpx 40rpx;
  border-radius: 40rpx;
  width: 50%;
  box-shadow: 0 10rpx 20rpx rgba(0,0,0,0.1);
}

.bubble-text {
  font-size: 32rpx;
  color: #333;
  line-height: 1.4;
  font-weight: 800;
}

/* Separator Bar */
.separator-bar {
  height: 60rpx;
  background-color: #F8DCD9;
  width: 100%;
}

/* Choice Content */
.choice-content {
  padding: 100rpx 40rpx;
  background-color: #E8E8E8;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 600rpx;
}

.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  width: 100%;
  align-items: center;
}

.btn-oui, .btn-non, .btn-later {
  width: 490rpx;
  height: 90rpx;
  border-radius: 86rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  font-size: 34rpx;
  box-shadow: 0 6rpx 12rpx rgba(0,0,0,0.1);
}

.btn-oui {
  background: #B2B2B2; /* Gray */
  color: white;
}

.btn-non {
  background: #FF0000; /* Red */
  color: white;
}

.btn-later {
  background: #6F2DBD; /* Purple */
  color: white;
}

/* Modal Styles */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.3);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-box {
  width: 580rpx;
  background: #4A4A4A; /* Dark gray as in photo */
  border-radius: 40rpx;
  padding: 60rpx 40rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 20rpx 50rpx rgba(0,0,0,0.3);
}

.close-modal {
  position: absolute;
  right: 30rpx;
  top: 20rpx;
  color: rgba(255,255,255,0.6);
  font-size: 28rpx;
  padding: 10rpx;
}

.modal-content {
  margin-bottom: 50rpx;
  text-align: center;
}

.modal-text {
  color: white;
  font-size: 30rpx;
  line-height: 1.5;
  font-weight: 500;
}

.modal-btn-ok {
  width: 420rpx;
  height: 80rpx;
  background: #A67B73; /* Salmon button from photo */
  color: white;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  font-size: 32rpx;
}

.bottom-spacer {
  height: 180rpx;
}
