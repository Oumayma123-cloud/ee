/* ============================================================
   Notifications Page – notifications.wxss
   ============================================================ */

.notifications-container {
  height: 100vh;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: hidden;
}

.mobile-card {
  width: 750rpx;
  height: 100%;
  margin: 0 auto;
  border-radius: 57.69rpx;
  overflow: hidden;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  position: relative;
  box-sizing: border-box;
}

/* ── Content ────────────────────────────────────────────── */
.content-container {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-height: 0;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 110rpx;
}

.scroll-area {
  flex: 1;
  height: 100%;
  width: 100%;
}

.notif-page-title-wrap {
  padding: 30rpx 40rpx 20rpx;
}

.notif-page-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1a1a1a;
  letter-spacing: 0.5rpx;
}

/* ── Notification List ──────────────────────────────────── */
.notif-list {
  padding: 10rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.notif-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 26rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #f0f0f0;
  position: relative;
}

.notif-item--unread {
  background: #f8f6ff;
  border-color: #eae6f8;
}

.notif-left {
  display: flex;
  align-items: flex-start;
  gap: 22rpx;
  flex: 1;
  min-width: 0;
}

/* ── Icon Wrap ──────────────────────────────────────────── */
.notif-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.notif-icon-bg--blue {
  background: #e8f0fe;
}

.notif-icon-bg--green {
  background: #e6f7ee;
}

.notif-icon-bg--pink {
  background: #fce8ec;
}

.notif-icon-bg--orange {
  background: #fff0e0;
}

.notif-icon-bg--purple {
  background: #f0e8ff;
}

.notif-icon-bg--yellow {
  background: #fff8e0;
}

.notif-icon-bg--red {
  background: #ffe8e8;
}

.notif-icon {
  width: 42rpx;
  height: 42rpx;
}

/* ── Info ────────────────────────────────────────────────── */
.notif-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
  flex: 1;
}

.notif-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.notif-desc {
  font-size: 22rpx;
  color: #777777;
  font-weight: 400;
  line-height: 1.4;
}

/* ── Right Side ─────────────────────────────────────────── */
.notif-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 16rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
  padding-top: 4rpx;
}

.notif-time {
  font-size: 20rpx;
  color: #aaaaaa;
  font-weight: 500;
  white-space: nowrap;
}

.notif-unread-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #4a7cff;
}
