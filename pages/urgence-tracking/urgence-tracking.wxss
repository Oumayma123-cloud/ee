.urgence-container {
  height: 100vh;
  background-color: #ffffff;
  color: #333333;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
}

.body-scroll {
  flex: 1;
  width: 100%;
  height: 0;
}

/* Header Styles */
.header {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  background: white;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.back-circle {
  width: 50rpx;
  height: 50rpx;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  font-size: 24rpx;
  color: #666;
}

.back-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.logo {
  width: 180rpx;
  height: 60rpx;
  display: block;
  flex-shrink: 0;
  margin: 0 auto;
}

.avatar-bubble {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  position: relative;
  z-index: 10;
}

.avatar-wrap {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: transparent;
}

.avatar-wrap--bubble {
  border: none;
  box-shadow: none;
  overflow: hidden;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

/* Hero Section */
.hero-section {
  background-color: #D6998A;
  height: 420rpx;
  position: relative;
  display: flex;
  align-items: flex-end;
  padding: 0;
  margin-top: 0;
  overflow: visible;
}

.operator-container {
  width: 300rpx;
  height: 350rpx;
  position: absolute;
  left: 40rpx;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  z-index: 2;
}

.operator-img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.question-bubble {
  position: absolute;
  right: 40rpx;
  top: 80rpx;
  background: white;
  padding: 30rpx 40rpx;
  border-radius: 40rpx;
  width: 45%;
  box-shadow: 0 10rpx 20rpx rgba(0,0,0,0.1);
}

.bubble-text {
  font-size: 32rpx;
  color: #333;
  line-height: 1.4;
  font-weight: 500;
}

.text-red {
  color: #E63946;
  font-weight: 600;
}

/* Separator Bar */
.separator-bar {
  height: 60rpx;
  background-color: #F8DCD9;
  width: 100%;
}

/* Tracking Content */
.tracking-content {
  padding: 30rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 25rpx;
}

.location-box {
  border: 1rpx solid #EAEAEA;
  border-radius: 60rpx;
  padding: 15rpx 45rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #ffffff;
}

.location-info {
  display: flex;
  flex-direction: column;
}

.location-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.location-value {
  font-size: 26rpx;
  color: #999;
}

.pencil-icon {
  font-size: 40rpx;
  color: #B2B2B2;
  font-weight: 300;
}

.map-container {
  width: 404rpx; /* 202 * 2 approx */
  height: 358rpx; /* 179 * 2 */
  margin: 0 auto;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.05);
}

.map-img {
  width: 100%;
  height: 100%;
}

.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 40rpx; /* gap 20px -> 40rpx */
  margin-top: 40rpx;
  align-items: center;
}

.btn-confirm-final {
  width: 490rpx; /* 245 * 2 */
  height: 90rpx;  /* 45 * 2 */
  background: #FF0000;
  color: white;
  border-radius: 86rpx; /* 43 * 2 */
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  font-size: 32rpx;
  box-sizing: border-box;
}

.btn-activate-loc {
  width: 490rpx; /* 245 * 2 */
  height: 90rpx;  /* 45 * 2 */
  background: #6F2DBD;
  color: white;
  border-radius: 86rpx; /* 43 * 2 */
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 30rpx;
  box-sizing: border-box;
}

.bottom-spacer {
  height: 180rpx;
}
