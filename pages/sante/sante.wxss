.container {
  background-color: #d0d0d0;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 0;
  display: flex;
  justify-content: stretch;
  align-items: stretch;
}

.shell {
  width: 100%;
  min-height: 100vh;
  background: #ffffff;
  border-radius: 30rpx;
  /* Remove overflow: hidden to allow natural page scrolling */
  display: flex;
  flex-direction: column;
  padding-top: 8rpx;
  padding-bottom: 140rpx; /* Space for fixed bottom-nav-bar */
}

/* New Header Styles from Photo */
.horaire-header-wrap {
  flex-shrink: 0;
  background: #ffffff;
  min-height: 120rpx;
  height: auto;
  padding-top: 10rpx;
  padding-bottom: 8rpx;
  box-sizing: border-box;
  position: sticky;
  top: 0;
  z-index: 100;
}

.status-row {
  display: flex;
  align-items: center;
  padding: 0 34rpx 0rpx;
  box-sizing: border-box;
  min-height: 0;
  height: auto;
}

.top-bar--horaire {
  position: relative;
  width: 100%;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 80rpx 0 20rpx; /* Shift avatar further to the right, avoiding logo overlap */
  box-sizing: border-box;
  background: #ffffff;
}

.back-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.back-circle {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #f2f2f2;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #333;
  font-size: 24rpx;
  font-weight: bold;
}

.back-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #000000;
}

.logo {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 60rpx;
}

.avatar-bubble {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  position: relative;
  z-index: 10;
}

.avatar-wrap {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: transparent;
}

.avatar-wrap--bubble {
  border: none;
  box-shadow: none;
  overflow: hidden;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}




.banner-area {
  margin: 0;
}

.banner-top-bar {
  background-color: #b8d8c1;
  height: 52rpx;
  width: 100%;
}
.banner-section {
  position: relative;
  height: 292rpx;
  overflow: hidden;
}
.banner-img { width: 100%; height: 100%; }
.banner-content {
  position: absolute;
  bottom: 18rpx;
  left: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}
.banner-title {
  color: white;
  font-weight: 700;
  font-size: 30rpx;
  white-space: nowrap;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.35);
  margin-bottom: 14rpx;
}
.btn-acceder {
  background: #fff;
  color: #222;
  font-size: 21rpx;
  font-weight: 700;
  border-radius: 30rpx;
  width: 128rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  margin: 0;
}
.banner-nav-bar {
  background-color: #b8d8c1;
  height: 68rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 96rpx;
}
.nav-arrow-wrapper {
  background: #d9dfdb;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
}
.nav-arrow-icon {
  width: 14rpx;
  height: 14rpx;
  opacity: 0.55;
}

.section-title {
  text-align: center;
  margin: 24rpx 0 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.section-title-img {
  width: 250rpx;
  height: 60rpx;
}

.main-content-wrapper {
  display: flex;
  position: relative;
  padding: 0 20rpx;
  box-sizing: border-box;
  flex: 1;
  justify-content: center;
  align-items: flex-start;
  gap: 18rpx;
}
.services-grid {
  /* 2 colonnes: 232 + 232 + gap(28) = 492 */
  width: 492rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  align-content: flex-start;
  margin: 0 auto;
  /* Espacement identique vertical/horizontal */
  row-gap: 28rpx;
  column-gap: 28rpx;
}
.service-card {
  /* Figma: 116x149px, radius 9px (converti en rpx ~ x2) */
  width: 232rpx;
  height: 298rpx;
  margin-bottom: 0;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.2;
  padding: 12rpx 10rpx;
  box-sizing: border-box;
}
.service-card image {
  width: 150rpx;
  height: 150rpx;
  margin-bottom: 12rpx;
  display: block;
  margin-left: auto;
  margin-right: auto;
}

.color-1 { background-color: #7cbf8f; color: #fff; }
.color-2 { background-color: #7abf8a; color: #fff; }
.color-3 { background-color: #75bc86; color: #fff; }
.color-4 { background-color: #c9ddd2; color: #2f8a50; }
.color-5 { background-color: #a6dbc4; color: #fff; }
.white-text { color: #2f8a50; }

.side-scrollbar {
  width: 56rpx;
  margin-left: 0;
  margin-top: 10rpx;
  height: 350rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}
.scroll-track {
  width: 24rpx;
  background: #ffffff;
  border-radius: 12rpx;
  flex: 1;
  position: relative;
  box-sizing: border-box;
  box-shadow: inset 0 2rpx 6rpx rgba(0, 0, 0, 0.06), 0 2rpx 4rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #e2e2e2;
}
.scroll-handle {
  width: 100%;
  height: 66rpx;
  background: #3c7d58;
  border-radius: 12rpx;
  position: absolute;
  top: 0;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}
.scroll-arrow-up, .scroll-arrow-down {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(180deg, #ffffff 0%, #ededed 100%);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.12);
  border: 1rpx solid #e0e0e0;
}
.arrow-text-scroll {
  font-size: 26rpx;
  color: #7f8c8d;
  font-weight: bold;
}

.tab-bar {
  height: 132rpx;
  background: #e9e9e9;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx solid #e5e5e5;
  margin-top: auto;
  padding: 0 70rpx;
  box-sizing: border-box;
}
.tab-icon { width: 24px; height: 24px; display: block; }

/* Tailles spécifiques par icône (approx. valeurs Figma) */
.tab-icon-home,
.tab-icon-msg,
.tab-icon-mic,
.tab-icon-cal,
.tab-icon-ambu {
  width: 24px;
  height: 24px;
}
.mic-container {
  background: #efefef;
  width: 112rpx;
  height: 112rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 50%;
  margin-top: -38rpx;
}
.mic-icon { width: 24px; height: 24px; }

.tab-item {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}
.badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background: #ffcc00;
  color: #000;
  font-size: 18rpx;
  font-weight: 700;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
}