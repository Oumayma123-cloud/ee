/* Style iOS : heure à gauche, signal + Wi‑Fi + batterie à droite ; fond blanc. */

.dsb-root {
  display: block;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  background: #ffffff;
}

.dsb-root--edge {
  padding-left: 28rpx;
  padding-right: 28rpx;
  box-sizing: border-box;
}

.dsb-row {
  width: 100%;
  min-height: 54rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 4rpx 0 6rpx;
  box-sizing: border-box;
}

.dsb-time {
  font-family:
    -apple-system,
    BlinkMacSystemFont,
    'SF Pro Text',
    'SF Pro Display',
    'Helvetica Neue',
    Helvetica,
    'PingFang SC',
    'Heiti SC',
    sans-serif;
  font-size: 30rpx;
  color: #000000;
  font-weight: 600;
  letter-spacing: -0.03em;
  line-height: 1;
  flex-shrink: 0;
}

.dsb-right {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  flex-shrink: 0;
  gap: 4rpx;
  margin-left: auto;
}

.dsb-signal {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: flex-end;
  gap: 2rpx;
  height: 22rpx;
}

.dsb-sig-bar {
  width: 4rpx;
  border-radius: 1rpx;
  background: #000000;
  flex-shrink: 0;
}

.dsb-sig-bar--1 {
  height: 5rpx;
}

.dsb-sig-bar--2 {
  height: 9rpx;
}

.dsb-sig-bar--3 {
  height: 13rpx;
}

.dsb-sig-bar--4 {
  height: 17rpx;
}

.dsb-wifi {
  width: 24rpx;
  height: 17rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dsb-wifi-img {
  width: 100%;
  height: 100%;
  display: block;
}

.dsb-battery {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-shrink: 0;
}

.dsb-battery-body {
  position: relative;
  width: 50rpx;
  height: 24rpx;
  border: 2rpx solid #000000;
  border-radius: 5rpx;
  box-sizing: border-box;
  overflow: hidden;
  background: #ffffff;
}

.dsb-battery-fill {
  position: absolute;
  left: 2rpx;
  top: 2rpx;
  right: 2rpx;
  bottom: 2rpx;
  background: #000000;
  border-radius: 2rpx;
}

.dsb-battery-cap {
  width: 3rpx;
  height: 9rpx;
  margin-left: 1rpx;
  background: #000000;
  border-radius: 0 2rpx 2rpx 0;
  flex-shrink: 0;
}
