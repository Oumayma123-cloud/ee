/* styles are primarily in app.wxss */
.nav-icon.active {
  opacity: 1;
  transform: scale(1.1);
}
.nav-icon {
  opacity: 1;
  transition: all 0.2s ease;
}

/* Local badge styles to bypass WeChat global class descendant selector limitation */
.nav-badge-slot {
  position: relative;
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

.nav-badge-slot .nav-icon {
  width: 44rpx;
  height: 44rpx;
  display: block;
}

.nav-badge .badge {
  position: absolute;
  top: -10rpx;
  right: -12rpx;
  min-width: 30rpx;
  height: 30rpx;
  border-radius: 15rpx;
  background: #eedd44;
  color: #000000;
  font-size: 16rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
  box-sizing: border-box;
  line-height: 1;
  border: 2rpx solid #f5f5f5;
  box-shadow: 0 2rpx 5rpx rgba(0, 0, 0, 0.1);
  z-index: 999;
}
