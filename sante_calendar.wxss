.container {
  background: #F7F8F8;
  min-height: 100vh;
  padding-bottom: 140rpx;
  position: relative;
}

/* Header + Top section */
.top-section { 
  background: #D8F1E0;
}

.header {
  padding: 36rpx 22rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  background: rgba(255, 255, 255, 0.90);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.header-left {
  display: flex;
  align-items: center;
}

.header-center {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-logo {
  width: 180rpx;
  height: auto;
}

.back-circle {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.78);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 20rpx rgba(0, 0, 0, 0.12);
  margin-right: 14rpx;
}

.back-icon {
  width: 28rpx;
  height: 28rpx;
}

.back-text {
  font-size: 26rpx;
  color: #0A2A25;
}

.logo {
  width: 190rpx;
  height: 58rpx;
}

.profile-bubble {
  position: relative;
  width: 78rpx;
  height: 78rpx;
}

.profile {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 3rpx solid white;
  box-shadow: 0 14rpx 26rpx rgba(0, 0, 0, 0.18);
}

.speech-tail {
  position: absolute;
  right: -10rpx;
  bottom: 8rpx;
  width: 18rpx;
  height: 18rpx;
  background: white;
  border-radius: 4rpx;
  transform: rotate(45deg);
}
.hero {
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
  align-items: flex-end; 
}

.hero-title {
  width: 60%;
  font-weight: bold;
  color: #000; 
}
.hero-image {
  width: 260rpx;
  height: 260rpx;
  border-radius: 10rpx;
}

/* CALENDAR */

.calendar-card {
  background: #70B682;

  border-radius: 0rpx 0rpx 0 0; 
  padding: 22rpx;
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.12);
}

.action-wrapper {
  margin: 20rpx 20rpx 30rpx;
  display: flex;
  justify-content: center;
}

.month-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.month-btn {
  background: white;
  border-radius: 50%;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.month-title {
  color: white;
  font-weight: bold;
}

/* WEEK */

.week-row {
  display: flex;
  margin-top: 20rpx;
}

.week-day {
  width: 14.28%;
  text-align: center;
  color: rgba(255,255,255,0.8);
}

/* GRID */

.days-grid {
  display: flex;
  flex-wrap: wrap;
  margin-top: 10rpx;
}

.day-wrapper {
  width: 14.28%;
  display: flex;
  justify-content: center;
  margin-bottom: 10rpx;
}

.day {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
}

.day.active {
  background: white;
  color: #0F3C36;
  font-weight: bold;
}

.empty {
  width: 60rpx;
  height: 60rpx;
}
 